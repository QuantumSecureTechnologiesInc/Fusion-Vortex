use serde::{Deserialize, Serialize};
#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize, Default)]
pub struct Span {
    pub start: FSize,
    pub end: FSize,
    pub line: FU32,
    pub col: FU32,
}
impl Span {
    pub fn new(start: FSize, end: FSize, line: FU32, col: FU32) -> Self {
        Self { start, end, line, col }
    }
}
