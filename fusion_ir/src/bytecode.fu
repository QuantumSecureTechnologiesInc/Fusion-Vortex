use serde::{Deserialize, Serialize};
#[derive(Debug, Clone, Copy, Serialize, Deserialize)]
pub enum Op {
    Const(FU32),
    LoadLocal(u8),
    StoreLocal(u8),
    Dup,
    Pop,
    Add,
    Sub,
    Mul,
    Div,
    Eq,
    Lt,
    Gt,
    JumpIfFalse(FInt),
    Jump(FInt),
    Call(FU32),
    Ret,
    Println,
}
