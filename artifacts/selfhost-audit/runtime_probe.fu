extern fn puts(s: string) -> int;
extern fn fusion_argc() -> int;
extern fn fusion_argv(idx: int) -> string;

pub fn main() -> int {
    puts("runtime_probe_start");
    let c = fusion_argc();
    if c > 0 {
        let a0 = fusion_argv(0);
        if a0 == "" {
            puts("argv0_empty");
        } else {
            puts("argv0_present");
        }
    }
    return 0;
}