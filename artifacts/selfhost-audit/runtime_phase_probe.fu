extern fn printf(fmt: string, ...) -> int;
extern fn fusion_parse_file_status(path: string) -> int;
extern fn fusion_sema_file_status(path: string) -> int;

pub fn main() -> int {
    let p = fusion_parse_file_status("crates\\fuc\\src\\main.fu");
    let s = fusion_sema_file_status("crates\\fuc\\src\\main.fu");
    printf("p=%d s=%d\n", p, s);
    return 0;
}
