mod stage1_parser_api;
mod stage1_sema_api;
mod ast;
mod lexer;
mod parser;
mod sema;
extern fn printf(fmt: string, ...) -> int;

pub fn main() -> int {
    let p1 = stage1_parser_api::parse_file("crates/fuc/tests/fixtures/hello_world.fu");
    let s1 = stage1_sema_api::sema_file("crates/fuc/tests/fixtures/hello_world.fu");
    let p2 = stage1_parser_api::parse_file("crates/fuc/src/__missing_stage1_target__.fu");
    printf("p1=%d s1=%d p2=%d\n", p1, s1, p2);
    return 0;
}
