---
# Clangd configuration for Fusion Programming Language
# Suppresses CUDA-related errors when CUDA toolkit is not installed

CompileFlags:
  Add:
    # Suppress CUDA warnings when toolkit is not available
    - "-Wno-unknown-cuda-version"
    - "-nocudalib"
    - "-nocudainc"
  
Diagnostics:
  # Suppress specific CUDA-related errors/warnings
  Suppress:
    - "libdevice"
    - "cuda_runtime.h"
    - "CUDA installation"
  
  # Clangd treats .cu files as CUDA by default
  # If CUDA is not installed, treat them as C++ to reduce noise
  UnusedIncludes: None
  MissingIncludes: None
