use serde::{Deserialize, Serialize};
/// An agent execution plan
///
/// Plans are composed of steps, each with explicit rationale.
/// This allows explainability without LLM hallucinations - the rationale is stored, replayed, audited.
#[derive(Debug, Clone, Serialize, Deserialize, PartialEq)]
struct AgentPlan {
    /// Unique plan identifier
    pub plan_id: FString,
    /// Overall goal of the plan
    pub goal: FString,
    /// Sequence of steps to execute
    pub steps: FVec<PlanStep>,
    /// Estimated total cost (arbitrary units)
    pub estimated_cost: f64,
}
/// A single step in an agent plan
#[derive(Debug, Clone, Serialize, Deserialize, PartialEq)]
struct PlanStep {
    /// Unique step identifier
    pub id: FString,
    /// Tool to execute
    pub tool: FString,
    /// Tool input parameters
    pub input: serde_json::Value,
    /// Human-readable rationale for this step
    pub rationale: FString,
    /// Cost estimate for this step
    pub cost_estimate: f64,
    /// Dependencies on other steps (step IDs)
    pub dependencies: FVec<FString>,
}
impl AgentPlan {
    /// Create a new agent plan
    pub fn new(plan_id: impl Into<FString>, goal: impl Into<FString>) -> Self {
        Self {
            plan_id: plan_id.into(),
            goal: goal.into(),
            steps: vec![],
            estimated_cost: 0.0,
        }
    }
    /// Add a step to the plan
    pub fn add_step(&mut self, step: PlanStep) {
        self.estimated_cost += step.cost_estimate;
        self.steps.push(step);
    }
    /// Get the number of steps in the plan
    pub fn step_count(&self) -> FSize {
        self.steps.len()
    }
    /// Check if the plan is empty
    pub fn is_empty(&self) -> FBool {
        self.steps.is_empty()
    }
}
impl PlanStep {
    /// Create a new plan step
    pub fn new(
        id: impl Into<FString>,
        tool: impl Into<FString>,
        input: serde_json::Value,
        rationale: impl Into<FString>,
        cost_estimate: f64,
    ) -> Self {
        Self {
            id: id.into(),
            tool: tool.into(),
            input,
            rationale: rationale.into(),
            cost_estimate,
            dependencies: vec![],
        }
    }
    /// Add a dependency to this step
    pub fn add_dependency(&mut self, step_id: impl Into<FString>) {
        self.dependencies.push(step_id.into());
    }
}
#[cfg(test)]
mod tests {
    use super::*;
    use serde_json::json;
    #[test]
    fn test_plan_creation() {
        let mut plan = AgentPlan::new("plan-1", "Complete task");
        let step = PlanStep::new(
            "step-1",
            "read_file",
            json!({ "path" : "test.txt" }),
            "Need to read the file to analyze its contents",
            1.0,
        );
        plan.add_step(step);
        assert_eq!(plan.step_count(), 1);
        assert_eq!(plan.estimated_cost, 1.0);
        assert!(! plan.is_empty());
    }
    #[test]
    fn test_step_dependencies() {
        let mut step1 = PlanStep::new(
            "step-1",
            "read_file",
            json!({ "path" : "input.txt" }),
            "Read input",
            1.0,
        );
        let mut step2 = PlanStep::new(
            "step-2",
            "process_data",
            json!({}),
            "Process the data from step-1",
            2.0,
        );
        step2.add_dependency("step-1");
        assert_eq!(step1.dependencies.len(), 0);
        assert_eq!(step2.dependencies.len(), 1);
        assert_eq!(step2.dependencies[0], "step-1");
    }
    #[test]
    fn test_plan_serialization() {
        let mut plan = AgentPlan::new("plan-1", "Test goal");
        plan.add_step(
            PlanStep::new(
                "step-1",
                "tool1",
                json!({ "param" : "value" }),
                "Test rationale",
                5.0,
            ),
        );
        let json = serde_json::to_string(&plan).unwrap();
        let deserialized: AgentPlan = serde_json::from_str(&json).unwrap();
        assert_eq!(plan, deserialized);
    }
}
