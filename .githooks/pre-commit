#!/usr/bin/env bash
# Fusion Pre-commit Hook
# Enforces Fusion Flux Engine policy before commits

set -e

# Colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "🔍 Checking Fusion Build Policy compliance..."

# Check for prohibited cargo commands in staged files
STAGED_FILES=$(git diff --cached --name-only)
VIOLATIONS=0

# Check for direct cargo invocations in scripts
for file in $STAGED_FILES; do
    if [[ -f "$file" ]]; then
        case "$file" in
            *.sh|*.ps1|*.bash|*.yml|*.yaml|Makefile)
                # Check for cargo build/test/run commands
                if grep -qE "(^|[^#])(cargo (build|test|run|check))" "$file" 2>/dev/null; then
                    # Exempt runtime directory and CI workflow files
                    if [[ ! "$file" =~ ^runtime/ ]] && [[ ! "$file" =~ ^.github/workflows/ ]]; then
                        echo -e "${RED}❌ Policy violation in: $file${NC}"
                        echo "   Contains prohibited 'cargo' command"
                        echo "   Use 'fusion build/test/run' instead"
                        VIOLATIONS=$((VIOLATIONS + 1))
                    fi
                fi
                ;;
        esac
    fi
done

# Check BUILD_POLICY.md is not being removed
if git diff --cached --name-status | grep -q "^D.*BUILD_POLICY.md"; then
    echo -e "${RED}❌ Cannot delete BUILD_POLICY.md${NC}"
    echo "   This file is required for policy enforcement"
    VIOLATIONS=$((VIOLATIONS + 1))
fi

# Check .fusion/build-policy.json is not being removed
if git diff --cached --name-status | grep -q "^D.*.fusion/build-policy.json"; then
    echo -e "${RED}❌ Cannot delete .fusion/build-policy.json${NC}"
    echo "   This file is required for policy enforcement"
    VIOLATIONS=$((VIOLATIONS + 1))
fi

# Report results
if [ $VIOLATIONS -gt 0 ]; then
    echo ""
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}Build policy violations detected: $VIOLATIONS${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "Please fix the violations above before committing."
    echo "See BUILD_POLICY.md for details."
    echo ""
    echo "To bypass (emergency only):"
    echo "  git commit --no-verify"
    echo ""
    exit 1
else
    echo "✅ Build policy compliance check passed"
    exit 0
fi
