{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "cd ../../fusion-visual-ui && npm run dev",
    "beforeBuildCommand": "cd ../../fusion-visual-ui && npm run build",
    "devPath": "http://localhost:3000",
    "distDir": "../../fusion-visual-ui/out",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Fusion Visual Compiler",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": true
      },
      "fs": {
        "all": true,
        "scope": ["$APPDATA/*", "$DESKTOP/*", "$DOCUMENT/*"]
      }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "© 2026 QuantumSecure Technologies Ltd",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.quantumsecure.fusion-visual-compiler",
      "longDescription": "Fusion Visual Compiler - A next-generation IDE powered by Supernova Runtime v3.0, Fusion Forge, and ReactorCLI. Build quantum-native applications with AI-assisted code generation.",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "Quantum-Native Visual Compiler",
      "targets": ["msi", "nsis"],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "wix": {
          "language": "en-US"
        }
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "Fusion Visual Compiler",
        "width": 1400,
        "minWidth": 1200,
        "minHeight": 700,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ]
  }
}
