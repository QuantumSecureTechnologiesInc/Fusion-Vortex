//! Help text and documentation
const LONG_ABOUT: &str = r#"
Fusion VSC CLI Coder - Advanced Agent Orchestration

Combines the best of Antigravity IDE, Claude Code, and Codex:
  • Planning/Fast agent modes
  • Continuous context and interrupts
  • Task group breakdown
  • Review policy enforcement
  • Hierarchical settings

QUICK START:
  fusion-coder                    # Start interactive (Planning mode)
  fusion-coder --mode fast        # Start in Fast mode
  fusion-coder --secure           # Enable secure mode
  fusion-coder resume --last      # Resume last session

EXAMPLES:
  # Complex feature with security
  fusion-coder --mode planning --secure
  
  # Quick fix
  fusion-coder --mode fast
  
  # Automated testing
  fusion-coder exec "run all tests" --json
  
  # Generate completions
  fusion-coder completion bash > /etc/bash_completion.d/fusion-coder

MODES:
  planning    Deep research, task breakdown, artifacts (default)
  fast        Direct execution, quick responses

For more info: See USER_GUIDE.md or run 'fusion-coder help <command>'
"#;
const RESUME_HELP: &str = r#"Resume a previous coding session

Sessions are stored in ~/.fusion-coder/sessions/

USAGE:
  fusion-coder resume [OPTIONS] [SESSION_ID]

OPTIONS:
  --last    Resume the most recent session

EXAMPLES:
  fusion-coder resume                    # Pick from list
  fusion-coder resume --last             # Resume last
  fusion-coder resume abc-123-def        # Resume specific ID
"#;
const EXEC_HELP: &str = r#"Execute a task in non-interactive mode

Perfect for automation, CI/CD, and scripting.

USAGE:
  fusion-coder exec [OPTIONS] <TASK>

OPTIONS:
  --json    Output results in JSON format

EXAMPLES:
  fusion-coder exec "implement user authentication"
  fusion-coder exec "run tests and fix failures" --json
  fusion-coder exec "refactor authentication module"
"#;
const COMPLETION_HELP: &str = r#"Generate shell completion scripts

USAGE:
  fusion-coder completion <SHELL>

SHELLS:
  bash, zsh, fish

EXAMPLES:
  # Bash
  fusion-coder completion bash > /etc/bash_completion.d/fusion-coder
  
  # Zsh
  fusion-coder completion zsh > ~/.zsh/completion/_fusion-coder
  
  # Fish
  fusion-coder completion fish > ~/.config/fish/completions/fusion-coder.fish
"#;
const AGENT_MODES_HELP: &str = r#"
AGENT MODES

Planning Mode (--mode planning):
  • Deep research and analysis
  • Task breakdown into subtasks
  • Artifact generation (plans, walkthroughs)
  • Comprehensive testing
  • Best for: Complex features, refactoring, new implementations

Fast Mode (--mode fast):
  • Direct execution
  • No task breakdown
  • Minimal artifacts
  • Quick responses
  • Best for: Bug fixes, simple changes, quick tasks

Switch modes anytime during session with /mode command.
"#;
const SECURE_MODE_HELP: &str = r#"
SECURE MODE (--secure)

Enhanced security features:
  ✓ Workspace isolation (no access outside project)
  ✓ URL allowlist/denylist enforcement
  ✓ .gitignore file respect
  ✓ Forced review for all terminal commands
  ✓ Forced review for all browser actions
  ✓ Path validation

Perfect for sensitive codebases or untrusted environments.
"#;
fn print_topic_help(topic: &str) {
    match topic {
        "modes" | "mode" => println!("{}", AGENT_MODES_HELP),
        "secure" | "security" => println!("{}", SECURE_MODE_HELP),
        "resume" => println!("{}", RESUME_HELP),
        "exec" => println!("{}", EXEC_HELP),
        "completion" | "completions" => println!("{}", COMPLETION_HELP),
        _ => {
            println!("Unknown help topic: {}", topic);
            println!("\nAvailable topics:");
            println!("  modes       Agent modes (Planning/Fast)");
            println!("  secure      Secure mode features");
            println!("  resume      Resume sessions");
            println!("  exec        Non-interactive execution");
            println!("  completion  Shell completions");
        }
    }
}
