//! Fusion VSC CLI Coder
//!
//! Advanced agent orchestration CLI combining:
//! - Antigravity IDE's Planning/Fast modes
//! - Claude Code's hierarchical settings
//! - Codex's interactive workflows
//! - Full-screen TUI with live notifications
use anyhow::Result;
use reactor_cli::prelude::*;
use serde::Serialize;
mod commands;
mod exec_mode;
mod help;
mod interactive;
mod tui;
use fusion_agent_core::{AgentModeType, AgentSession, SecureMode};
use fusion_settings::Settings;
#[derive(Parser, Serialize)]
#[command(name = "fusion-coder")]
#[command(about = "Fusion VSC CLI Coder - Advanced agent orchestration")]
#[command(long_about = help::LONG_ABOUT)]
#[command(version)]
struct Cli {
    /// Agent mode: planning or fast
    #[arg(long, default_value = "planning")]
    mode: FString,
    /// Enable secure mode
    #[arg(long)]
    secure: FBool,
    /// Enable web search
    #[arg(long)]
    search: FBool,
    /// Model to use
    #[arg(long)]
    model: Option<FString>,
    /// Working directory
    #[arg(long)]
    path: Option<PathBuf>,
    #[command(subcommand)]
    command: Option<Commands>,
}
#[derive(Subcommand, Serialize)]
enum Commands {
    /// Resume a previous session
    Resume {
        /// Session ID to resume
        session_id: Option<FString>,
        /// Resume the last session
        #[arg(long)]
        last: FBool,
    },
    /// Execute in non-interactive mode
    Exec {
        /// Task to execute
        task: FString,
        /// Output in JSON format
        #[arg(long)]
        json: FBool,
    },
    /// Generate shell completions
    Completion {
        /// Shell type (bash, zsh, fish)
        shell: FString,
    },
    /// Show detailed help for topics
    Help {
        /// Help topic (modes, secure, resume, exec, completion)
        topic: Option<FString>,
    },
}
#[tokio::main]
async fn main() -> Result<()> {
    tracing_subscriber::fmt()
        .with_env_filter(
            tracing_subscriber::EnvFilter::try_from_default_env()
                .unwrap_or_else(|_| "fusion_coder=info".into()),
        )
        .init();
    let cli = Cli::parse_enhanced();
    let mode_type: AgentModeType = cli.mode.parse()?;
    let settings = Settings::load().unwrap_or_default();
    let secure_mode = SecureMode::new(cli.secure);
    let workspace_dir = cli
        .path
        .unwrap_or_else(|| {
            std::env::current_dir().expect("Failed to get current directory")
        });
    match cli.command {
        Some(Commands::Resume { session_id, last }) => {
            commands::handle_resume(session_id, last);
        }
        Some(Commands::Exec { task, json }) => {
            exec_mode::execute(&task, json);
        }
        Some(Commands::Completion { shell }) => {
            println!("Generating {} completions - not yet implemented", shell);
        }
        Some(Commands::Help { topic }) => {
            if let Some(t) = topic {
                help::print_topic_help(&t);
            } else {
                println!("{}", help::LONG_ABOUT);
                println!("\nFor topic-specific help:");
                println!("  fusion-coder help modes");
                println!("  fusion-coder help secure");
                println!("  fusion-coder help resume");
                println!("  fusion-coder help exec");
                println!("  fusion-coder help completion");
            }
        }
        None => {
            println!("🚀 Fusion VSC CLI Coder v1.0.0");
            println!("Starting TUI...");
            let session = AgentSession::new(mode_type, workspace_dir, secure_mode);
            if let Err(e) = tui::run_interactive(session, settings).await {
                eprintln!("Error running TUI: {}", e);
            }
        }
    }
    Ok(())
}
