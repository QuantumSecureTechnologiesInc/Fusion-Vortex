use anyhow::{Context, Result};
use crate::commands::quantum_env::expand_env;
use std::path::{Path, PathBuf};
use toml::Value;

struct AiConfig {
    provider: Option<String>,
    default_device: Option<String>,
    mixed_precision: Option<bool>,
    gradient_checkpointing: Option<bool>,
    batch_size: Option<u32>,
    timeout: Option<String>,
    quantization: Option<String>,
    dist_backend: Option<String>,
    world_size: Option<u32>,
    rank: Option<u32>,
    ollama_base_url: Option<String>,
    ollama_model: Option<String>,
    qwen_api_key: Option<String>,
    qwen_base_url: Option<String>,
    qwen_model: Option<String>,
    deepseek_api_key: Option<String>,
    deepseek_base_url: Option<String>,
    deepseek_model: Option<String>,
    gpt_oss_base_url: Option<String>,
    gpt_oss_model: Option<String>,
    mistral_api_key: Option<String>,
    mistral_base_url: Option<String>,
    mistral_model: Option<String>,
    phi_base_url: Option<String>,
    phi_model: Option<String>,
    gemma_base_url: Option<String>,
    gemma_model: Option<String>,
}

pub fn apply_ai_env(cmd: &mut std::process::Command) -> Result<()> {
    let manifest = find_fusion_manifest()?;
    if manifest.is_none() {
        return Ok(());
    }
    let config = load_ai_config(manifest.as_ref().unwrap())?;
    if let Some(device) = &config.default_device {
        cmd.env("FUSION_AI_DEVICE", device);
    }
    if let Some(provider) = &config.provider {
        cmd.env("FUSION_AI_PROVIDER", provider);
    }
    if let Some(enabled) = config.mixed_precision {
        cmd.env("FUSION_AI_MIXED_PRECISION", enabled.to_string());
    }
    if let Some(enabled) = config.gradient_checkpointing {
        cmd.env("FUSION_AI_GRADIENT_CHECKPOINTING", enabled.to_string());
    }
    if let Some(batch) = config.batch_size {
        cmd.env("FUSION_AI_BATCH_SIZE", batch.to_string());
    }
    if let Some(timeout) = &config.timeout {
        cmd.env("FUSION_AI_TIMEOUT", timeout);
    }
    if let Some(quant) = &config.quantization {
        cmd.env("FUSION_AI_QUANTIZATION", quant);
    }
    if let Some(backend) = &config.dist_backend {
        cmd.env("FUSION_AI_DIST_BACKEND", backend);
    }
    if let Some(world) = config.world_size {
        cmd.env("FUSION_AI_WORLD_SIZE", world.to_string());
    }
    if let Some(rank) = config.rank {
        cmd.env("FUSION_AI_RANK", rank.to_string());
    }
    if let Some(url) = &config.ollama_base_url {
        cmd.env("OLLAMA_BASE_URL", url);
    }
    if let Some(model) = &config.ollama_model {
        cmd.env("OLLAMA_MODEL", model);
    }
    if let Some(key) = &config.qwen_api_key {
        cmd.env("QWEN_API_KEY", key);
    }
    if let Some(url) = &config.qwen_base_url {
        cmd.env("QWEN_BASE_URL", url);
    }
    if let Some(model) = &config.qwen_model {
        cmd.env("QWEN_MODEL", model);
    }
    if let Some(key) = &config.deepseek_api_key {
        cmd.env("DEEPSEEK_API_KEY", key);
    }
    if let Some(url) = &config.deepseek_base_url {
        cmd.env("DEEPSEEK_BASE_URL", url);
    }
    if let Some(model) = &config.deepseek_model {
        cmd.env("DEEPSEEK_MODEL", model);
    }
    if let Some(url) = &config.gpt_oss_base_url {
        cmd.env("GPT_OSS_BASE_URL", url);
    }
    if let Some(model) = &config.gpt_oss_model {
        cmd.env("GPT_OSS_MODEL", model);
    }
    if let Some(key) = &config.mistral_api_key {
        cmd.env("MISTRAL_API_KEY", key);
    }
    if let Some(url) = &config.mistral_base_url {
        cmd.env("MISTRAL_BASE_URL", url);
    }
    if let Some(model) = &config.mistral_model {
        cmd.env("MISTRAL_MODEL", model);
    }
    if let Some(url) = &config.phi_base_url {
        cmd.env("PHI_BASE_URL", url);
    }
    if let Some(model) = &config.phi_model {
        cmd.env("PHI_MODEL", model);
    }
    if let Some(url) = &config.gemma_base_url {
        cmd.env("GEMMA_BASE_URL", url);
    }
    if let Some(model) = &config.gemma_model {
        cmd.env("GEMMA_MODEL", model);
    }
    Ok(())
}

pub fn apply_ai_env_to_process() -> Result<()> {
    let manifest = find_fusion_manifest()?;
    if manifest.is_none() {
        return Ok(());
    }
    let config = load_ai_config(manifest.as_ref().unwrap())?;
    if let Some(device) = &config.default_device {
        std::env::set_var("FUSION_AI_DEVICE", device);
    }
    if let Some(enabled) = config.mixed_precision {
        std::env::set_var("FUSION_AI_MIXED_PRECISION", enabled.to_string());
    }
    if let Some(enabled) = config.gradient_checkpointing {
        std::env::set_var(
            "FUSION_AI_GRADIENT_CHECKPOINTING",
            enabled.to_string(),
        );
    }
    if let Some(batch) = config.batch_size {
        std::env::set_var("FUSION_AI_BATCH_SIZE", batch.to_string());
    }
    if let Some(timeout) = &config.timeout {
        std::env::set_var("FUSION_AI_TIMEOUT", timeout);
    }
    if let Some(quant) = &config.quantization {
        std::env::set_var("FUSION_AI_QUANTIZATION", quant);
    }
    if let Some(backend) = &config.dist_backend {
        std::env::set_var("FUSION_AI_DIST_BACKEND", backend);
    }
    if let Some(world) = config.world_size {
        std::env::set_var("FUSION_AI_WORLD_SIZE", world.to_string());
    }
    if let Some(rank) = config.rank {
        std::env::set_var("FUSION_AI_RANK", rank.to_string());
    }
    Ok(())
}

fn find_fusion_manifest() -> Result<Option<PathBuf>> {
    let mut dir = std::env::current_dir().context("Failed to resolve current directory")?;
    loop {
        let candidate = dir.join("Fusion.toml");
        if candidate.exists() {
            return Ok(Some(candidate));
        }
        if !dir.pop() {
            return Ok(None);
        }
    }
}

fn load_ai_config(path: &Path) -> Result<AiConfig> {
    let content = std::fs::read_to_string(path)
        .with_context(|| format!("Failed to read {}", path.display()))?;
    let doc: Value = content.parse().context("Failed to parse Fusion.toml")?;
    let ai = doc.get("ai");
    let serving = ai.and_then(|v| v.get("serving"));
    let distributed = ai.and_then(|v| v.get("distributed"));
    let ollama = ai.and_then(|v| v.get("ollama"));
    let qwen = ai.and_then(|v| v.get("qwen"));
    let deepseek = ai.and_then(|v| v.get("deepseek"));
    let gpt_oss = ai.and_then(|v| v.get("gpt_oss"));
    let mistral = ai.and_then(|v| v.get("mistral"));
    let phi = ai.and_then(|v| v.get("phi"));
    let gemma = ai.and_then(|v| v.get("gemma"));
    Ok(AiConfig {
        provider: ai
            .and_then(|v| v.get("provider"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        default_device: ai
            .and_then(|v| v.get("default_device"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        mixed_precision: ai
            .and_then(|v| v.get("mixed_precision"))
            .and_then(Value::as_bool),
        gradient_checkpointing: ai
            .and_then(|v| v.get("gradient_checkpointing"))
            .and_then(Value::as_bool),
        batch_size: serving
            .and_then(|v| v.get("batch_size"))
            .and_then(Value::as_integer)
            .map(|v| v as u32),
        timeout: serving
            .and_then(|v| v.get("timeout"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        quantization: serving
            .and_then(|v| v.get("quantization"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        dist_backend: distributed
            .and_then(|v| v.get("backend"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        world_size: distributed
            .and_then(|v| v.get("world_size"))
            .and_then(Value::as_integer)
            .map(|v| v as u32),
        rank: distributed
            .and_then(|v| v.get("rank"))
            .and_then(Value::as_integer)
            .map(|v| v as u32),
        ollama_base_url: ollama
            .and_then(|v| v.get("base_url"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        ollama_model: ollama
            .and_then(|v| v.get("model"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        qwen_api_key: qwen
            .and_then(|v| v.get("api_key"))
            .and_then(Value::as_str)
            .map(expand_env),
        qwen_base_url: qwen
            .and_then(|v| v.get("base_url"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        qwen_model: qwen
            .and_then(|v| v.get("model"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        deepseek_api_key: deepseek
            .and_then(|v| v.get("api_key"))
            .and_then(Value::as_str)
            .map(expand_env),
        deepseek_base_url: deepseek
            .and_then(|v| v.get("base_url"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        deepseek_model: deepseek
            .and_then(|v| v.get("model"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        gpt_oss_base_url: gpt_oss
            .and_then(|v| v.get("base_url"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        gpt_oss_model: gpt_oss
            .and_then(|v| v.get("model"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        mistral_api_key: mistral
            .and_then(|v| v.get("api_key"))
            .and_then(Value::as_str)
            .map(expand_env),
        mistral_base_url: mistral
            .and_then(|v| v.get("base_url"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        mistral_model: mistral
            .and_then(|v| v.get("model"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        phi_base_url: phi
            .and_then(|v| v.get("base_url"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        phi_model: phi
            .and_then(|v| v.get("model"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        gemma_base_url: gemma
            .and_then(|v| v.get("base_url"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
        gemma_model: gemma
            .and_then(|v| v.get("model"))
            .and_then(Value::as_str)
            .map(|v| v.to_string()),
    })
}
