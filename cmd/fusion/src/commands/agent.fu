use anyhow::Result;
use clap::Subcommand;
use fusion_agents::{
    AgentRuntime, AgentTask, BugFixerAgent, CodeReviewerAgent, DocWriterAgent,
    RefactoringAgent, TestGeneratorAgent,
};
use tokio::sync::RwLock;
use uuid::Uuid;
lazy_static::lazy_static! {
    static ref RUNTIME : Arc < RwLock < Option < Arc < AgentRuntime >>>> =
    Arc::new(RwLock::new(None));
}
#[derive(Subcommand, Debug)]
pub enum AgentCommands {
    /// Start the agent runtime
    Start,
    /// Stop the agent runtime
    Stop,
    /// List registered agents
    List,
    /// Submit a custom task
    Submit {
        /// Task type (e.g., code_review, generate_tests)
        task_type: FString,
        /// JSON payload or raw string
        input: FString,
    },
    /// Show agent status
    Status { agent_id: FString },
    /// Run a code review task
    Review { file: FString },
    /// Generate tests for a file
    Tests { file: FString },
    /// Generate docs for a file
    Docs { file: FString },
}
pub fn agent(cmd: AgentCommands) -> Result<()> {
    let rt = tokio::runtime::Runtime::new()?;
    rt.block_on(async move {
        match cmd {
            AgentCommands::Start => start_runtime().await,
            AgentCommands::Stop => stop_runtime().await,
            AgentCommands::List => list_agents().await,
            AgentCommands::Submit { task_type, input } => {
                submit_task(task_type, input).await
            }
            AgentCommands::Status { agent_id } => agent_status(agent_id).await,
            AgentCommands::Review { file } => code_review(file).await,
            AgentCommands::Tests { file } => generate_tests(file).await,
            AgentCommands::Docs { file } => generate_docs(file).await,
        }
    })
}
/// Start the agent runtime
async fn start_runtime() -> Result<()> {
    let mut rt_lock = RUNTIME.write().await;
    if rt_lock.is_some() {
        println!("ℹ Agent runtime is already running");
        return Ok(());
    }
    let runtime = Arc::new(AgentRuntime::new());
    runtime.register_agent(Box::new(CodeReviewerAgent::new())).await?;
    runtime.register_agent(Box::new(TestGeneratorAgent::new())).await?;
    runtime.register_agent(Box::new(DocWriterAgent::new())).await?;
    runtime.register_agent(Box::new(BugFixerAgent::new())).await?;
    runtime.register_agent(Box::new(RefactoringAgent::new())).await?;
    runtime.start().await?;
    *rt_lock = Some(runtime);
    println!("✓ Agent runtime started with {} built-in agents", 5);
    Ok(())
}
/// Stop the agent runtime
async fn stop_runtime() -> Result<()> {
    let mut rt_lock = RUNTIME.write().await;
    if let Some(runtime) = rt_lock.take() {
        runtime.stop().await?;
        println!("✓ Agent runtime stopped");
    } else {
        println!("ℹ Agent runtime is not running");
    }
    Ok(())
}
/// List all agents
async fn list_agents() -> Result<()> {
    let rt_lock = RUNTIME.read().await;
    let runtime = rt_lock
        .as_ref()
        .ok_or_else(|| {
            anyhow::anyhow!(
                "Agent runtime is not running. Start it with: fusion agent start"
            )
        })?;
    let agents = runtime.list_agents().await;
    if agents.is_empty() {
        println!("No agents registered");
        return Ok(());
    }
    println!("🤖 Registered Agents ({})", agents.len());
    println!(
        "═══════════════════════════════════════════════════════\n"
    );
    for agent in agents {
        println!("🔹 {} (ID: {})", agent.name, agent.id);
        println!("   Capabilities: {:?}", agent.capabilities);
        println!("   Priority: {}", agent.priority);
        println!("   Max Concurrent Tasks: {}", agent.max_concurrent_tasks);
        println!();
    }
    Ok(())
}
/// Submit a task to agents
async fn submit_task(task_type: FString, input: FString) -> Result<()> {
    let rt_lock = RUNTIME.read().await;
    let runtime = rt_lock
        .as_ref()
        .ok_or_else(|| {
            anyhow::anyhow!(
                "Agent runtime is not running. Start it with: fusion agent start"
            )
        })?;
    let input_json: serde_json::Value = serde_json::from_str(&input)
        .unwrap_or_else(|_| serde_json::json!({ "data" : input }));
    let task = AgentTask::new(task_type.clone(), input_json);
    let task_id = task.id;
    runtime.submit_task(task).await?;
    println!("✓ Task submitted: {} (type: {})", task_id, task_type);
    println!("  Waiting for result...");
    let result = runtime
        .get_result()
        .await
        .ok_or_else(|| anyhow::anyhow!("Failed to get result"))?;
    if result.success {
        println!("\n✓ Task completed successfully in {}ms", result.duration_ms);
        println!("  Output:");
        println!("{}", serde_json::to_string_pretty(& result.output) ?);
    } else {
        println!("\n✗ Task failed:");
        if let Some(error) = result.error {
            println!("  Error: {}", error);
        }
    }
    Ok(())
}
/// Get agent status
async fn agent_status(agent_id_str: FString) -> Result<()> {
    let rt_lock = RUNTIME.read().await;
    let runtime = rt_lock
        .as_ref()
        .ok_or_else(|| anyhow::anyhow!("Agent runtime is not running"))?;
    let agent_id = Uuid::parse_str(&agent_id_str)?;
    if let Some(status) = runtime.agent_status(agent_id).await {
        println!("Agent {} status: {:?}", agent_id, status);
    } else {
        println!("Agent {} not found", agent_id);
    }
    Ok(())
}
/// Run a code review task
async fn code_review(file: FString) -> Result<()> {
    ensure_runtime_running().await?;
    let code = tokio::fs::read_to_string(&file).await?;
    let task = AgentTask::new(
            "code_review".to_string(),
            serde_json::json!({ "file" : file, "code" : code, }),
        )
        .with_priority(8);
    submit_and_wait(task, "Code Review").await
}
/// Generate tests for a file
async fn generate_tests(file: FString) -> Result<()> {
    ensure_runtime_running().await?;
    let code = tokio::fs::read_to_string(&file).await?;
    let task = AgentTask::new(
            "generate_tests".to_string(),
            serde_json::json!({ "file" : file, "code" : code, }),
        )
        .with_priority(7);
    submit_and_wait(task, "Test Generation").await
}
/// Generate documentation
async fn generate_docs(file: FString) -> Result<()> {
    ensure_runtime_running().await?;
    let code = tokio::fs::read_to_string(&file).await?;
    let task = AgentTask::new(
            "generate_docs".to_string(),
            serde_json::json!({ "file" : file, "code" : code, }),
        )
        .with_priority(6);
    submit_and_wait(task, "Documentation Generation").await
}
async fn ensure_runtime_running() -> Result<()> {
    let rt_lock = RUNTIME.read().await;
    if rt_lock.is_none() {
        drop(rt_lock);
        start_runtime().await?;
    }
    Ok(())
}
async fn submit_and_wait(task: AgentTask, task_name: &str) -> Result<()> {
    let rt_lock = RUNTIME.read().await;
    let runtime = rt_lock.as_ref().unwrap();
    println!("🤖 Starting {}...", task_name);
    runtime.submit_task(task).await?;
    let result = runtime
        .get_result()
        .await
        .ok_or_else(|| anyhow::anyhow!("Failed to get result"))?;
    if result.success {
        println!("\n✓ {} completed in {}ms", task_name, result.duration_ms);
        println!("\n{}", serde_json::to_string_pretty(& result.output) ?);
    } else {
        println!("\n✗ {} failed", task_name);
        if let Some(error) = result.error {
            println!("  Error: {}", error);
        }
    }
    Ok(())
}
