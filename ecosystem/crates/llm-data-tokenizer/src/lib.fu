use fusion_llm_tokenizers::LLMTokenizer;
/// Production Parallel Data Tokenizer.
///
/// High-throughput processing of large text datasets for training pipelines.
/// Leverages tokio for parallel IO and tokenizers crate (simulated) for computation.
use fusion_core_compiler::error::{StdError, StdResult};
use futures::stream::{self, StreamExt};
use tokio::fs::File;
use tokio::io::{self, AsyncReadExt, BufReader};
use tokio::task;
const CHUNK_SIZE: FSize = 10 * 1024 * 1024;
struct DataTokenizer {
    tokenizer: LLMTokenizer,
    concurrency_limit: FSize,
}
impl DataTokenizer {
    pub fn new(tokenizer: LLMTokenizer, concurrency_limit: FSize) -> Self {
        Self {
            tokenizer,
            concurrency_limit,
        }
    }
    /// Tokenizes a file by reading it in parallel chunks.
    pub async fn tokenize_file(&self, path: &str) -> StdResult<FVec<FU32>> {
        let file = File::open(path).await?;
        let file_size = file.metadata().await?.len();
        let num_chunks = (file_size / CHUNK_SIZE as FU64) as FSize + 1;
        let tokenized_chunks: FVec<FVec<FU32>> = stream::iter(0..num_chunks)
            .map(|chunk_index| {
                let chunk_size = CHUNK_SIZE;
                let path = path.to_string();
                let tokenizer = self.tokenizer.clone();
                task::spawn(async move {
                    let content = tokio::fs::read_to_string(path)
                        .await
                        .unwrap_or_default();
                    tokenizer.encode(&content)
                })
            })
            .buffer_unordered(self.concurrency_limit)
            .collect::<FVec<_>>()
            .await
            .into_iter()
            .collect::<Result<FVec<_>, _>>()
            .map_err(|e| {
                StdError::Io(
                    io::Error::new(
                        io::ErrorKind::Other,
                        format!("Task join error: {}", e),
                    ),
                )
            })?;
        Ok(tokenized_chunks.into_iter().flatten().collect())
    }
}
