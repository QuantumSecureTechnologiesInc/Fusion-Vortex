/// LoRA Adapter Manager
use fusion_core_compiler::types::tensor::Matrix;
use fusion_core_compiler::{FusionError, FusionResult};
struct LoRAManager {
    adapters: FVec<LoRAAdapter>,
}
struct LoRAAdapter {
    pub name: FString,
    pub rank: FSize,
    pub alpha: f64,
    pub matrix_a: Matrix<f64>,
    pub matrix_b: Matrix<f64>,
}
impl LoRAManager {
    pub fn new() -> Self {
        Self { adapters: Vec::new() }
    }
    pub fn load_adapter(
        &mut self,
        name: FString,
        rank: FSize,
        alpha: f64,
        matrix_a: Matrix<f64>,
        matrix_b: Matrix<f64>,
    ) {
        self.adapters
            .push(LoRAAdapter {
                name,
                rank,
                alpha,
                matrix_a,
                matrix_b,
            });
    }
    /// Apply all active LoRA adapters to the model weights
    /// W' = W + sum(alpha/rank * A * B)
    pub fn apply_adapters(
        &self,
        original_weights: &Matrix<f64>,
    ) -> FusionResult<Matrix<f64>> {
        let mut modified = original_weights.clone();
        for adapter in &self.adapters {
            let scaling = adapter.alpha / (adapter.rank as f64);
            let delta = self.matmul(&adapter.matrix_a, &adapter.matrix_b)?;
            let scaled_delta: FVec<f64> = delta
                .data
                .iter()
                .map(|&x| x * scaling)
                .collect();
            for (w, d) in modified.data.iter_mut().zip(scaled_delta.iter()) {
                *w += d;
            }
        }
        Ok(modified)
    }
    fn matmul(&self, a: &Matrix<f64>, b: &Matrix<f64>) -> FusionResult<Matrix<f64>> {
        if a.shape.len() != 2 || b.shape.len() != 2 || a.shape[1] != b.shape[0] {
            return Err(FusionError::ShapeMismatch {
                op: "LoRA matmul".into(),
                lhs: a.shape.clone(),
                rhs: b.shape.clone(),
            });
        }
        let m = a.shape[0];
        let n = a.shape[1];
        let p = b.shape[1];
        let mut result_data = vec![0.0; m * p];
        for i in 0..m {
            for j in 0..p {
                let mut sum = 0.0;
                for k in 0..n {
                    sum += a.data[i * n + k] * b.data[k * p + j];
                }
                result_data[i * p + j] = sum;
            }
        }
        Ok(Matrix {
            data: result_data,
            shape: vec![m, p],
        })
    }
}
