// Reactor CLI context (pure .fu)

extern fn fusion_env_get(key: string) -> string;
extern fn fusion_ipc_query(key: string) -> string;
extern fn strlen(s: string) -> int;

fn resolve_key(key: string) -> string {
    let env_key: string = "FUSION_";
    let val: string = fusion_env_get(key);
    if strlen(val) > 0 { return val; }
    let ipc_val: string = fusion_ipc_query(key);
    return ipc_val;
}

