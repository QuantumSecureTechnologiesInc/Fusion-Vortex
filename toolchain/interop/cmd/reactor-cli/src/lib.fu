// Reactor CLI core (pure .fu)

struct ReactorConfig {
    artifact: string,
    target: string,
    replicas: int,
}

fn reactor_config_new(artifact: string, target: string, replicas: int) -> ReactorConfig {
    let c: ReactorConfig = ReactorConfig { artifact: artifact, target: target, replicas: replicas };
    return c;
}

fn runtime_version() -> int {
    return 3; // Supernova
}

