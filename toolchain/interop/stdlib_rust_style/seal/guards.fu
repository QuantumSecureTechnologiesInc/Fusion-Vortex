// Guard layer (pure .fu)

extern fn string_starts_with(s: string, prefix: string) -> bool;

fn ensure_system_operational(active: bool) -> bool {
    if active { return true; }
    return false;
}

fn ensure_clearance(user_id: string) -> bool {
    if string_starts_with(user_id, "usr_") { return true; }
    return string_starts_with(user_id, "admin_");
}

