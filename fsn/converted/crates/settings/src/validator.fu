// SOURCE: crates/settings/src/validator.rs
// NOTE: Converted into FSN mirror under fsn/converted.
use crate::FusionSettings;
use anyhow::Result;

/// Settings validator
struct SettingsValidator;

impl SettingsValidator {
    fn new() -> Self {
        Self
    }

    /// Validate complete settings structure
    fn validate(&self, settings: &FusionSettings) -> Result<()> {
        self.validate_ai(&settings.ai)?;
        self.validate_github(&settings.github)?;
        self.validate_editor(&settings.editor)?;
        self.validate_projects(&settings.projects)?;
        self.validate_mcp(&settings.mcp)?;
        Ok(())
    }

    fn validate_ai(&self, ai: &crate::schema::AiSettings) -> Result<()> {
        // Validate model name
        if ai.default_model.is_empty() {
            anyhow::bail!("AI default_model cannot be empty");
        }

        // Validate max_tokens
        if ai.max_tokens == 0 {
            anyhow::bail!("AI max_tokens must be greater than 0");
        }
        if ai.max_tokens > 128000 {
            anyhow::bail!("AI max_tokens cannot exceed 128000");
        }

        // Validate temperature
        if ai.temperature < 0.0 || ai.temperature > 2.0 {
            anyhow::bail!("AI temperature must be between 0.0 and 2.0");
        }

        // Validate at least one provider has API key
        let has_key = ai.providers.openai.api_key.is_some()
            || ai.providers.anthropic.api_key.is_some()
            || ai.providers.google.api_key.is_some();

        if !has_key {
            tracing::warn!("No AI provider API keys configured");
        }

        Ok(())
    }

    fn validate_github(&self, github: &crate::schema::GitHubSettings) -> Result<()> {
        if let Some(visibility) = &github.default_visibility {
            if !["public", "private", "internal"].contains(&visibility.as_str()) {
                anyhow::bail!(
                    "GitHub default_visibility must be 'public', 'private', or 'internal'"
                );
            }
        }

        Ok(())
    }

    fn validate_editor(&self, editor: &crate::schema::EditorSettings) -> Result<()> {
        if editor.default.is_empty() {
            anyhow::bail!("Editor default cannot be empty");
        }

        if editor.terminal.is_empty() {
            anyhow::bail!("Editor terminal cannot be empty");
        }

        Ok(())
    }

    fn validate_projects(&self, projects: &crate::schema::ProjectSettings) -> Result<()> {
        if projects.workspace_dir.is_empty() {
            anyhow::bail!("Projects workspace_dir cannot be empty");
        }

        if projects.session_retention_days == 0 {
            anyhow::bail!("Projects session_retention_days must be greater than 0");
        }

        if projects.session_retention_days > 365 {
            tracing::warn!(
                "Projects session_retention_days is very high ({})",
                projects.session_retention_days
            );
        }

        Ok(())
    }

    fn validate_mcp(&self, _mcp: &crate::schema::McpSettings) -> Result<()> {
        // MCP settings are all optional
        Ok(())
    }
}

impl Default for SettingsValidator {
    fn default() -> Self {
        Self::new()
    }
}

#[cfg(test)]
mod tests {
    use super::*;
    use crate::FusionSettings;

    #[test]
    fn test_validate_default_settings() {
        let settings = FusionSettings::default();
        let validator = SettingsValidator::new();
        assert!(validator.validate(&settings).is_ok());
    }

    #[test]
    fn test_invalid_temperature() {
        let mut settings = FusionSettings::default();
        settings.ai.temperature = 3.0; // Invalid

        let validator = SettingsValidator::new();
        assert!(validator.validate(&settings).is_err());
    }

    #[test]
    fn test_invalid_max_tokens() {
        let mut settings = FusionSettings::default();
        settings.ai.max_tokens = 0; // Invalid

        let validator = SettingsValidator::new();
        assert!(validator.validate(&settings).is_err());
    }
}
