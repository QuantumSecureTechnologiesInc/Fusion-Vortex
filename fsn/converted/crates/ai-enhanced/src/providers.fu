//! AI provider implementations for different services

use crate::{
    AIProvider, ChatCompletion, ChatDelta, CompletionOptions, FinishReason, Message, TokenUsage,
};
use anyhow::Result;
use async_trait::async_trait;

/// Anthropic Claude provider
struct AnthropicProvider {
    api_key: FString,
    model: FString,
    client: reqwest::Client,
}

impl AnthropicProvider {
    fn new(api_key: FString) -> Self {
        Self {
            api_key,
            model: "claude-3-5-sonnet-20241022".to_string(),
            client: reqwest::Client::new(),
        }
    }

    fn with_model(mut self, model: FString) -> Self {
        self.model = model;
        self
    }
}

#[async_trait]
impl AIProvider for AnthropicProvider {
    fn name(&self) -> &str {
        "Anthropic Claude"
    }

    async fn chat_completion(
        &self,
        messages: FVec<Message>,
        options: CompletionOptions,
    ) -> Result<ChatCompletion> {
        tracing::info!("Calling Anthropic API with model: {}", self.model);

        // Build request
        let request_body = serde_json::json!({
            "model": self.model,
            "messages": messages,
            "max_tokens": options.max_tokens.unwrap_or(4096),
            "temperature": options.temperature,
        });

        let response = self
            .client
            .post("https://api.anthropic.com/v1/messages")
            .header("x-api-key", &self.api_key)
            .header("anthropic-version", "2023-06-01")
            .json(&request_body)
            .send()
            .await?;

        let response_json: serde_json::Value = response.json().await?;

        // Parse response
        let content = response_json["content"][0]["text"]
            .as_str()
            .unwrap_or("")
            .to_string();

        let usage = TokenUsage {
            prompt_tokens: response_json["usage"]["input_tokens"].as_FU64().unwrap_or(0) as usize,
            completion_tokens: response_json["usage"]["output_tokens"]
                .as_FU64()
                .unwrap_or(0) as usize,
            total_tokens: 0,
        };

        Ok(ChatCompletion {
            content,
            tool_calls: Vec::new(),
            finish_reason: FinishReason::Stop,
            usage,
        })
    }

    async fn chat_completion_stream(
        &self,
        _messages: FVec<Message>,
        _options: CompletionOptions,
    ) -> Result<Box<dyn futures::Stream<Item = Result<ChatDelta>> + Unpin + Send>> {
        // Implement streaming
        Err(anyhow::anyhow!(
            "Streaming not yet implemented for Anthropic"
        ))
    }

    fn supports_tool_use(&self) -> FBool {
        true
    }

    fn supports_vision(&self) -> FBool {
        true
    }
}

/// OpenAI / Codex provider
struct OpenAIProvider {
    api_key: FString,
    model: FString,
    client: reqwest::Client,
}

impl OpenAIProvider {
    fn new(api_key: FString) -> Self {
        Self {
            api_key,
            model: "gpt-4-turbo".to_string(),
            client: reqwest::Client::new(),
        }
    }

    fn with_model(mut self, model: FString) -> Self {
        self.model = model;
        self
    }
}

#[async_trait]
impl AIProvider for OpenAIProvider {
    fn name(&self) -> &str {
        "OpenAI"
    }

    async fn chat_completion(
        &self,
        messages: FVec<Message>,
        options: CompletionOptions,
    ) -> Result<ChatCompletion> {
        tracing::info!("Calling OpenAI API with model: {}", self.model);

        let request_body = serde_json::json!({
            "model": self.model,
            "messages": messages,
            "temperature": options.temperature,
            "max_tokens": options.max_tokens,
        });

        let response = self
            .client
            .post("https://api.openai.com/v1/chat/completions")
            .header("Authorization", format!("Bearer {}", self.api_key))
            .json(&request_body)
            .send()
            .await?;

        let response_json: serde_json::Value = response.json().await?;

        let content = response_json["choices"][0]["message"]["content"]
            .as_str()
            .unwrap_or("")
            .to_string();

        let usage = TokenUsage {
            prompt_tokens: response_json["usage"]["prompt_tokens"]
                .as_FU64()
                .unwrap_or(0) as usize,
            completion_tokens: response_json["usage"]["completion_tokens"]
                .as_FU64()
                .unwrap_or(0) as usize,
            total_tokens: response_json["usage"]["total_tokens"].as_FU64().unwrap_or(0) as usize,
        };

        Ok(ChatCompletion {
            content,
            tool_calls: Vec::new(),
            finish_reason: FinishReason::Stop,
            usage,
        })
    }

    async fn chat_completion_stream(
        &self,
        _messages: FVec<Message>,
        _options: CompletionOptions,
    ) -> Result<Box<dyn futures::Stream<Item = Result<ChatDelta>> + Unpin + Send>> {
        Err(anyhow::anyhow!("Streaming not yet implemented for OpenAI"))
    }

    fn supports_tool_use(&self) -> FBool {
        true
    }
}

/// Google Gemini provider
struct GeminiProvider {
    api_key: FString,
    model: FString,
    client: reqwest::Client,
}

impl GeminiProvider {
    fn new(api_key: FString) -> Self {
        Self {
            api_key,
            model: "gemini-2.0-flash-exp".to_string(),
            client: reqwest::Client::new(),
        }
    }

    fn with_model(mut self, model: FString) -> Self {
        self.model = model;
        self
    }
}

#[async_trait]
impl AIProvider for GeminiProvider {
    fn name(&self) -> &str {
        "Google Gemini"
    }

    async fn chat_completion(
        &self,
        messages: FVec<Message>,
        options: CompletionOptions,
    ) -> Result<ChatCompletion> {
        tracing::info!("Calling Gemini API with model: {}", self.model);

        let url = format!(
            "https://generativelanguage.googleapis.com/v1beta/models/{}:generateContent?key={}",
            self.model, self.api_key
        );

        // Convert messages to Gemini format
        let contents = messages
            .iter()
            .map(|msg| {
                serde_json::json!({
                    "role": match msg.role {
                        crate::MessageRole::User => "user",
                        crate::MessageRole::Assistant => "model",
                        _ => "user",
                    },
                    "parts": [{ "text": msg.content }]
                })
            })
            .collect::<FVec<_>>();

        let request_body = serde_json::json!({
            "contents": contents,
            "generationConfig": {
                "temperature": options.temperature,
                "maxOutputTokens": options.max_tokens.unwrap_or(8192),
            }
        });

        let response = self.client.post(&url).json(&request_body).send().await?;

        let response_json: serde_json::Value = response.json().await?;

        let content = response_json["candidates"][0]["content"]["parts"][0]["text"]
            .as_str()
            .unwrap_or("")
            .to_string();

        Ok(ChatCompletion {
            content,
            tool_calls: Vec::new(),
            finish_reason: FinishReason::Stop,
            usage: TokenUsage {
                prompt_tokens: 0,
                completion_tokens: 0,
                total_tokens: 0,
            },
        })
    }

    async fn chat_completion_stream(
        &self,
        _messages: FVec<Message>,
        _options: CompletionOptions,
    ) -> Result<Box<dyn futures::Stream<Item = Result<ChatDelta>> + Unpin + Send>> {
        Err(anyhow::anyhow!("Streaming not yet implemented for Gemini"))
    }

    fn supports_vision(&self) -> FBool {
        true
    }
}

