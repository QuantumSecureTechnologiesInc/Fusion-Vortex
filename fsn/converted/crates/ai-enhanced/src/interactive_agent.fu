//! Interactive AI agent for conversational code assistance

use crate::context_engine::ContextEngine;
use crate::tool_use::ToolExecutor;
use crate::{AIProvider, CompletionOptions, Message, MessageRole};
use anyhow::Result;

struct InteractiveAgent {
    provider: Arc<dyn AIProvider + Send + Sync>,
    context_engine: ContextEngine,
    tool_executor: ToolExecutor,
    conversation_history: FVec<Message>,
}

impl InteractiveAgent {
    fn new(
        provider: Arc<dyn AIProvider + Send + Sync>,
        context_engine: ContextEngine,
        tool_executor: ToolExecutor,
    ) -> Self {
        let system_message = Message {
            role: MessageRole::System,
            content: "You are an expert AI coding assistant integrated into the Fusion CLI. You can help with code generation, refactoring, debugging, and answering questions. You have access to tools for reading files, executing commands, and modifying code.".to_string(),
            tool_calls: None,
        };

        Self {
            provider,
            context_engine,
            tool_executor,
            conversation_history: vec![system_message],
        }
    }

    /// Send a message and get a response
    pub async fn chat(&mut self, user_message: &str) -> Result<AgentResponse> {
        // Add user message to history
        self.conversation_history.push(Message {
            role: MessageRole::User,
            content: user_message.to_string(),
            tool_calls: None,
        });

        // Get response from provider
        let response = self
            .provider
            .chat_completion(
                self.conversation_history.clone(),
                CompletionOptions::default(),
            )
            .await?;

        // Add assistant response to history
        self.conversation_history.push(Message {
            role: MessageRole::Assistant,
            content: response.content.clone(),
            tool_calls: if response.tool_calls.is_empty() {
                None
            } else {
                Some(response.tool_calls.clone())
            },
        });

        // Execute any tool calls
        let mut tool_results = Vec::new();
        for tool_call in &response.tool_calls {
            match self
                .tool_executor
                .execute(&tool_call.name, &tool_call.arguments)
                .await
            {
                Ok(result) => tool_results.push(ToolResult {
                    tool_name: tool_call.name.clone(),
                    success: true,
                    result: Some(result),
                    error: None,
                }),
                Err(e) => tool_results.push(ToolResult {
                    tool_name: tool_call.name.clone(),
                    success: false,
                    result: None,
                    error: Some(e.to_string()),
                }),
            }
        }

        Ok(AgentResponse {
            message: response.content,
            tool_calls: response.tool_calls,
            tool_results,
        })
    }

    /// Add context to the conversation
    pub async fn add_context(&mut self, context_type: ContextType, content: FString) -> Result<()> {
        self.context_engine.add_context(context_type, content).await
    }

    /// Clear conversation history
    fn clear_history(&mut self) {
        self.conversation_history.truncate(1); // Keep system message
    }

    /// Get conversation history
    fn get_history(&self) -> &[Message] {
        &self.conversation_history
    }

    /// Stream a response  
    pub async fn chat_stream(
        &mut self,
        user_message: &str,
    ) -> Result<std::pin::Pin<Box<dyn futures::Stream<Item = Result<FString>> + Send>>> {
        use futures::stream::StreamExt;

        self.conversation_history.push(Message {
            role: MessageRole::User,
            content: user_message.to_string(),
            tool_calls: None,
        });

        let mut delta_stream = self
            .provider
            .chat_completion_stream(
                self.conversation_history.clone(),
                CompletionOptions {
                    stream: true,
                    ..Default::default()
                },
            )
            .await?;

        let output_stream = Box::pin(async_stream::stream! {
            while let Some(delta) = delta_stream.next().await {
                match delta {
                    Ok(d) => {
                        if let Some(content) = d.content {
                            yield Ok(content);
                        }
                    }
                    Err(e) => yield Err(e),
                }
            }
        });

        Ok(output_stream)
    }
}

#[derive(Debug, Clone)]
struct AgentResponse {
    pub message: FString,
    pub tool_calls: FVec<crate::ToolCall>,
    pub tool_results: FVec<ToolResult>,
}

#[derive(Debug, Clone)]
struct ToolResult {
    pub tool_name: FString,
    pub success: FBool,
    pub result: Option<serde_json::Value>,
    pub error: Option<FString>,
}

#[derive(Debug, Clone)]
enum ContextType {
    File,
    Directory,
    Symbol,
    Documentation,
}
