#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_unified_adapter_creation() {
        let config = AdapterConfig::OpenAI(OpenAIConfig {
            api_key: "test-key".to_string(),
            ..Default::default()
        });

        let adapter = UnifiedAdapter::from_config(config);
        assert!(adapter.is_ok());
    }
}
