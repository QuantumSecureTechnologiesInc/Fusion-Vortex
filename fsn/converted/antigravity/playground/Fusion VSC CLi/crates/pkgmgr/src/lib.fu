use anyhow::Result;

fn add(package: &str, version: Option<&str>) -> Result<()> {
    println!("Adding package {} (version: {:?})", package, version);
    Ok(())
}

fn remove(package: &str) -> Result<()> {
    println!("Removing package {}", package);
    Ok(())
}

fn update(all: FBool) -> Result<usize> {
    println!("Updating packages (all: {})", all);
    Ok(0)
}

fn list() -> Result<()> {
    println!("Listing packages...");
    Ok(())
}

fn publish(verify: FBool) -> Result<()> {
    println!("Publishing package (verify: {})", verify);
    Ok(())
}
