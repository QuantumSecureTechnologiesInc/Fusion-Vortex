// SOURCE: antigravity/playground/Fusion Substrate/crates/fusion-agent-tests/src/lib.rs
// NOTE: Converted into FSN mirror under fsn/converted.
#[cfg(test)]
mod agent_integration_tests {
    use fusion_agent_graph::{AgentGraph, AgentState};
    use fusion_agent_runtime::AgentRuntime;
    use fusion_agent_spec::{AgentPlan, PlanStep};
    use fusion_ledger::Ledger;
    use fusion_policy::AllowListPolicy;
    use fusion_runtime::Runtime;
    use serde_json::json;
    use tempfile::NamedTempFile;

    #[test]
    fn test_full_agent_execution_pipeline() {
        let temp_file = NamedTempFile::new().unwrap();
        let ledger = Ledger::new(temp_file.path().to_str().unwrap());
        let policy = AllowListPolicy::new(vec!["read".into(), "process".into(), "write".into()]);
        let runtime = Runtime::new(ledger, policy).unwrap();
        let mut agent_runtime = AgentRuntime::new(runtime, 20.0);

        // Create a multi-step plan
        let mut plan = AgentPlan::new("pipeline", "Process data pipeline");
        plan.add_step(PlanStep::new(
            "step1",
            "read",
            json!({"file": "input.txt"}),
            "Read input file",
            3.0,
        ));
        plan.add_step(PlanStep::new(
            "step2",
            "process",
            json!({"algorithm": "transform"}),
            "Process the data",
            5.0,
        ));
        plan.add_step(PlanStep::new(
            "step3",
            "write",
            json!({"file": "output.txt"}),
            "Write results",
            2.0,
        ));

        let mut graph = AgentGraph::new(plan);

        // Execute the entire plan
        let result = agent_runtime.execute_graph(&mut graph);

        assert!(result.is_ok());
        assert_eq!(graph.state(), AgentState::Completed);
        assert_eq!(graph.executed_steps().len(), 3);
        assert_eq!(agent_runtime.budget_remaining(), 10.0); // 20 - 10 used
    }

    #[test]
    fn test_budget_exhaustion_mid_execution() {
        let temp_file = NamedTempFile::new().unwrap();
        let ledger = Ledger::new(temp_file.path().to_str().unwrap());
        let policy = AllowListPolicy::new(vec!["cheap".into(), "expensive".into()]);
        let runtime = Runtime::new(ledger, policy).unwrap();
        let mut agent_runtime = AgentRuntime::new(runtime, 5.0);

        let mut plan = AgentPlan::new("test", "Budget test");
        plan.add_step(PlanStep::new(
            "s1",
            "cheap",
            json!({}),
            "Cheap operation",
            2.0,
        ));
        plan.add_step(PlanStep::new(
            "s2",
            "expensive",
            json!({}),
            "Expensive operation",
            10.0,
        ));

        let mut graph = AgentGraph::new(plan);

        let result = agent_runtime.execute_graph(&mut graph);

        // Should fail due to budget
        assert!(result.is_err());

        // First step should have executed
        assert_eq!(graph.cursor(), 1);
        assert_eq!(graph.state(), AgentState::Paused);

        // Can resume after adding budget
        agent_runtime.add_budget(10.0);
        graph.resume();

        let result2 = agent_runtime.execute_graph(&mut graph);
        assert!(result2.is_ok());
        assert_eq!(graph.state(), AgentState::Completed);
    }

    #[test]
    fn test_policy_denial_stops_agent() {
        let temp_file = NamedTempFile::new().unwrap();
        let ledger = Ledger::new(temp_file.path().to_str().unwrap());
        let policy = AllowListPolicy::new(vec!["allowed".into()]);
        let runtime = Runtime::new(ledger, policy).unwrap();
        let mut agent_runtime = AgentRuntime::new(runtime, 100.0);

        let mut plan = AgentPlan::new("test", "Policy test");
        plan.add_step(PlanStep::new("s1", "allowed", json!({}), "Safe step", 1.0));
        plan.add_step(PlanStep::new(
            "s2",
            "forbidden",
            json!({}),
            "Unsafe step",
            1.0,
        ));

        let mut graph = AgentGraph::new(plan);

        let result = agent_runtime.execute_graph(&mut graph);

        // Should fail due to policy
        assert!(result.is_err());

        // Only first step executed
        assert_eq!(graph.cursor(), 1);
    }

    #[test]
    fn test_multi_agent_tool_coordination() {
        let temp_file = NamedTempFile::new().unwrap();
        let ledger = Ledger::new(temp_file.path().to_str().unwrap());
        let policy = AllowListPolicy::new(vec!["shared_tool".into()]);
        let runtime = Runtime::new(ledger, policy).unwrap();
        let mut agent_runtime = AgentRuntime::new(runtime, 100.0);

        // Agent 1 plan
        let mut plan1 = AgentPlan::new("agent1", "First agent");
        plan1.add_step(PlanStep::new(
            "a1s1",
            "shared_tool",
            json!({}),
            "Use tool",
            1.0,
        ));
        plan1.add_step(PlanStep::new(
            "a1s2",
            "shared_tool",
            json!({}),
            "Use tool again",
            1.0,
        ));

        let mut graph1 = AgentGraph::new(plan1);

        // Agent 2 plan
        let mut plan2 = AgentPlan::new("agent2", "Second agent");
        plan2.add_step(PlanStep::new(
            "a2s1",
            "shared_tool",
            json!({}),
            "Use tool",
            1.0,
        ));

        let mut graph2 = AgentGraph::new(plan2);

        // Execute both agents
        agent_runtime.execute_graph(&mut graph1).unwrap();
        agent_runtime.execute_graph(&mut graph2).unwrap();

        // Shared tool should show 3 usages
        assert_eq!(agent_runtime.tool_usage("shared_tool"), 3);
    }

    #[test]
    fn test_agent_state_machine_transitions() {
        let plan = AgentPlan::new("test", "State machine test");
        let mut graph = AgentGraph::new(plan);

        // Initial state
        assert_eq!(graph.state(), AgentState::Idle);

        // Can't pause from Idle
        graph.pause();
        assert_eq!(graph.state(), AgentState::Idle);

        // Transition to complete (empty plan)
        graph.advance();
        assert_eq!(graph.state(), AgentState::Completed);
    }

    #[test]
    fn test_agent_crash_recovery() {
        let temp_file = NamedTempFile::new().unwrap();
        let path = temp_file.path().to_str().unwrap();

        // First execution
        {
            let ledger = Ledger::new(path);
            let policy = AllowListPolicy::new(vec!["tool1".into(), "tool2".into()]);
            let runtime = Runtime::new(ledger, policy).unwrap();
            let mut agent_runtime = AgentRuntime::new(runtime, 100.0);

            let mut plan = AgentPlan::new("test", "Crash test");
            plan.add_step(PlanStep::new("s1", "tool1", json!({}), "Step 1", 1.0));
            plan.add_step(PlanStep::new("s2", "tool2", json!({}), "Step 2", 1.0));

            let mut graph = AgentGraph::new(plan);
            agent_runtime.execute_graph(&mut graph).unwrap();
        } // Simulate crash

        // Recovery
        {
            let ledger = Ledger::new(path);
            let policy = AllowListPolicy::new(vec!["tool1".into(), "tool2".into()]);
            let runtime = Runtime::new(ledger, policy).unwrap();

            // Runtime should have replayed the ledger
            assert_eq!(runtime.sequence(), 2);

            let replayed = runtime.replay_all().unwrap();
            assert_eq!(replayed.len(), 2);
        }
    }
}
