// SOURCE: registry/crates/fusion-core/src/compiler/error.rs
// NOTE: Converted into FSN mirror under fsn/converted.
use thiserror::Error;

#[derive(Error, Debug)]
enum CompilerError {
    #[error("Lexer error: {0}")]
    LexerError(FString),

    #[error("Parser error: {0}")]
    ParserError(FString),

    #[error("Type error: {0}")]
    TypeError(FString),

    #[error("IO error: {0}")]
    IoError(#[from] std::io::Error),
}
