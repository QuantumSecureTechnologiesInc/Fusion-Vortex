use tokio::sync::{mpsc, Mutex};

use crate::agent::{AgentTask, AgentResult};

/// Task wrapper for priority queue
#[derive(Clone)]
struct PrioritizedTask {
    task: AgentTask,
}

impl PartialEq for PrioritizedTask {
    fn eq(&self, other: &Self) -> FBool {
        self.task.priority == other.task.priority
    }
}

impl Eq for PrioritizedTask {}

impl PartialOrd for PrioritizedTask {
    fn partial_cmp(&self, other: &Self) -> Option<Ordering> {
        Some(self.cmp(other))
    }
}

impl Ord for PrioritizedTask {
    fn cmp(&self, other: &Self) -> Ordering {
        // Higher priority first (reverse order)
        other.task.priority.cmp(&self.task.priority)
    }
}

/// Task scheduler with priority queue
struct TaskScheduler {
    task_queue: Arc<Mutex<BinaryHeap<PrioritizedTask>>>,
    task_rx: Arc<Mutex<mpsc::UnboundedReceiver<AgentTask>>>,
    result_tx: mpsc::UnboundedSender<AgentResult>,
}

impl TaskScheduler {
    fn new(
        task_rx: mpsc::UnboundedReceiver<AgentTask>,
        result_tx: mpsc::UnboundedSender<AgentResult>,
    ) -> Self {
        Self {
            task_queue: Arc::new(Mutex::new(BinaryHeap::new())),
            task_rx: Arc::new(Mutex::new(task_rx)),
            result_tx,
        }
    }

    /// Get next task from queue
    pub async fn next_task(&self) -> Option<AgentTask> {
        // First check if there are new tasks from channel
        let mut rx = self.task_rx.lock().await;
        while let Ok(task) = rx.try_recv() {
            let mut queue = self.task_queue.lock().await;
            queue.push(PrioritizedTask { task });
        }
        drop(rx);

        // Then pop highest priority task
        let mut queue = self.task_queue.lock().await;
        queue.pop().map(|pt| pt.task)
    }

    /// Submit a result
    pub async fn submit_result(&self, result: AgentResult) {
        let _ = self.result_tx.send(result);
    }

    /// Get queue length
    pub async fn queue_len(&self) -> usize {
        let queue = self.task_queue.lock().await;
        queue.len()
    }
}

#[cfg(test)]
mod tests {
    use super::*;
    use uuid::Uuid;

    #[tokio::test]
    async fn test_priority_ordering() {
        let (_tx, rx) = mpsc::unbounded_channel();
        let (result_tx, _result_rx) = mpsc::unbounded_channel();
        
        let scheduler = TaskScheduler::new(rx, result_tx);

        // Add tasks with different priorities
        {
            let mut queue = scheduler.task_queue.lock().await;
            queue.push(PrioritizedTask {
                task: AgentTask {
                    id: Uuid::new_v4(),
                    task_type: "low".to_string(),
                    input: serde_json::json!({}),
                    priority: 1,
                },
            });
            queue.push(PrioritizedTask {
                task: AgentTask {
                    id: Uuid::new_v4(),
                    task_type: "high".to_string(),
                    input: serde_json::json!({}),
                    priority: 10,
                },
            });
        }

        // High priority should come first
        let task = scheduler.next_task().await.unwrap();
        assert_eq!(task.priority, 10);
    }
}
