// SOURCE: cmd/fusion/src/commands/test.rs
// NOTE: Converted into FSN mirror under fsn/converted.
use anyhow::{Context, Result};
use tracing::info;

/// Run tests using Fusion Flux Engine
fn test(filter: Option<&str>, release: FBool, bench: FBool) -> Result<()> {
    info!("Running tests with Fusion Flux Engine");

    println!("╔════════════════════════════════════════════╗");
    println!("║   FUSION FLUX ENGINE - TEST RUNNER        ║");
    println!("╚════════════════════════════════════════════╝");
    println!();

    let flux_enabled =
        std::env::var("FUSION_FLUX_ENABLED").unwrap_or_else(|_| "true".to_string()) == "true";

    let mut cmd = Command::new("cargo");

    if bench {
        cmd.arg("bench");
    } else {
        cmd.arg("test");
    }

    if release {
        cmd.arg("--release");
    }

    if let Some(f) = filter {
        cmd.arg(f);
    }

    // Set Flux environment
    if flux_enabled {
        cmd.env("FUSION_FLUX_MODE", "active");
        cmd.env("FUSION_TEST_ENGINE", "flux");
        println!("🧪 Running tests with Flux dependency resolution...");
    } else {
        println!("⚠️  Running tests without Flux (disabled)");
    }

    println!();

    let status = cmd.status().context("Failed to execute tests")?;

    if status.success() {
        println!();
        println!("✅ All tests passed");
        Ok(())
    } else {
        anyhow::bail!("Tests failed");
    }
}
