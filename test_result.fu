// Test Result<T, E> implementation

fn main() -> int {
    let ok_result = Result::<int, int>::ok(42);
    let err_result = Result::<int, int>::err(404);
    
    print("ok_result.is_ok():");
    print(ok_result.is_ok());
    
    print("err_result.is_err():");
    print(err_result.is_err());
    
    let ok_value = ok_result.unwrap();
    print("Ok value:");
    print(ok_value);
    
    let err_value = err_result.unwrap_err();
    print("Error value:");
    print(err_value);
    
    let default_val = err_result.unwrap_or(0);
    print("Unwrap error with default:");
    print(default_val);
    
    return 0;
}
