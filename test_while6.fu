extern fn printf(fmt: string, ...) -> int;

fn test6(a: int, b: int, c: int, d: int, e: int, f: int) -> int {
    printf("6p: %d\n", a);
    return 0;
}

fn main() -> int {
    printf("Start\n");
    let mut i: int = 0;
    while i < 2 {
        let r = test6(i, 1, 2, 3, 4, 5);
        i = i + 1;
    }
    printf("End\n");
    return 0;
}
