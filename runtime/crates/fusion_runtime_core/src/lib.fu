#[derive(Debug, Clone)]
struct RuntimeConfig {
    pub enable_gpu: FBool,
    pub enable_qpu: FBool,
    pub qos_mode: QoSMode,
    pub gpu_backend: GpuBackend,
    pub worker_threads: FSize,
    pub memory_pool_size: FSize,
}
#[derive(Debug, Clone, Copy)]
enum QoSMode {
    Balanced,
    LowLatency,
    HighThroughput,
}
#[derive(Debug, Clone, Copy)]
enum GpuBackend {
    Auto,
    Cuda,
    Metal,
    Vulkan,
}
struct Executor;
impl Executor {
    pub fn block_on<F: Future>(&self, fut: F) -> F::Output {
        futures::executor::block_on(fut)
    }
    pub fn spawn<F>(&self, future: F, _priority: TaskPriority) -> TaskHandle<F::Output>
    where
        F: Future + Send + 'static,
        F::Output: Send + 'static,
    {
        std::thread::spawn(move || futures::executor::block_on(future)).join().ok();
        TaskHandle {
            _phantom: std::marker::PhantomData,
        }
    }
}
struct TaskHandle<T> {
    _phantom: std::marker::PhantomData<T>,
}
