{
  "name": "fusion-language",
  "displayName": "Fusion Language Support",
  "description": "Language support for the Fusion programming language with LSP integration",
  "version": "0.1.0",
  "publisher": "quantumsecure",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "fusion",
    "systems programming",
    "quantum computing",
    "machine learning"
  ],
  "activationEvents": [
    
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "fusion",
        "aliases": [
          "Fusion",
          "fusion"
        ],
        "extensions": [
          ".fu"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/fusion-icon.png",
          "dark": "./icons/fusion-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "fusion",
        "scopeName": "source.fusion",
        "path": "./syntaxes/fusion.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Fusion Language Server",
      "properties": {
        "fusion.server.path": {
          "type": "string",
          "default": "fusion_lang",
          "description": "Path to the Fusion language server executable"
        },
        "fusion.server.args": {
          "type": "array",
          "default": [],
          "description": "Arguments to pass to the language server"
        },
        "fusion.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VS Code and the Fusion language server"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.19.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quantumsecure/fusion-lang.git"
  },
  "license": "MIT",
  "author": "",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/quantumsecure/fusion-lang/issues"
  },
  "homepage": "https://github.com/quantumsecure/fusion-lang#readme"
}
