{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Fusion",
  "scopeName": "source.fusion",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.fusion",
          "match": "//.*$"
        },
        {
          "name": "comment.block.fusion",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.fusion",
          "match": "\\b(if|else|while|for|return|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.fusion",
          "match": "\\b(fn|class|let|mut|pub|extern|trait|implements)\\b"
        },
        {
          "name": "keyword.other.fusion",
          "match": "\\b(self|Self)\\b"
        },
        {
          "name": "constant.language.boolean.fusion",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "storage.modifier.fusion",
          "match": "\\b(static|const)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.fusion",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.fusion",
              "match": "\\\\(n|r|t|\\\\|0|'|\"))"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.fusion",
          "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.hex.fusion",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.fusion",
          "match": "\\b0[bB][01]+\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.fusion",
          "match": "\\b(int|float|bool|string|void)\\b"
        },
        {
          "name": "storage.type.fusion",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
        },
        {
          "name": "storage.type.generic.fusion",
          "match": "<[A-Z][a-zA-Z0-9_]*(,\\s*[A-Z][a-zA-Z0-9_]*)*>"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.fusion",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "entity.name.function.method.fusion",
          "match": "\\.([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.fusion",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.comparison.fusion",
          "match": "(==|!=|<|>|<=|>=)"
        },
        {
          "name": "keyword.operator.logical.fusion",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.assignment.fusion",
          "match": "="
        },
        {
          "name": "keyword.operator.arrow.fusion",
          "match": "->"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.fusion",
          "match": "[,;]"
        },
        {
          "name": "punctuation.brackets.fusion",
          "match": "[\\[\\]{}()]"
        },
        {
          "name": "punctuation.accessor.fusion",
          "match": "\\.|::"
        }
      ]
    }
  }
}
