# --- Core Mathematical Structure ---

class Quaternion:
    """
    A pure quaternion representation q = w + xi + yj + zk.
    
    Optimised for cryptographic operations:
    - Uses __slots__ for lower memory overhead.
    - Implements 'Combined Rotations' logic.
    """
    __slots__ = ('w', 'x', 'y', 'z')

    def __init__(self, w: float, x: float, y: float, z: float):
        self.w = w
        self.x = x
        self.y = y
        self.z = z

    def __repr__(self) -> str:
        return f"Q({self.w:.4f}, {self.x:.4f}, {self.y:.4f}, {self.z:.4f})"

    def to_bytes(self) -> bytes:
        """Serialises the quaternion components to IEEE 754 doubles."""
        return struct.pack('>dddd', self.w, self.x, self.y, self.z)

    @classmethod
    def from_bytes(cls, data: bytes) -> 'Quaternion':
        if len(data) != 32:
            raise ValueError("Quaternion bytes must be 32 bytes.")
        w, x, y, z = struct.unpack('>dddd', data)
        return cls(w, x, y, z)

    def add(self, other: 'Quaternion') -> 'Quaternion':
        return Quaternion(self.w + other.w, self.x + other.x, self.y + other.y, self.z + other.z)

    def sub(self, other: 'Quaternion') -> 'Quaternion':
        return Quaternion(self.w - other.w, self.x - other.x, self.y - other.y, self.z - other.z)

    def mul(self, other: 'Quaternion') -> 'Quaternion':
        """
        Hamilton product.
        Basis of 'Combined Rotations': R_net = R2 * R1.
        """
        w = self.w * other.w - self.x * other.x - self.y * other.y - self.z * other.z
        x = self.w * other.x + self.x * other.w + self.y * other.z - self.z * other.y
        y = self.w * other.y - self.x * other.z + self.y * other.w + self.z * other.x
        z = self.w * other.z + self.x * other.y - self.y * other.x + self.z * other.w
        return Quaternion(w, x, y, z)

    def compose(self, other: 'Quaternion') -> 'Quaternion':
        """
        Explicitly combines two rotations.
        Optimisation: Pre-calculating the product of two rotation quaternions
        is faster than applying them sequentially to a vector.
        """
        return self.mul(other)

    def scalar_mul(self, scalar: float) -> 'Quaternion':
        return Quaternion(self.w * scalar, self.x * scalar, self.y * scalar, self.z * scalar)

    def conjugate(self) -> 'Quaternion':
        return Quaternion(self.w, -self.x, -self.y, -self.z)

    def norm_sq(self) -> float:
        return self.w * self.w + self.x * self.x + self.y * self.y + self.z * self.z

    def norm(self) -> float:
        return math.sqrt(self.norm_sq())

    def inverse(self) -> 'Quaternion':
        n_sq = self.norm_sq()
        if n_sq < EPSILON:
            raise ArithmeticError("Cannot invert zero-norm quaternion.")
        inv_n = 1.0 / n_sq
        return Quaternion(self.w * inv_n, -self.x * inv_n, -self.y * inv_n, -self.z * inv_n)

    def normalize(self) -> 'Quaternion':
        n = self.norm()
        if n < EPSILON:
            return Quaternion(1.0, 0.0, 0.0, 0.0)
        inv_n = 1.0 / n
        return self.scalar_mul(inv_n)

    def rotate(self, vector: 'Quaternion') -> 'Quaternion':
        """
        Applies rotation: v' = q * v * q*.
        
        Optimisation (Gimbal Lock Avoidance):
        We assume 'self' is a unit quaternion (versor), which represents
        a rotation on the 3-sphere. This avoids the singularities associated
        with Euler angles.
        
        Optimisation (Speed):
        We use the conjugate (q*) instead of inverse (q^-1) because for
        unit quaternions, q^-1 == q*. This saves a norm calculation and division.
        """
        conj = self.conjugate()
        temp = self.mul(vector)
        return temp.mul(conj)


# --- Chaotic Dynamics & Sponge Engine ---

class HeisenbergEulerSponge:
    """
    A cryptographic sponge construction built on the Heisenberg-Euler chaos map.
    
    Optimisation (Zero-Churn):
    The internal loops use scalar variables to avoid creating Quaternion objects
    until the very last step.
    """
    
    def __init__(self):
        # State maintained as scalars for performance
        self.rate_w, self.rate_x, self.rate_y, self.rate_z = 0.0, 0.0, 0.0, 0.0
        self.cap_w, self.cap_x, self.cap_y, self.cap_z = 0.00729735256, 0.0, 0.0, 0.0

    @staticmethod
    def _scalar_chaos_step(w: float, x: float, y: float, z: float) -> Tuple[float, float, float, float]:
        """
        Optimised scalar implementation of the chaos map.
        Avoids object creation overhead in the hot loop.
        """
        r = DEFAULT_CHAOS_R
        
        # 1. Map to (0, 1) and iterate Logistic Map
        # W
        val = w
        s = abs(math.sin(val)) * 0.999 + 0.0001
        for _ in range(5): s = r * s * (1.0 - s)
        nw = val + (s - 0.5)
        
        # X
        val = x
        s = abs(math.sin(val)) * 0.999 + 0.0001
        for _ in range(5): s = r * s * (1.0 - s)
        nx = val + (s - 0.5)
        
        # Y
        val = y
        s = abs(math.sin(val)) * 0.999 + 0.0001
        for _ in range(5): s = r * s * (1.0 - s)
        ny = val + (s - 0.5)
        
        # Z
        val = z
        s = abs(math.sin(val)) * 0.999 + 0.0001
        for _ in range(5): s = r * s * (1.0 - s)
        nz = val + (s - 0.5)
        
        # 2. Normalize
        norm = math.sqrt(nw*nw + nx*nx + ny*ny + nz*nz)
        if norm > EPSILON:
            inv = 1.0 / norm
            nw *= inv; nx *= inv; ny *= inv; nz *= inv
        else:
            nw = 1.0; nx = 0.0; ny = 0.0; nz = 0.0

        # 3. Symplectic Mix
        fw = nw - nx
        fx = nx + nw
        fy = ny - nz
        fz = nz + ny
        
        # Normalize again
        norm = math.sqrt(fw*fw + fx*fx + fy*fy + fz*fz)
        if norm > EPSILON:
            inv = 1.0 / norm
            return fw*inv, fx*inv, fy*inv, fz*inv
        return 1.0, 0.0, 0.0, 0.0

    def permute(self):
        """Mixing step: Cross-couple Rate and Capacity."""
        # Mix
        self.rate_w += self.cap_w
        self.rate_x += self.cap_x
        self.rate_y += self.cap_y
        self.rate_z += self.cap_z
        
        # Evolve
        for _ in range(DEFAULT_CHAOS_ITERATIONS):
            self.rate_w, self.rate_x, self.rate_y, self.rate_z = \
                self._scalar_chaos_step(self.rate_w, self.rate_x, self.rate_y, self.rate_z)
            self.cap_w, self.cap_x, self.cap_y, self.cap_z = \
                self._scalar_chaos_step(self.cap_w, self.cap_x, self.cap_y, self.cap_z)

    def absorb(self, data: bytes):
        seed_hash = hashlib.sha256(data).digest()
        parts = struct.unpack('>dddd', seed_hash)
        
        # Additive injection
        self.rate_w += parts[0]
        self.rate_x += parts[1]
        self.rate_y += parts[2]
        self.rate_z += parts[3]
        self.permute()

    def squeeze(self) -> bytes:
        self.permute()
        return struct.pack('>dddd', self.rate_w, self.rate_x, self.rate_y, self.rate_z)


# --- The HyperCycle Lattice-Free Protocol ---

class HyperCycleProtocol:
    """
    The main CQC protocol engine.
    Implements 'Combined Rotations' for efficient Blinding.
    """

    def __init__(self, agent_id: str, use_chaos: bool = False):
        self.agent_id = agent_id
        self.use_chaos = use_chaos
        self.session_log: List[str] = []

    def log(self, message: str):
        timestamp = time.strftime("%H:%M:%S", time.gmtime())
        entry = f"[{timestamp}] [{self.agent_id}] {message}"
        self.session_log.append(entry)

    def generate_ephemeral_keypair(self) -> Tuple[Quaternion, Quaternion]:
        """
        Generates keys using the Optimised Sponge engine.
        """
        sponge = HeisenbergEulerSponge()
        sponge.absorb(secrets.token_bytes(64))
        
        if self.use_chaos:
            sponge.absorb(secrets.token_bytes(64))
            
        priv_bytes = sponge.squeeze()
        private_q = Quaternion.from_bytes(priv_bytes).normalize()

        g_bytes = hashlib.sha3_256(b"HyperCycle_Generator_Origin").digest()
        generator_g = Quaternion(*struct.unpack('>dddd', g_bytes)).normalize()

        public_q = private_q.rotate(generator_g)
        
        self.log(f"Generated keypair (Chaos={'On' if self.use_chaos else 'Off'}).")
        return private_q, public_q

    def compute_shared_secret(self, my_private: Quaternion, their_public: Quaternion) -> bytes:
        """
        Computes Shared Secret with optional Blinding.
        
        Optimisation (Combined Rotations):
        If chaos/blinding is enabled, we need to apply both the Public Key rotation
        and a Blinding Rotation to the base state. Instead of doing two separate
        rotations, we pre-multiply the quaternions (compose) and apply once.
        """
        if self.use_chaos:
            # 1. Generate Blinding Rotation (M)
            # In a real KEM, this would be ephemeral entropy.
            M = Quaternion(0.7071, 0.7071, 0.0, 0.0) # Example constant 90 deg mask
            
            # 2. Combine Rotations: Net = M * Public
            # Applying Net is mathematically equivalent to Apply Public then Apply M.
            # R_net = M.compose(their_public)
            combined_rot = M.compose(their_public)
            
            # 3. Apply Combined Rotation to Private State
            # Note: NCAC standard is S = Priv * Pub. 
            # In rotated space: S = Rotate(Combined, Priv)
            mix_state = combined_rot.rotate(my_private)
            
        else:
            # Standard Unblinded Path
            # Mix = Priv * Pub
            mix_state = my_private.mul(their_public)
        
        # KDF
        sponge = HeisenbergEulerSponge()
        sponge.absorb(mix_state.to_bytes())
        
        shared_secret = sponge.squeeze()
        self.log("Derived shared secret.")
        return shared_secret


# --- Optimization & Chaos Suite (CLI) ---

class OptimizationSuite:
    
    @staticmethod
    def benchmark_throughput(iterations: int = 100_000):
        print(f"\n[Benchmarking] Running {iterations} Hamilton Products...")
        q1 = secure_random_quaternion()
        q2 = secure_random_quaternion()
        
        start = time.perf_counter()
        for _ in range(iterations):
            q1 = q1.mul(q2)
            if _ % 1000 == 0: q1 = q1.normalize()
        duration = time.perf_counter() - start
        
        print(f"Result: {(iterations/duration):,.2f} ops/sec")

    @staticmethod
    def benchmark_combined_rotations(iterations: int = 100_000):
        print(f"\n[Benchmarking] Combined vs Sequential Rotations ({iterations} iters)...")
        
        rot1 = secure_random_quaternion()
        rot2 = secure_random_quaternion()
        vec = secure_random_quaternion()
        
        # 1. Sequential
        t0 = time.perf_counter()
        for _ in range(iterations):
            temp = rot1.rotate(vec)
            _ = rot2.rotate(temp)
        t_seq = time.perf_counter() - t0
        print(f"Sequential Time: {t_seq:.4f}s")
        
        # 2. Combined (Optimised)
        t0 = time.perf_counter()
        combined = rot2.compose(rot1)
        for _ in range(iterations):
            _ = combined.rotate(vec)
        t_comb = time.perf_counter() - t0
        print(f"Combined Time:   {t_comb:.4f}s")
        
        speedup = t_seq / t_comb if t_comb > 0 else 0
        print(f"Speedup Factor:  {speedup:.2f}x")

    @staticmethod
    def chaos_stress_test(rounds: int = 1000):
        print(f"\n[Chaos Test] Measuring sensitivity ({rounds} rounds)...")
        s1 = HeisenbergEulerSponge()
        s1.rate_w = 0.5; s1.rate_x = 0.5; s1.rate_y = 0.5; s1.rate_z = 0.5
        
        s2 = HeisenbergEulerSponge()
        s2.rate_w = 0.5 + 1e-9; s2.rate_x = 0.5; s2.rate_y = 0.5; s2.rate_z = 0.5
        
        for _ in range(rounds):
            s1.permute()
            s2.permute()
        
        # Calculate distance
        dw = s1.rate_w - s2.rate_w
        dx = s1.rate_x - s2.rate_x
        dy = s1.rate_y - s2.rate_y
        dz = s1.rate_z - s2.rate_z
        diff = math.sqrt(dw*dw + dx*dx + dy*dy + dz*dz)
        
        print(f"Final Delta:   {diff:.9f}")
        print(f"Divergence:    {'High (Good)' if diff > 0.1 else 'Low'}")


