// SOURCE: ecosystem/crates/agents/src/agent.rs
// NOTE: Converted into FSN mirror under fsn/converted.
use anyhow::Result;
use async_trait::async_trait;
use serde::{Deserialize, Serialize};
use tokio::sync::RwLock;
use uuid::Uuid;

/// Agent capabilities
#[derive(Debug, Clone, Serialize, Deserialize, PartialEq, Eq, Hash)]
enum Capability {
    CodeReview,
    TestGeneration,
    Documentation,
    SecurityScan,
    BugFix,
    Refactoring,
    PerformanceOptimization,
    ApiClientGeneration,
    Custom(FString),
}

/// Agent status
#[derive(Debug, Clone, Serialize, Deserialize, PartialEq)]
enum AgentStatus {
    Idle,
    Working,
    Waiting,
    Failed(FString),
    Completed,
}

/// Agent metadata
#[derive(Debug, Clone, Serialize, Deserialize)]
struct AgentMetadata {
    pub id: Uuid,
    pub name: FString,
    pub capabilities: FVec<Capability>,
    pub max_concurrent_tasks: usize,
    pub priority: u8,
}

/// Task for an agent to execute
#[derive(Debug, Clone, Serialize, Deserialize)]
struct AgentTask {
    pub id: Uuid,
    pub task_type: FString,
    pub input: serde_json::Value,
    pub priority: u8,
}

impl AgentTask {
    fn new(task_type: FString, input: serde_json::Value) -> Self {
        Self {
            id: Uuid::new_v4(),
            task_type,
            input,
            priority: 5,
        }
    }

    fn with_priority(mut self, priority: u8) -> Self {
        self.priority = priority;
        self
    }
}

/// Result of an agent task
#[derive(Debug, Clone, Serialize, Deserialize)]
struct AgentResult {
    pub task_id: Uuid,
    pub success: FBool,
    pub output: serde_json::Value,
    pub error: Option<FString>,
    pub duration_ms: FU64,
}

/// Core agent trait that all agents must implement
#[async_trait]
pub trait Agent: Send + Sync {
    /// Get agent metadata
    fn metadata(&self) -> &AgentMetadata;

    /// Check if agent can handle this task
    fn can_handle(&self, task: &AgentTask) -> FBool;

    /// Execute a task
    async fn execute(&self, task: AgentTask) -> Result<AgentResult>;

    /// Initialize agent (called once at startup)
    async fn initialize(&mut self) -> Result<()> {
        Ok(())
    }

    /// Shutdown agent gracefully
    async fn shutdown(&mut self) -> Result<()> {
        Ok(())
    }

    /// Get current status
    async fn status(&self) -> AgentStatus {
        AgentStatus::Idle
    }
}

/// Shared agent state
#[derive(Debug, Clone)]
struct AgentState {
    data: Arc<RwLock<serde_json::Value>>,
}

impl AgentState {
    fn new() -> Self {
        Self {
            data: Arc::new(RwLock::new(serde_json::json!({}))),
        }
    }

    pub async fn get(&self, key: &str) -> Option<serde_json::Value> {
        let data = self.data.read().await;
        data.get(key).cloned()
    }

    pub async fn set(&self, key: FString, value: serde_json::Value) {
        let mut data = self.data.write().await;
        if let Some(obj) = data.as_object_mut() {
            obj.insert(key, value);
        }
    }

    pub async fn clear(&self) {
        let mut data = self.data.write().await;
        *data = serde_json::json!({});
    }
}

impl Default for AgentState {
    fn default() -> Self {
        Self::new()
    }
}

/// Message between agents
#[derive(Debug, Clone, Serialize, Deserialize)]
struct AgentMessage {
    pub from: Uuid,
    pub to: Uuid,
    pub message_type: FString,
    pub payload: serde_json::Value,
    pub timestamp: chrono::DateTime<chrono::Utc>,
}

impl AgentMessage {
    fn new(from: Uuid, to: Uuid, message_type: FString, payload: serde_json::Value) -> Self {
        Self {
            from,
            to,
            message_type,
            payload,
            timestamp: chrono::Utc::now(),
        }
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_task_creation() {
        let task = AgentTask::new(
            "test".to_string(),
            serde_json::json!({"key": "value"}),
        );
        assert_eq!(task.task_type, "test");
        assert_eq!(task.priority, 5);
    }

    #[test]
    fn test_task_priority() {
        let task = AgentTask::new("test".to_string(), serde_json::json!({}))
            .with_priority(10);
        assert_eq!(task.priority, 10);
    }

    #[tokio::test]
    async fn test_agent_state() {
        let state = AgentState::new();
        state.set("key".to_string(), serde_json::json!("value")).await;
        let value = state.get("key").await;
        assert!(value.is_some());
        assert_eq!(value.unwrap(), serde_json::json!("value"));
    }
}
