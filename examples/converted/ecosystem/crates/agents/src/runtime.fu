// SOURCE: ecosystem/crates/agents/src/runtime.rs
// NOTE: Converted into FSN mirror under fsn/converted.
use anyhow::{Context, Result};
use tokio::sync::{mpsc, RwLock};
use tokio::task::JoinHandle;
use tracing::{debug, error, info, warn};
use uuid::Uuid;

use crate::agent::{Agent, AgentMetadata, AgentResult, AgentStatus, AgentTask};
use crate::scheduler::TaskScheduler;

/// Agent runtime that manages multiple agents
struct AgentRuntime {
    agents: Arc<RwLock<FMap<Uuid, Box<dyn Agent>>>>,
    scheduler: Arc<TaskScheduler>,
    task_tx: mpsc::UnboundedSender<AgentTask>,
    result_rx: Arc<RwLock<mpsc::UnboundedReceiver<AgentResult>>>,
    worker_handles: Arc<RwLock<FVec<JoinHandle<()>>>>,
}

impl AgentRuntime {
    /// Create a new agent runtime
    fn new() -> Self {
        let (task_tx, task_rx) = mpsc::unbounded_channel();
        let (result_tx, result_rx) = mpsc::unbounded_channel();

        let scheduler = Arc::new(TaskScheduler::new(task_rx, result_tx));

        Self {
            agents: Arc::new(RwLock::new(HashMap::new())),
            scheduler,
            task_tx,
            result_rx: Arc::new(RwLock::new(result_rx)),
            worker_handles: Arc::new(RwLock::new(Vec::new())),
        }
    }

    /// Register an agent
    pub async fn register_agent(&self, mut agent: Box<dyn Agent>) -> Result<Uuid> {
        agent.initialize().await.context("Failed to initialize agent")?;
        
        let id = agent.metadata().id;
        let name = agent.metadata().name.clone();

        let mut agents = self.agents.write().await;
        agents.insert(id, agent);

        info!("Registered agent: {} ({})", name, id);

        Ok(id)
    }

    /// Unregister an agent
    pub async fn unregister_agent(&self, agent_id: Uuid) -> Result<()> {
        let mut agents = self.agents.write().await;
        
        if let Some(mut agent) = agents.remove(&agent_id) {
            agent.shutdown().await.context("Failed to shutdown agent")?;
            info!("Unregistered agent: {}", agent_id);
        }

        Ok(())
    }

    /// Submit a task
    pub async fn submit_task(&self, task: AgentTask) -> Result<Uuid> {
        let task_id = task.id;
        
        self.task_tx.send(task)
            .context("Failed to submit task")?;

        debug!("Submitted task: {}", task_id);

        Ok(task_id)
    }

    /// Get result (blocking until available)
    pub async fn get_result(&self) -> Option<AgentResult> {
        let mut rx = self.result_rx.write().await;
        rx.recv().await
    }

    /// Start the runtime
    pub async fn start(&self) -> Result<()> {
        info!("Starting agent runtime");

        let agents = self.agents.clone();
        let scheduler = self.scheduler.clone();

        // Start worker pool
        let num_workers = num_cpus::get();
        let mut handles = self.worker_handles.write().await;

        for worker_id in 0..num_workers {
            let agents = agents.clone();
            let scheduler = scheduler.clone();

            let handle = tokio::spawn(async move {
                info!("Worker {} started", worker_id);

                loop {
                    // Get next task from scheduler
                    if let Some(task) = scheduler.next_task().await {
                        debug!("Worker {} processing task {}", worker_id, task.id);

                        // Find agent that can handle this task
                        let agents_read = agents.read().await;
                        let mut agent_found = None;

                        for (id, agent) in agents_read.iter() {
                            if agent.can_handle(&task) {
                                agent_found = Some(*id);
                                break;
                            }
                        }
                        drop(agents_read);

                        if let Some(agent_id) = agent_found {
                            let agents_read = agents.read().await;
                            if let Some(agent) = agents_read.get(&agent_id) {
                                // Execute task
                                let start = std::time::Instant::now();
                                
                                match agent.execute(task.clone()).await {
                                    Ok(result) => {
                                        let duration = start.elapsed();
                                        info!(
                                            "Task {} completed by agent {} in {:?}",
                                            task.id, agent_id, duration
                                        );
                                        scheduler.submit_result(result).await;
                                    }
                                    Err(e) => {
                                        error!("Task {} failed: {}", task.id, e);
                                        let error_result = AgentResult {
                                            task_id: task.id,
                                            success: false,
                                            output: serde_json::json!({}),
                                            error: Some(e.to_string()),
                                            duration_ms: start.elapsed().as_millis() as FU64,
                                        };
                                        scheduler.submit_result(error_result).await;
                                    }
                                }
                            }
                        } else {
                            warn!("No agent found to handle task {}", task.id);
                            let error_result = AgentResult {
                                task_id: task.id,
                                success: false,
                                output: serde_json::json!({}),
                                error: Some("No agent available".to_string()),
                                duration_ms: 0,
                            };
                            scheduler.submit_result(error_result).await;
                        }
                    } else {
                        // No tasks available, sleep briefly
                        tokio::time::sleep(tokio::time::Duration::from_millis(10)).await;
                    }
                }
            });

            handles.push(handle);
        }

        info!("Agent runtime started with {} workers", num_workers);

        Ok(())
    }

    /// Stop the runtime
    pub async fn stop(&self) -> Result<()> {
        info!("Stopping agent runtime");

        // Shutdown all agents
        let mut agents = self.agents.write().await;
        for (id, agent) in agents.iter_mut() {
            if let Err(e) = agent.shutdown().await {
                error!("Failed to shutdown agent {}: {}", id, e);
            }
        }
        agents.clear();

        // Cancel all workers
        let mut handles = self.worker_handles.write().await;
        for handle in handles.drain(..) {
            handle.abort();
        }

        info!("Agent runtime stopped");

        Ok(())
    }

    /// List all registered agents
    pub async fn list_agents(&self) -> FVec<AgentMetadata> {
        let agents = self.agents.read().await;
        agents.values().map(|a| a.metadata().clone()).collect()
    }

    /// Get agent status
    pub async fn agent_status(&self, agent_id: Uuid) -> Option<AgentStatus> {
        let agents = self.agents.read().await;
        if let Some(agent) = agents.get(&agent_id) {
            Some(agent.status().await)
        } else {
            None
        }
    }
}

impl Default for AgentRuntime {
    fn default() -> Self {
        Self::new()
    }
}

#[cfg(test)]
mod tests {
    use super::*;
    use crate::agent::{Agent, AgentMetadata, AgentTask, AgentResult, Capability};
    use async_trait::async_trait;

    struct TestAgent {
        meta: AgentMetadata,
    }

    #[async_trait]
    impl Agent for TestAgent {
        fn metadata(&self) -> &AgentMetadata {
            &self.meta
        }

        fn can_handle(&self, _task: &AgentTask) -> FBool {
            true
        }

        async fn execute(&self, task: AgentTask) -> Result<AgentResult> {
            Ok(AgentResult {
                task_id: task.id,
                success: true,
                output: serde_json::json!({"result": "test"}),
                error: None,
                duration_ms: 10,
            })
        }
    }

    #[tokio::test]
    async fn test_runtime_creation() {
        let runtime = AgentRuntime::new();
        assert_eq!(runtime.list_agents().await.len(), 0);
    }

    #[tokio::test]
    async fn test_agent_registration() {
        let runtime = AgentRuntime::new();
        
        let agent = Box::new(TestAgent {
            meta: AgentMetadata {
                id: Uuid::new_v4(),
                name: "test".to_string(),
                capabilities: vec![Capability::CodeReview],
                max_concurrent_tasks: 1,
                priority: 5,
            },
        });

        let result = runtime.register_agent(agent).await;
        assert!(result.is_ok());
        assert_eq!(runtime.list_agents().await.len(), 1);
    }
}
