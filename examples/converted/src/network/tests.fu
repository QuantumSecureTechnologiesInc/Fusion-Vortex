// src/network/tests.rs
use super::*;

#[test]
fn test_secure_channel_echo() {
    let listener = TcpListener::bind("127.0.0.1:0").unwrap();
    let addr = listener.local_addr().unwrap();

    let server_handle = thread::spawn(move || {
        let (socket, _) = listener.accept().unwrap();
        let mut channel = SecureChannel::server_handshake(socket).unwrap();
        let msg = channel.recv().unwrap();
        channel.send(&msg).unwrap();
    });

    let mut client = FusionNetwork::connect(&addr.to_string()).unwrap();
    client.send(b"Hello").unwrap();
    let reply = client.recv().unwrap();
    assert_eq!(reply, b"Hello");

    server_handle.join().unwrap();
}

#[test]
fn test_authentication_flow() {
    let listener = TcpListener::bind("127.0.0.1:0").unwrap();
    let addr = listener.local_addr().unwrap();

    let server_handle = thread::spawn(move || {
        let (socket, _) = listener.accept().unwrap();
        let mut channel = SecureChannel::server_handshake(socket).unwrap();

        // Wait for auth request
        let msg = channel.recv_message().unwrap();
        match msg {
            Message::Authenticate { client_id, token } => {
                // Mock simple auth logic
                if token == "secret123" {
                    channel
                        .send_message(&Message::AuthResult {
                            success: true,
                            message: format!("Welcome {}", client_id),
                        })
                        .unwrap();
                } else {
                    channel
                        .send_message(&Message::AuthResult {
                            success: false,
                            message: "Invalid token".into(),
                        })
                        .unwrap();
                }
            }
            _ => panic!("Expected auth message"),
        }
    });

    let mut client = FusionNetwork::connect(&addr.to_string()).unwrap();
    client
        .authenticate("user1", "secret123")
        .expect("Authentication failed");

    assert_eq!(client.identity(), Some(&"user1".to_string()));
    assert!(client.is_authenticated());

    server_handle.join().unwrap();
}

#[test]
fn test_rate_limiting() {
    let listener = TcpListener::bind("127.0.0.1:0").unwrap();
    let addr = listener.local_addr().unwrap();

    let server_handle = thread::spawn(move || {
        let (socket, _) = listener.accept().unwrap();
        let mut channel = SecureChannel::server_handshake(socket).unwrap();
        // Server has default rate limit 100/sec implemented in server_handshake

        let mut hit_limit = false;
        // Try to read more messages than allowed in 1 sec (which is 0 duration effectively for test)
        for _ in 0..150 {
            match channel.recv_message() {
                Ok(_) => {}
                Err(NetworkError::RateLimit) => {
                    hit_limit = true;
                    break;
                }
                Err(_) => break,
            }
        }
        assert!(hit_limit, "Should have hit rate limit");
    });

    let mut client = FusionNetwork::connect(&addr.to_string()).unwrap();
    // Send 150 messages rapidly
    for _ in 0..150 {
        if let Err(_) = client.send_message(&Message::Ping) {
            break;
        }
    }

    server_handle.join().unwrap();
}

#[test]
fn test_concurrent_load() {
    let listener = TcpListener::bind("127.0.0.1:0").unwrap();
    let addr = listener.local_addr().unwrap();

    // Spawn thread-per-connection server (simulating highly concurrent server logic)
    // We manually implement the loop here to avoid dependency on the async Runtime for this unit test
    let server_handle = thread::spawn(move || {
        let mut handles = vec![];
        for _ in 0..10 {
            // Expect 10 clients
            let (socket, _) = listener.accept().unwrap();
            handles.push(thread::spawn(move || {
                let mut channel = SecureChannel::server_handshake(socket).unwrap();
                for _ in 0..50 {
                    let msg = match channel.recv_message() {
                        Ok(m) => m,
                        Err(_) => return,
                    };
                    let _ = channel.send_message(&msg); // Echo
                }
            }));
        }
        for h in handles {
            h.join().unwrap();
        }
    });

    // 10 Clients concurrently
    let mut handles = vec![];
    for i in 0..10 {
        let addr_str = addr.to_string();
        handles.push(thread::spawn(move || {
            let mut client = FusionNetwork::connect(&addr_str).unwrap();
            for j in 0..50 {
                let msg = Message::Execute {
                    function_name: "test".into(),
                    args: vec![i as u8, j as u8],
                };
                if client.send_message(&msg).is_err() {
                    break;
                }

                match client.recv_message() {
                    Ok(Message::Execute { args, .. }) => {
                        assert_eq!(args, vec![i as u8, j as u8]);
                    }
                    _ => {} // Ignore errors/wrong messages for robustness in test teardown
                }
            }
        }));
    }

    for h in handles {
        h.join().unwrap();
    }
    server_handle.join().unwrap();
}
