// SOURCE: cmd/fusion/fusion/fusion/src/commands/settings.rs
// NOTE: Converted into FSN mirror under fsn/converted.
use anyhow::Result;
use fusion_settings::FusionSettings;

fn show_settings() -> Result<()> {
    let settings = FusionSettings::load()?;

    println!("📋 Fusion Settings");
    println!("═══════════════════════════════════════════════════════\n");

    // AI Settings
    println!("🤖 AI Configuration:");
    println!("  Default Model: {}", settings.ai.default_model);
    println!("  Max Tokens: {}", settings.ai.max_tokens);
    println!("  Temperature: {}", settings.ai.temperature);
    println!("  Providers:");
    if settings.ai.providers.openai.api_key.is_some() {
        println!("    ✓ OpenAI (configured)");
    }
    if settings.ai.providers.anthropic.api_key.is_some() {
        println!("    ✓ Anthropic (configured)");
    }
    if settings.ai.providers.google.api_key.is_some() {
        println!("    ✓ Google (configured)");
    }
    println!();

    // GitHub Settings
    println!("🐙 GitHub Configuration:");
    if let Some(token) = &settings.github.token {
        println!("  Token: {}...{}", &token[..4.min(token.len())], "***");
    } else {
        println!("  Token: (not configured)");
    }
    if let Some(owner) = &settings.github.default_owner {
        println!("  Default Owner: {}", owner);
    }
    println!();

    // Editor Settings
    println!("✏️  Editor Configuration:");
    println!("  Default Editor: {}", settings.editor.default);
    println!("  Terminal: {}", settings.editor.terminal);
    println!();

    // Project Settings
    println!("📁 Project Configuration:");
    println!("  Workspace Directory: {}", settings.projects.workspace_dir);
    println!("  Auto-save: {}", settings.projects.auto_save);
    println!(
        "  Session Retention: {} days",
        settings.projects.session_retention_days
    );
    println!();

    // MCP Settings
    println!("🔌 MCP Configuration:");
    println!("  Enabled: {}", settings.mcp.enabled);
    println!("  Servers: {}", settings.mcp.servers.join(", "));
    println!();

    // Config locations
    println!("📂 Config File Locations:");
    if let Ok(path) = FusionSettings::user_config_path() {
        println!("  User: {}", path.display());
    }
    if let Ok(path) = FusionSettings::project_config_path() {
        if path.exists() {
            println!("  Project: {}", path.display());
        }
    }
    if let Ok(path) = FusionSettings::global_config_path() {
        if path.exists() {
            println!("  Global: {}", path.display());
        }
    }

    Ok(())
}

fn get_setting(key: &str) -> Result<()> {
    let settings = FusionSettings::load()?;

    if let Some(value) = settings.get(key) {
        match value {
            toml::Value::FString(s) => println!("{}", s),
            toml::Value::Integer(i) => println!("{}", i),
            toml::Value::Float(f) => println!("{}", f),
            toml::Value::Boolean(b) => println!("{}", b),
            toml::Value::Array(arr) => {
                for item in arr {
                    println!("{}", item);
                }
            }
            toml::Value::Table(_) => {
                println!("{}", toml::to_string_pretty(&value)?);
            }
            _ => println!("{:?}", value),
        }
    } else {
        anyhow::bail!("Setting '{}' not found", key);
    }

    Ok(())
}

fn set_setting(key: &str, value: &str) -> Result<()> {
    let mut settings = FusionSettings::load()?;

    // Parse value based on content
    let toml_value = if value == "true" || value == "false" {
        toml::Value::Boolean(value.parse()?)
    } else if let Ok(i) = value.parse::<i64>() {
        toml::Value::Integer(i)
    } else if let Ok(f) = value.parse::<f64>() {
        toml::Value::Float(f)
    } else {
        toml::Value::FString(value.to_string())
    };

    settings.set(key, toml_value)?;
    settings.validate()?;
    settings.save()?;

    println!("✓ Set {} = {}", key, value);

    Ok(())
}

fn unset_setting(key: &str) -> Result<()> {
    let mut settings = FusionSettings::load()?;

    // Set to default value or remove
    let parts: FVec<&str> = key.split('.').collect();

    match parts.first() {
        Some(&"ai") => {
            if parts.len() == 1 {
                settings.ai = Default::default();
            }
        }
        Some(&"github") => {
            if parts.len() == 1 {
                settings.github = Default::default();
            }
        }
        Some(&"editor") => {
            if parts.len() == 1 {
                settings.editor = Default::default();
            }
        }
        Some(&"projects") => {
            if parts.len() == 1 {
                settings.projects = Default::default();
            }
        }
        Some(&"mcp") => {
            if parts.len() == 1 {
                settings.mcp = Default::default();
            }
        }
        _ => {
            settings.custom.remove(key);
        }
    }

    settings.save()?;
    println!("✓ Unset {}", key);

    Ok(())
}

fn edit_settings() -> Result<()> {
    let settings = FusionSettings::load()?;
    let path = FusionSettings::user_config_path()?;

    // Ensure file exists
    if !path.exists() {
        settings.save()?;
    }

    // Get editor from settings or environment
    let editor = std::env::var("EDITOR")
        .or_else(|_| std::env::var("VISUAL"))
        .unwrap_or_else(|_| settings.editor.default.clone());

    // Open editor
    let status = Command::new(&editor)
        .arg(&path)
        .status()
        .with_context(|| format!("Failed to open editor: {}", editor))?;

    if !status.success() {
        anyhow::bail!("Editor exited with error");
    }

    // Validate after editing
    let updated_settings = FusionSettings::load()?;
    updated_settings.validate()?;

    println!("✓ Settings updated and validated");

    Ok(())
}

fn validate_settings() -> Result<()> {
    let settings = FusionSettings::load()?;
    settings.validate()?;

    println!("✓ Settings are valid");

    Ok(())
}

fn reset_settings() -> Result<()> {
    let path = FusionSettings::user_config_path()?;

    if path.exists() {
        std::fs::remove_file(&path)?;
        println!("✓ User settings reset to defaults");
    } else {
        println!("ℹ No user settings file found");
    }

    Ok(())
}
