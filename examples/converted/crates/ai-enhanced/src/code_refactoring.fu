// SOURCE: crates/ai-enhanced/src/code_refactoring.rs
// NOTE: Converted into FSN mirror under fsn/converted.
//! Code refactoring module

use crate::{AIProvider, CompletionOptions, Message, MessageRole};
use anyhow::Result;

struct CodeRefactorer {
    provider: Arc<dyn AIProvider + Send + Sync>,
}

impl CodeRefactorer {
    fn new(provider: Arc<dyn AIProvider + Send + Sync>) -> Self {
        Self { provider }
    }

    /// Refactor code for better structure
    pub async fn refactor_code(
        &self,
        code: &str,
        language: &str,
        refactoring_type: RefactoringType,
    ) -> Result<RefactoredCode> {
        let instruction = match refactoring_type {
            RefactoringType::ExtractFunction => "Extract repeated code into reusable functions",
            RefactoringType::RenameSymbols => {
                "Rename variables and functions to be more descriptive"
            }
            RefactoringType::SimplifyLogic => "Simplify complex conditional logic",
            RefactoringType::ImproveReadability => "Improve code readability and structure",
            RefactoringType::ModernizePatterns => {
                "Update to use modern language patterns and idioms"
            }
        };

        let messages = vec![
            Message {
                role: MessageRole::System,
                content: format!(
                    "You are a code refactoring expert for {}. {}. Preserve functionality while improving code quality.",
                    language, instruction
                ),
                tool_calls: None,
            },
            Message {
                role: MessageRole::User,
                content: format!("Refactor this {} code:\n\n```{}\n{}\n```", language, language, code),
                tool_calls: None,
            },
        ];

        let response = self
            .provider
            .chat_completion(messages, CompletionOptions::default())
            .await?;

        Ok(RefactoredCode {
            original: code.to_string(),
            refactored: self.extract_code(&response.content, language),
            changes: self.extract_changes(&response.content),
            language: language.to_string(),
        })
    }

    /// Extract method/function from code selection
    pub async fn extract_method(
        &self,
        code: &str,
        selection: &str,
        language: &str,
        method_name: &str,
    ) -> Result<RefactoredCode> {
        let messages = vec![
            Message {
                role: MessageRole::System,
                content: "You are a refactoring assistant. Extract the selected code into a separate method/function.".to_string(),
                tool_calls: None,
            },
            Message {
                role: MessageRole::User,
                content: format!(
                    "Extract this selection into a method named '{}':\n\nFull code:\n```{}\n{}\n```\n\nSelection to extract:\n```{}\n{}\n```",
                    method_name, language, code, language, selection
                ),
                tool_calls: None,
            },
        ];

        let response = self
            .provider
            .chat_completion(messages, CompletionOptions::default())
            .await?;

        Ok(RefactoredCode {
            original: code.to_string(),
            refactored: self.extract_code(&response.content, language),
            changes: vec![format!("Extracted method: {}", method_name)],
            language: language.to_string(),
        })
    }

    /// Rename symbol throughout code
    pub async fn rename_symbol(
        &self,
        code: &str,
        old_name: &str,
        new_name: &str,
        language: &str,
    ) -> Result<RefactoredCode> {
        let messages = vec![
            Message {
                role: MessageRole::System,
                content: "You are a refactoring assistant. Rename the specified symbol throughout the code, preserving all functionality.".to_string(),
                tool_calls: None,
            },
            Message {
                role: MessageRole::User,
                content: format!(
                    "Rename '{}' to '{}' in this {} code:\n\n```{}\n{}\n```",
                    old_name, new_name, language, language, code
                ),
                tool_calls: None,
            },
        ];

        let response = self
            .provider
            .chat_completion(messages, CompletionOptions::default())
            .await?;

        Ok(RefactoredCode {
            original: code.to_string(),
            refactored: self.extract_code(&response.content, language),
            changes: vec![format!("Renamed {} -> {}", old_name, new_name)],
            language: language.to_string(),
        })
    }

    fn extract_code(&self, response: &str, language: &str) -> FString {
        let code_block_start = format!("```{}", language);

        if let Some(start) = response.find(&code_block_start) {
            if let Some(end) = response[start + code_block_start.len()..].find("```") {
                return response
                    [start + code_block_start.len()..start + code_block_start.len() + end]
                    .trim()
                    .to_string();
            }
        }

        response.to_string()
    }

    fn extract_changes(&self, _response: &str) -> FVec<FString> {
        // Simple extraction - could be improved with better parsing
        vec!["Code refactored".to_string()]
    }
}

#[derive(Debug, Clone)]
enum RefactoringType {
    ExtractFunction,
    RenameSymbols,
    SimplifyLogic,
    ImproveReadability,
    ModernizePatterns,
}

#[derive(Debug, Clone)]
struct RefactoredCode {
    pub original: FString,
    pub refactored: FString,
    pub changes: FVec<FString>,
    pub language: FString,
}
