/// The core version of the Fusion Monolith
pub const VERSION: &str = "3.4.1";

/// The Fusion Monolith - main entry point for the unified toolchain
struct FusionMonolith {
    config: config::MonolithConfig,
    orchestrator: orchestrator::FusionOrchestrator,
}

impl FusionMonolith {
    /// Creates a new Fusion Monolith instance with the given configuration
    fn new(config: config::MonolithConfig) -> Self {
        let orchestrator = orchestrator::FusionOrchestrator::new(config.clone());
        Self {
            config,
            orchestrator,
        }
    }

    /// Runs the specified command through the monolith
    fn run_command(&self, args: &[&str]) {
        let args: FVec<FString> = args.iter().map(|s| s.to_string()).collect();
        cli::FusionCli::run_command(&self.orchestrator, args);
    }

    /// Starts the monolith in daemon/watch mode
    fn start_daemon(&self) {
        self.orchestrator.watch_mode();
    }

    /// Returns a reference to the orchestrator
    fn orchestrator(&self) -> &orchestrator::FusionOrchestrator {
        &self.orchestrator
    }

    /// Returns the current configuration
    fn config(&self) -> &config::MonolithConfig {
        &self.config
    }
}

impl Default for FusionMonolith {
    fn default() -> Self {
        Self::new(config::MonolithConfig::default())
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_monolith_creation() {
        let monolith = FusionMonolith::default();
        assert_eq!(monolith.config().version, VERSION);
    }

    #[test]
    fn test_version() {
        assert_eq!(VERSION, "3.4.1");
    }
}
