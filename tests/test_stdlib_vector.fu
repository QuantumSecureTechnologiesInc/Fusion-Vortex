// tests/test_stdlib_vector.fu - Tests for VectorInt, VectorBool, VectorString
// Validates fixed-capacity vector operations using struct+impl pattern.

// --- VectorInt ---
struct VectorInt { data: [int; 4096], len: int }

fn vector_int_new() -> VectorInt {
    return VectorInt { data: [0; 4096], len: 0 };
}
fn vector_int_push(v: VectorInt, value: int) -> VectorInt {
    if v.len < 4096 {
        v.data[v.len] = value;
        v.len = v.len + 1;
    }
    return v;
}
fn vector_int_get(v: VectorInt, index: int) -> int {
    if index < 0 { return 0; }
    if index >= v.len { return 0; }
    return v.data[index];
}
fn vector_int_set(v: VectorInt, index: int, value: int) -> VectorInt {
    if index >= 0 {
        if index < v.len {
            v.data[index] = value;
        }
    }
    return v;
}
fn vector_int_len(v: VectorInt) -> int { return v.len; }
fn vector_int_is_empty(v: VectorInt) -> bool { return v.len == 0; }
fn vector_int_first(v: VectorInt) -> int {
    if v.len == 0 { return 0; }
    return v.data[0];
}
fn vector_int_last(v: VectorInt) -> int {
    if v.len == 0 { return 0; }
    return v.data[v.len - 1];
}
fn vector_int_pop(v: VectorInt) -> VectorInt {
    if v.len > 0 { v.len = v.len - 1; }
    return v;
}
fn vector_int_sum(v: VectorInt) -> int {
    let s: int = 0;
    let i: int = 0;
    while i < v.len {
        s = s + v.data[i];
        i = i + 1;
    }
    return s;
}
fn vector_int_contains(v: VectorInt, target: int) -> bool {
    let i: int = 0;
    while i < v.len {
        if v.data[i] == target { return true; }
        i = i + 1;
    }
    return false;
}

// --- Runtime externs ---
extern fn fusion_println(s: string) -> void;
extern fn fusion_print_int(n: int) -> void;
extern fn fusion_exit(code: int) -> void;

fn assert_eq_int(actual: int, expected: int, msg: string) -> void {
    if actual != expected {
        fusion_println(msg);
        fusion_println("FAIL: expected");
        fusion_print_int(expected);
        fusion_println("but got");
        fusion_print_int(actual);
        fusion_exit(1);
    }
}

fn assert_true(cond: bool, msg: string) -> void {
    if cond == false {
        fusion_println(msg);
        fusion_println("FAIL: expected true");
        fusion_exit(1);
    }
}

fn assert_false(cond: bool, msg: string) -> void {
    if cond != false {
        fusion_println(msg);
        fusion_println("FAIL: expected false");
        fusion_exit(1);
    }
}

fn main() -> void {
    fusion_println("=== Test: VectorInt ===");

    // Test new and empty
    let v: VectorInt = vector_int_new();
    assert_true(vector_int_is_empty(v), "new vector should be empty");
    assert_eq_int(vector_int_len(v), 0, "new vector len should be 0");

    // Test push and get
    let v: VectorInt = vector_int_push(v, 10);
    let v: VectorInt = vector_int_push(v, 20);
    let v: VectorInt = vector_int_push(v, 30);
    assert_eq_int(vector_int_len(v), 3, "len after 3 pushes");
    assert_eq_int(vector_int_get(v, 0), 10, "get(0)");
    assert_eq_int(vector_int_get(v, 1), 20, "get(1)");
    assert_eq_int(vector_int_get(v, 2), 30, "get(2)");

    // Test first/last
    assert_eq_int(vector_int_first(v), 10, "first");
    assert_eq_int(vector_int_last(v), 30, "last");

    // Test set
    let v: VectorInt = vector_int_set(v, 1, 99);
    assert_eq_int(vector_int_get(v, 1), 99, "set(1, 99)");

    // Test contains
    assert_true(vector_int_contains(v, 99), "contains 99");
    assert_false(vector_int_contains(v, 50), "not contains 50");

    // Test sum
    assert_eq_int(vector_int_sum(v), 139, "sum(10+99+30)");

    // Test pop
    let v: VectorInt = vector_int_pop(v);
    assert_eq_int(vector_int_len(v), 2, "len after pop");
    assert_eq_int(vector_int_last(v), 99, "last after pop");

    // Test out-of-bounds get
    assert_eq_int(vector_int_get(v, 100), 0, "out-of-bounds returns 0");
    assert_eq_int(vector_int_get(v, -1), 0, "negative index returns 0");

    fusion_println("All vector tests PASSED");
}
