}

pub fn main() -> int {
    let args: Fuc2Args = parse_args();
    
    printf("=== Fusion Compiler v2 (fuc2) ===\n");
    printf("  Input:  %s\n", args.input);
    printf("  Output: %s\n", args.output);
    printf("\n");
    
    printf("[fuc2] Resolving modules...\n");
    printf("[fuc2] Desugaring syntax...\n");
    
    // Stage 1: Preprocess using PowerShell helper
    let r: int = 0;
    r = system("powershell -ExecutionPolicy Bypass -File scripts\\selfhost_preprocess.ps1 crates\\fuc2\\src\\main.fu fuc2_flat.fu");
    if r != 0 {
        printf("[fuc2] Preprocessing failed\n");
        return 1;
    }
    printf("[fuc2] Preprocessing complete.\n");
    
    // Stage 2: Compile with bootstrap compiler
    r = system("bin\\fuc.exe --emit-bin -o fuc2_next.exe fuc2_flat.fu");
    if r != 0 {
        printf("[fuc2] Compilation failed\n");
        return 1;
    }
    
    printf("[fuc2] Build successful: %s\n", args.output);
    return 0;
}

fn invoke_bootstrap(bootstrap: string, flat_file: string, output: string) -> int {
    printf("  [fuc2] Invoking bootstrap compiler...\n");
    let r: int = 0;
    r = system("bin\\fuc.exe --emit-bin -o fuc2_next.exe fuc2_flat.fu");
    if r != 0 {
        printf("  [fuc2] Bootstrap compilation failed\n");
        return 1;
    }
    printf("  [fuc2] Bootstrap compilation successful.\n");
    return 0;
}
