//! fuc2 — Fusion Compiler v2: Module Preprocessor and Build Driver
//!
//! Extends the bootstrap fuc.exe compiler with:
//! 1. Multi-file module resolution (mod X; → reads X.fu)
//! 2. Syntax desugaring (pub, enum → int constants, use removal)
//! 3. extern fn deduplication across modules
//! 4. Vortex borrow checking integration (optional pre-compilation pass)
//!
//! Pipeline: source.fu → resolve mods → desugar → flatten → fuc.exe → link

extern fn printf(fmt: string, ...) -> int;
extern fn strlen(s: string) -> int;
extern fn system(cmd: string) -> int;

// CLI arguments (minimal — fits in 16 bytes)
struct Fuc2Args {
    input: string,
    output: string,
}

fn parse_args() -> Fuc2Args {
    let mut args: Fuc2Args = Fuc2Args {
        input: "a.fu",
        output: "a.out",
    };
    return args;
}

//===----------------------------------------------------------------------===//
// Module Resolver
//===----------------------------------------------------------------------===//

