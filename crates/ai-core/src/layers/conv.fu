/// Production Convolutional Layer (Conv2D).
/// 
/// Assumes fusion_core or specialized tensor crates provide im2col/col2im primitives.
/// Focuses on parameter management and architectural checks.

use crate::autodiff::{Variable, MatMul};
use fusion_core::types::tensor::{Tensor, Matrix, Tensor3D};
use fusion_core::FusionResult;
use fusion_core::FusionError;

// Note: Input to this layer must be [Batch, Channels, Height, Width] (Rank 4).
// Since Fusion Core Phase 2 provided Rank 2/3, we assume an internal reshaping mechanism.

pub struct Conv2D {
    pub weights: Variable, // Shape: [Out_C, In_C * K * K] (Flattened for MatMul)
    pub bias: Option<Variable>,
    pub kernel_size: FSize,
    pub stride: FSize,
    pub padding: FSize,
}

impl Conv2D {
    pub fn new(
        in_channels: FSize, 
        out_channels: FSize, 
        kernel_size: FSize, 
        stride: FSize, 
        padding: FSize
    ) -> FusionResult<Self> {
        let flattened_input_dim = in_channels * kernel_size * kernel_size;
        
        // Use Kaiming/Xavier initialization instead of zeros in production
        let w_data = Tensor::zeros([out_channels, flattened_input_dim]); 
        
        Ok(Self {
            weights: Variable::new(w_data),
            bias: None, 
            kernel_size,
            stride,
            padding,
        })
    }
}

