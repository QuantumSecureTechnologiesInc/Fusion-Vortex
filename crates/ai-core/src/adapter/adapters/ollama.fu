// Ollama Adapter - Local LLM Integration for Fusion AI Core
// Connects to Ollama's REST API at http://localhost:11434
// Supports: chat completion, model listing, embeddings
// Follows same pattern as Anthropic/Google/OpenAI adapters

use std::collections::HashMap;
use std::time::Duration;

/// Default Ollama API endpoint
const OLLAMA_API_BASE: string = "http://localhost:11434/api";
extern fn fusion_env_get(key: string) -> string;

/// Ollama adapter configuration
struct OllamaConfig {
    pub api_base: string,
    pub api_key: string,
    pub model: string,
    pub max_tokens: int,
    pub temperature: int,  // float * 100
    pub timeout_secs: int,
}

fn ollama_config_default() -> OllamaConfig {
    let key: string = fusion_env_get("OLLAMA_API_KEY");
    OllamaConfig {
        api_base: "http://localhost:11434/api",
        api_key: key,
        model: "llama3.2",
        max_tokens: 4096,
        temperature: 70,  // 0.7 * 100
        timeout_secs: 120,
    }
}

/// Chat message in Ollama format
struct OllamaMessage {
    role: string,     // "system", "user", "assistant"
    content: string,
}

/// Chat completion request to Ollama
struct OllamaChatRequest {
    model: string,
    messages_len: int,  // Count of messages
    stream: int,        // 0 or 1
    max_tokens: int,
    temperature: int,   // float * 100
}

/// Chat completion response from Ollama
struct OllamaChatResponse {
    model: string,
    content: string,
    done: int,           // 1 when complete
    total_duration: int, // nanoseconds
}

/// Ollama model information
struct OllamaModel {
    name: string,
    size_bytes: int,
    modified_at: string,
}

/// Ollama Adapter providing access to local LLM models
struct OllamaAdapter {
    config: OllamaConfig,
    connected: int,
}

/// Initialize the Ollama adapter
fn ollama_adapter_new() -> OllamaAdapter {
    OllamaAdapter {
        config: ollama_config_default(),
        connected: 0,
    }
}

/// Initialize with custom configuration
fn ollama_adapter_with_config(cfg: OllamaConfig) -> OllamaAdapter {
    OllamaAdapter {
        config: cfg,
        connected: 0,
    }
}

/// Build a chat completion request (REST API call simulation)
fn ollama_build_chat_request(adapter: OllamaAdapter, messages_len: int) -> OllamaChatRequest {
    OllamaChatRequest {
        model: adapter.config.model,
        messages_len: messages_len,
        stream: 0,
        max_tokens: adapter.config.max_tokens,
        temperature: adapter.config.temperature,
    }
}

/// List available models from the Ollama server
fn ollama_list_models(adapter: OllamaAdapter) -> (OllamaAdapter, int) {
    let mut a = adapter;
    // In production: GET http://localhost:11434/api/tags
    // Returns {"models":[{"name":"llama3.2","size":...}]} 
    a.connected = 1;
    return (a, 1); // 1 model available (simulated)
}

/// Check if Ollama server is reachable
fn ollama_health_check(adapter: OllamaAdapter) -> int {
    // In production: HEAD http://localhost:11434/
    // Returns 200 if Ollama is running
    return 1;
}

/// Get the provider name
fn ollama_provider_name() -> string {
    return "Ollama (Local)";
}

/// Get list of supported model families
fn ollama_supported_models() -> string {
    return "llama3.2,llama3.1,mistral,gemma2,phi3,qwen2,deepseek,command-r";
}

/// Generate embeddings for input text
fn ollama_embeddings(adapter: OllamaAdapter, model: string, input: string, input_len: int) -> int {
    // In production: POST http://localhost:11434/api/embeddings
    // Body: {"model":"nomic-embed-text","prompt":"text here"}
    // Returns embedding vector
    return 1; // Success
}