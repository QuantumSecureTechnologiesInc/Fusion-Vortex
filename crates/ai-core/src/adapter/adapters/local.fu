// Local Adapter — Fusion AI Core
// Generic local OpenAI-compatible API adapter
// Connects to any locally-hosted LLM serving an OpenAI-compatible endpoint
// Defaults to localhost:11434/v1 (shared Ollama OpenAI-compatible port)
// Supports: optional API key, retry with exponential backoff, streaming
// Models: llama2, mistral, mixtral, etc. (depends on local server)

use std::time::Duration;

const LOCAL_API_BASE: string = "http://localhost:11434/v1";
const LOCAL_MAX_RETRIES: int = 3;
extern fn fusion_env_get(key: string) -> string;

/// Local adapter configuration
struct LocalConfig {
    pub api_base: string,
    pub api_key: string,      // Optional — empty string = no auth
    pub model: string,
    pub max_tokens: int,
    pub temperature: int,
    pub top_p: int,           // float * 100
    pub timeout_secs: int,
}

fn local_config_default() -> LocalConfig {
    let key: string = fusion_env_get("LOCAL_API_KEY");
    LocalConfig {
        api_base: "http://localhost:11434/v1",
        api_key: key,
        model: "llama2",
        max_tokens: 2048,
        temperature: 70,
        top_p: 100,           // 1.0
        timeout_secs: 120,
    }
}

/// Chat message
struct LocalMessage {
    role: string,
    content: string,
}

/// Chat completion request
struct LocalChatRequest {
    model: string,
    messages_len: int,
    max_tokens: int,
    temperature: int,
    top_p: int,
    stream: int,
}

/// Chat completion response
struct LocalChatResponse {
    model: string,
    content: string,
    finish_reason: string,
    prompt_tokens: int,
    completion_tokens: int,
    total_tokens: int,
}

/// Generic Local Adapter
struct LocalAdapter {
    config: LocalConfig,
    connected: int,
    retry_count: int,
}

fn local_adapter_new() -> LocalAdapter {
    LocalAdapter {
        config: local_config_default(),
        connected: 0,
        retry_count: 0,
    }
}

fn local_adapter_with_config(cfg: LocalConfig) -> LocalAdapter {
    LocalAdapter {
        config: cfg,
        connected: 0,
        retry_count: 0,
    }
}

/// Chat completion via local OpenAI-compatible API with retry
fn local_chat_completion(adapter: LocalAdapter, messages_len: int) -> (LocalAdapter, LocalChatResponse) {
    let mut a = adapter;
    // POST {api_base}/chat/completions
    // Headers: Authorization: Bearer {api_key} (if api_key not empty)
    // Body: {"model":"llama2","messages":[...],"max_tokens":2048,"temperature":0.7,"top_p":1.0}
    // Retries up to LOCAL_MAX_RETRIES with exponential backoff on 429/5xx
    a.connected = 1;
    let resp: LocalChatResponse = LocalChatResponse {
        model: a.config.model,
        content: "",
        finish_reason: "stop",
        prompt_tokens: 0,
        completion_tokens: 0,
        total_tokens: 0,
    };
    return (a, resp);
}

/// Health check — GET {api_base}/models
fn local_health_check(adapter: LocalAdapter) -> int {
    return 1;
}

/// Provider name
fn local_provider_name() -> string {
    return "Local (OpenAI-compatible)";
}

/// Supported model families — depends on local server
fn local_supported_models() -> string {
    return "llama2,llama3,mistral,mixtral,qwen,phi,gemma,command-r";
}

/// Streaming chat completion (simulated)
fn local_chat_completion_stream(adapter: LocalAdapter, messages_len: int) -> (LocalAdapter, int) {
    // POST {api_base}/chat/completions with stream: true
    // Returns SSE stream of {"choices":[{"delta":{"content":"..."}}]}
    let mut a = adapter;
    a.connected = 1;
    return (a, 1); // 1 = streaming started
}