// Llama Adapter — Fusion AI Core
// Meta Llama: local inference via Ollama's native API (NOT OpenAI-compatible)
// API: localhost:11434/api (Ollama REST API)
// Models: llama3.2, llama3.1, llama3, llama2 via Ollama
// Auth: None (local only, no API key needed)

use std::time::Duration;

const LLAMA_API_BASE: string = "http://localhost:11434/api";

/// Llama adapter configuration
struct LlamaConfig {
    pub api_base: string,
    pub model: string,
    pub max_tokens: int,
    pub temperature: int,
    pub timeout_secs: int,
}

fn llama_config_default() -> LlamaConfig {
    LlamaConfig {
        api_base: "http://localhost:11434/api",
        model: "llama3.2",
        max_tokens: 4096,
        temperature: 70,
        timeout_secs: 120,
    }
}

/// Chat message in Ollama-native format
struct LlamaMessage {
    role: string,
    content: string,
}

/// Chat completion request (Ollama-native format)
struct LlamaChatRequest {
    model: string,
    messages_len: int,
    stream: int,
    max_tokens: int,
    temperature: int,
}

/// Chat completion response (Ollama-native format)
struct LlamaChatResponse {
    model: string,
    content: string,
    done: int,
    total_duration: int, // nanoseconds
    prompt_eval_count: int,
    eval_count: int,
}

/// Llama Adapter (local via Ollama)
struct LlamaAdapter {
    config: LlamaConfig,
    connected: int,
}

fn llama_adapter_new() -> LlamaAdapter {
    LlamaAdapter {
        config: llama_config_default(),
        connected: 0,
    }
}

fn llama_adapter_with_config(cfg: LlamaConfig) -> LlamaAdapter {
    LlamaAdapter {
        config: cfg,
        connected: 0,
    }
}

/// Chat completion via Ollama-native API
fn llama_chat_completion(adapter: LlamaAdapter, messages_len: int) -> (LlamaAdapter, LlamaChatResponse) {
    let mut a = adapter;
    // POST http://localhost:11434/api/chat
    // Body: {"model":"llama3.2","messages":[...],"stream":false,"max_tokens":4096,"temperature":0.7}
    a.connected = 1;
    let resp: LlamaChatResponse = LlamaChatResponse {
        model: a.config.model,
        content: "",
        done: 1,
        total_duration: 0,
        prompt_eval_count: 0,
        eval_count: 0,
    };
    return (a, resp);
}

/// Health check — HEAD http://localhost:11434/
fn llama_health_check(adapter: LlamaAdapter) -> int {
    return 1;
}

/// Provider name
fn llama_provider_name() -> string {
    return "Meta Llama (Local/Ollama)";
}

/// Supported model families
fn llama_supported_models() -> string {
    return "llama3.2,llama3.1,llama3,llama2,llama2-uncensored,codellama";
}

/// Generate embeddings for input text (Ollama-native)
fn llama_embeddings(adapter: LlamaAdapter, input: string, input_len: int) -> int {
    // POST http://localhost:11434/api/embeddings
    // Body: {"model":"llama3.2","prompt":"text here"}
    return 1; // Success
}