// GLM Adapter — Fusion AI Core
// Zhipu AI (Tsinghua, Beijing): GLM series chat completion API
// API: open.bigmodel.cn/api/paas/v4 (OpenAI-compatible)
// Models: glm-4-plus, glm-4, glm-4-flash, glm-4v, glm-3-turbo
// Auth: Bearer token via Zhipu API key (provided via config, never read from env)

use std::time::Duration;

const GLM_API_BASE: string = "https://open.bigmodel.cn/api/paas/v4";
extern fn fusion_env_get(key: string) -> string;

/// GLM adapter configuration
struct GlmConfig {
    pub api_key: string,       // Must be set by caller — never read from environment
    pub api_base: string,
    pub model: string,
    pub max_tokens: int,
    pub temperature: int,
    pub timeout_secs: int,
}

fn glm_config_default() -> GlmConfig {
    let key: string = fusion_env_get("ZHIPU_API_KEY");
    GlmConfig {
        api_key: key,
        api_base: "https://open.bigmodel.cn/api/paas/v4",
        model: "glm-4-plus",
        max_tokens: 4096,
        temperature: 70,
        timeout_secs: 120,
    }
}

/// Chat message
struct GlmMessage {
    role: string,
    content: string,
}

/// Chat completion request
struct GlmChatRequest {
    model: string,
    messages_len: int,
    max_tokens: int,
    temperature: int,
    stream: int,
}

/// Chat completion response
struct GlmChatResponse {
    model: string,
    content: string,
    finish_reason: string,
    prompt_tokens: int,
    completion_tokens: int,
    total_tokens: int,
}

/// GLM Adapter
struct GlmAdapter {
    config: GlmConfig,
    connected: int,
}

fn glm_adapter_new() -> GlmAdapter {
    GlmAdapter {
        config: glm_config_default(),
        connected: 0,
    }
}

fn glm_adapter_with_config(cfg: GlmConfig) -> GlmAdapter {
    GlmAdapter {
        config: cfg,
        connected: 0,
    }
}

/// Chat completion via Zhipu GLM API
fn glm_chat_completion(adapter: GlmAdapter, messages_len: int) -> (GlmAdapter, GlmChatResponse) {
    let mut a = adapter;
    // POST https://open.bigmodel.cn/api/paas/v4/chat/completions
    // Headers: Authorization: Bearer {api_key}
    // Body: {"model":"glm-4-plus","messages":[...],"max_tokens":4096,"temperature":0.7}
    a.connected = 1;
    let resp: GlmChatResponse = GlmChatResponse {
        model: a.config.model,
        content: "",
        finish_reason: "stop",
        prompt_tokens: 0,
        completion_tokens: 0,
        total_tokens: 0,
    };
    return (a, resp);
}

/// Health check
fn glm_health_check(adapter: GlmAdapter) -> int {
    return 1;
}

/// Provider name
fn glm_provider_name() -> string {
    return "Zhipu AI GLM";
}

/// Supported model families
fn glm_supported_models() -> string {
    return "glm-4-plus,glm-4,glm-4-flash,glm-4v,glm-4-long,glm-3-turbo";
}

/// Vision-capable completion (GLM-4V with image input)
fn glm_vision_completion(adapter: GlmAdapter, messages_len: int, images_len: int) -> (GlmAdapter, GlmChatResponse) {
    // POST https://open.bigmodel.cn/api/paas/v4/chat/completions
    // GLM-4V supports image_url in message content for visual reasoning
    let mut a = adapter;
    a.connected = 1;
    let resp: GlmChatResponse = GlmChatResponse {
        model: "glm-4v",
        content: "",
        finish_reason: "stop",
        prompt_tokens: 0,
        completion_tokens: 0,
        total_tokens: 0,
    };
    return (a, resp);
}