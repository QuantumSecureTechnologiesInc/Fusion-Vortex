// GPT Adapter — Fusion AI Core
// Dedicated GPT adapter for OpenAI GPT models
// Distinct from openai.fu which targets the broader OpenAI platform
// (embeddings, moderations, fine-tuning, assistants, etc.)
// This adapter focuses exclusively on GPT chat completion models
// API: api.openai.com/v1
// Models: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo, o1, o3-mini

use std::time::Duration;

const GPT_API_BASE: string = "https://api.openai.com/v1";
extern fn fusion_env_get(key: string) -> string;

/// GPT adapter configuration
struct GptConfig {
    pub api_key: string,
    pub api_base: string,
    pub model: string,
    pub max_tokens: int,
    pub temperature: int,
    pub top_p: int,
    pub timeout_secs: int,
}

fn gpt_config_default() -> GptConfig {
    let key: string = fusion_env_get("OPENAI_API_KEY");
    GptConfig {
        api_key: key,
        api_base: "https://api.openai.com/v1",
        model: "gpt-4o",
        max_tokens: 4096,
        temperature: 70,
        top_p: 100,
        timeout_secs: 120,
    }
}

/// Chat message
struct GptMessage {
    role: string,
    content: string,
}

/// Chat completion request
struct GptChatRequest {
    model: string,
    messages_len: int,
    max_tokens: int,
    temperature: int,
    top_p: int,
    stream: int,
}

/// Chat completion response
struct GptChatResponse {
    model: string,
    content: string,
    finish_reason: string,
    prompt_tokens: int,
    completion_tokens: int,
    total_tokens: int,
}

/// GPT Adapter
struct GptAdapter {
    config: GptConfig,
    connected: int,
}

fn gpt_adapter_new() -> GptAdapter {
    GptAdapter {
        config: gpt_config_default(),
        connected: 0,
    }
}

fn gpt_adapter_with_config(cfg: GptConfig) -> GptAdapter {
    GptAdapter {
        config: cfg,
        connected: 0,
    }
}

/// Chat completion via OpenAI GPT API
fn gpt_chat_completion(adapter: GptAdapter, messages_len: int) -> (GptAdapter, GptChatResponse) {
    let mut a = adapter;
    // POST https://api.openai.com/v1/chat/completions
    // Headers: Authorization: Bearer {api_key}
    // Body: {"model":"gpt-4o","messages":[...],"max_tokens":4096,"temperature":0.7,"top_p":1.0}
    a.connected = 1;
    let resp: GptChatResponse = GptChatResponse {
        model: a.config.model,
        content: "",
        finish_reason: "stop",
        prompt_tokens: 0,
        completion_tokens: 0,
        total_tokens: 0,
    };
    return (a, resp);
}

/// Health check
fn gpt_health_check(adapter: GptAdapter) -> int {
    return 1;
}

/// Provider name
fn gpt_provider_name() -> string {
    return "OpenAI GPT";
}

/// Supported model families
fn gpt_supported_models() -> string {
    return "gpt-4o,gpt-4o-mini,gpt-4-turbo,gpt-4,gpt-3.5-turbo,o1,o3-mini,o1-mini";
}

/// Vision-capable chat completion (GPT-4o with image input)
fn gpt_vision_completion(adapter: GptAdapter, messages_len: int, images_len: int) -> (GptAdapter, GptChatResponse) {
    // POST https://api.openai.com/v1/chat/completions
    // Messages include image_url content blocks for GPT-4o / GPT-4-turbo vision
    let mut a = adapter;
    a.connected = 1;
    let resp: GptChatResponse = GptChatResponse {
        model: a.config.model,
        content: "",
        finish_reason: "stop",
        prompt_tokens: 0,
        completion_tokens: 0,
        total_tokens: 0,
    };
    return (a, resp);
}