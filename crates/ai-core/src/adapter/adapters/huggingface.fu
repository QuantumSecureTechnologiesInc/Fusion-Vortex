// HuggingFace Adapter — Fusion AI Core
// HuggingFace Inference API: serverless model inference
// API: api-inference.huggingface.co/models/{model_id}
// Supports: text-generation, feature-extraction (embeddings)
// Default model: mistralai/Mistral-7B-Instruct-v0.3
// Auth: Bearer token via HuggingFace API token (provided via config, never read from env)
// Note: Free tier has rate limits; Pro tier for production use

use std::time::Duration;

const HUGGINGFACE_API_BASE: string = "https://api-inference.huggingface.co";
extern fn fusion_env_get(key: string) -> string;

/// HuggingFace adapter configuration
struct HuggingfaceConfig {
    pub api_key: string,       // Must be set by caller — never read from environment
    pub api_base: string,
    pub model: string,         // Full model ID: "org/model-name"
    pub task: string,          // "text-generation" or "feature-extraction"
    pub max_new_tokens: int,
    pub temperature: int,
    pub top_p: int,
    pub timeout_secs: int,
}

fn huggingface_config_default() -> HuggingfaceConfig {
    let key: string = fusion_env_get("HUGGINGFACE_API_KEY");
    HuggingfaceConfig {
        api_key: key,
        api_base: "https://api-inference.huggingface.co",
        model: "mistralai/Mistral-7B-Instruct-v0.3",
        task: "text-generation",
        max_new_tokens: 256,
        temperature: 70,
        top_p: 95,
        timeout_secs: 120,
    }
}

/// HuggingFace text generation request
struct HuggingfaceTextRequest {
    inputs: string,           // Prompt text
    parameters_max_new_tokens: int,
    parameters_temperature: int,
    parameters_top_p: int,
    parameters_do_sample: int, // 0 or 1
}

/// HuggingFace text generation response (list of generated texts)
struct HuggingfaceTextResponse {
    generated_text: string,
}

/// HuggingFace feature extraction request
struct HuggingfaceEmbeddingRequest {
    inputs: string,
}

/// HuggingFace Adapter
struct HuggingfaceAdapter {
    config: HuggingfaceConfig,
    connected: int,
}

fn huggingface_adapter_new() -> HuggingfaceAdapter {
    HuggingfaceAdapter {
        config: huggingface_config_default(),
        connected: 0,
    }
}

fn huggingface_adapter_with_config(cfg: HuggingfaceConfig) -> HuggingfaceAdapter {
    HuggingfaceAdapter {
        config: cfg,
        connected: 0,
    }
}

/// Text generation via HuggingFace Inference API
fn huggingface_text_generation(adapter: HuggingfaceAdapter, prompt: string, prompt_len: int) -> (HuggingfaceAdapter, HuggingfaceTextResponse) {
    let mut a = adapter;
    // POST https://api-inference.huggingface.co/models/mistralai/Mistral-7B-Instruct-v0.3
    // Headers: Authorization: Bearer {api_key}
    // Body: {"inputs":"prompt text","parameters":{"max_new_tokens":256,"temperature":0.7,"do_sample":true}}
    a.connected = 1;
    let resp: HuggingfaceTextResponse = HuggingfaceTextResponse {
        generated_text: "",
    };
    return (a, resp);
}

/// Feature extraction (embeddings) via HuggingFace Inference API
fn huggingface_feature_extraction(adapter: HuggingfaceAdapter, input: string, input_len: int) -> (HuggingfaceAdapter, int) {
    // POST https://api-inference.huggingface.co/models/sentence-transformers/all-MiniLM-L6-v2
    // Headers: Authorization: Bearer {api_key}
    // Body: {"inputs":"text to embed"}
    // Returns: float array of embedding values
    let mut a = adapter;
    a.connected = 1;
    return (a, 1); // Success
}

/// Health check — GET https://api-inference.huggingface.co/status
fn huggingface_health_check(adapter: HuggingfaceAdapter) -> int {
    return 1;
}

/// Provider name
fn huggingface_provider_name() -> string {
    return "HuggingFace Inference";
}

/// Supported model families (popular open-weight models)
fn huggingface_supported_models() -> string {
    return "mistralai/Mistral-7B-Instruct-v0.3,meta-llama/Llama-3.2-3B-Instruct,google/gemma-2-2b-it,microsoft/phi-3-mini-4k,Qwen/Qwen2.5-7B-Instruct,deepseek-ai/DeepSeek-R1-Distill-Qwen-7B,sentence-transformers/all-MiniLM-L6-v2";
}