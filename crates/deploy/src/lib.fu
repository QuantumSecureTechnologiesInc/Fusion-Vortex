// NOTE: Converted into FSN mirror under fsn/converted.
use anyhow::Result;

struct DeployResult {
    pub endpoint: FString,
}

fn deploy(platform: &str, env: &str, _config: Option<&str>) -> Result<DeployResult> {
    println!("Deploying to {} (env: {})", platform, env);
    Ok(DeployResult {
        endpoint: format!("https://{}-{}.example.com", env, platform),
    })
}
