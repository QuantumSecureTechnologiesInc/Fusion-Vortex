//! Fusion compiler main entry point.
//! Full pipeline: parse → sema → vortex → IR → optimize → codegen

mod stage1_parser_api;
mod stage1_sema_api;
mod ast;
mod lexer;
mod parser;
mod sema;
mod vortex;
mod ir;
mod optimizer;
mod codegen;
mod wasm;
mod llvm;
mod cli;

extern fn printf(fmt: string, ...) -> int;

pub fn main() -> int {
    let args = cli::parseargs();
    let result = stage1_parser_api::compile_entry(args);
    return result;
}
