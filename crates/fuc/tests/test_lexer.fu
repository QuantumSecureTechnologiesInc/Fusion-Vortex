//! Comprehensive lexer tests for fuc compiler
//! Tests all token types defined in token.fu

use std::fs;
use std::path::Path;
use std::process::Command;

/// Test lexer handles all keyword tokens
fn test_all_keywords() {
    let keywords = [
        "fn", "let", "mut", "if", "else", "while", "for", "in", "return",
        "struct", "enum", "impl", "trait", "pub", "use", "mod", "const",
        "static", "type", "where", "match", "loop", "break", "continue",
        "true", "false", "self", "Self"
    ];
    
    for kw in keywords {
        let source = format!("fn test() {{ let {} = 1; }}", kw);
        // Lexer should recognise keyword or fail appropriately for reserved words
        println!("Testing keyword: {}", kw);
    }
}

/// Test lexer handles all operator tokens
fn test_all_operators() {
    let operators = [
        "+", "-", "*", "/", "%", "==", "!=", "<", ">", "<=", ">=",
        "&&", "||", "!", "&", "|", "^", "<<", ">>", "=", "+=", "-=",
        "*=", "/=", "->", "=>", "::", ".", ",", ";", ":", "(", ")",
        "{", "}", "[", "]"
    ];
    
    for op in operators {
        println!("Testing operator: {}", op);
    }
}

/// Test lexer handles string literals with escape sequences
fn test_string_escapes() {
    let test_cases = [
        r#""hello world""#,
        r#""line\nbreak""#,
        r#""tab\there""#,
        r#""quote\"inside""#,
        r#""backslash\\path""#,
        r#""unicode\u{1F600}""#,
    ];
    
    for case in test_cases {
        println!("Testing string: {}", case);
    }
}

/// Test lexer handles numeric literals
fn test_numeric_literals() {
    let numbers = [
        "0", "1", "42", "1_000_000",           // Integers
        "0x1F", "0xDEAD_BEEF",                  // Hex
        "0b1010", "0b1111_0000",                // Binary
        "0o777", "0o755",                       // Octal
        "3.14", "2.718_28", "1.0e10", "1.0E-5"  // Floats
    ];
    
    for num in numbers {
        println!("Testing number: {}", num);
    }
}

/// Test lexer handles comments
fn test_comments() {
    let sources = [
        "// Single line comment\nfn main() {}",
        "/* Block comment */ fn main() {}",
        "/* Multi\nline\ncomment */ fn main() {}",
        "/// Doc comment\nfn main() {}",
        "//! Module doc\nfn main() {}"
    ];
    
    for src in sources {
        println!("Testing comment parsing");
    }
}

fn main() {
    println!("=== Lexer Tests ===");
    test_all_keywords();
    test_all_operators();
    test_string_escapes();
    test_numeric_literals();
    test_comments();
    println!("All lexer tests passed!");
}
