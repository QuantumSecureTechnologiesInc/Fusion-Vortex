struct Point {
    x: int,
    y: int
}

struct Rect {
    top_left: Point,
    bottom_right: Point
}

struct PtrNode {
    value: int,
    next: *PtrNode
}

fn main() -> int {
    let x_val: int = 10;
    let y_val: int = 20;

    let p1: Point = Point { x: x_val, y: y_val };
    let val: int = p1.y;

    let x: int = 100;
    let y: int = 200;
    let p2: Point = Point { x, y };

    let p3: Point = Point { x, y: 500 };

    let r: Rect = Rect { top_left: p2, bottom_right: p2 };
    r.top_left.x = 0;

    let i: int = 5;
    return 0;
}
