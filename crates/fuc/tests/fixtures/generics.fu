//! Test generic types and trait implementations

/// Generic identity function
fn identity<T>(x: T) -> T {
    x
}

/// Generic pair struct
struct Pair<A, B> {
    first: A,
    second: B
}

impl<A, B> Pair<A, B> {
    fn new(a: A, b: B) -> Self {
        Pair { first: a, second: b }
    }
    
    fn swap(self) -> Pair<B, A> {
        Pair { first: self.second, second: self.first }
    }
}

/// Generic option type
enum Option<T> {
    Some(T),
    None
}

impl<T> Option<T> {
    fn is_some(self) -> FBool {
        match self {
            Option::Some(_) => true,
            Option::None => false
        }
    }
    
    fn unwrap_or(self, default: T) -> T {
        match self {
            Option::Some(v) => v,
            Option::None => default
        }
    }
}

/// Trait definition
trait Displayable {
    fn display(self) -> FString;
}

impl Displayable for FInt {
    fn display(self) -> FString {
        format!("{}", self)
    }
}

impl Displayable for FBool {
    fn display(self) -> FString {
        if self { "true" } else { "false" }
    }
}

/// Generic function with trait bound
fn print_displayable<T: Displayable>(item: T) {
    println!("{}", item.display());
}

fn main() {
    // Test identity
    let int_id = identity(42);
    let str_id = identity("hello");
    println!("identity(42) = {}", int_id);
    println!("identity(hello) = {}", str_id);
    
    // Test Pair
    let pair = Pair::new(1, "one");
    println!("pair.first = {}", pair.first);
    println!("pair.second = {}", pair.second);
    
    let swapped = pair.swap();
    println!("swapped.first = {}", swapped.first);
    
    // Test Option
    let some_val: Option<FInt> = Option::Some(42);
    let none_val: Option<FInt> = Option::None;
    
    println!("some_val.is_some() = {}", some_val.is_some());
    println!("none_val.is_some() = {}", none_val.is_some());
    println!("none_val.unwrap_or(99) = {}", none_val.unwrap_or(99));
    
    // Test trait bounds
    print_displayable(123);
    print_displayable(true);
    
    println!("All generic tests passed!");
}
