// Simple Fusion test program for self-hosting verification

extern fn printf(fmt: string, ...) -> int;

pub fn add(a: int, b: int) -> int {
    return a + b;
}

pub fn main() -> int {
    let x: int = 42;
    let y: int = 58;
    let z: int = add(x, y);
    printf("Result: %d\n", z);
    return 0;
}