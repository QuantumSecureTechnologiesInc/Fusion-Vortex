use fusion_agent_spec::{AgentPlan, PlanStep};
use serde::{Deserialize, Serialize};
/// Agent execution state
#[derive(Debug, Clone, Copy, PartialEq, Eq, Serialize, Deserialize)]
enum AgentState {
    /// Agent is idle, waiting to start
    Idle,
    /// Agent is currently executing
    Running,
    /// Agent execution is paused
    Paused,
    /// Agent has completed all steps
    Completed,
    /// Agent encountered an error
    Failed,
}
/// Agent execution graph
///
/// Manages the state machine and cursor-based execution of an agent plan.
/// **Partial execution is just a cursor. No magic. No async spaghetti.**
struct AgentGraph {
    plan: AgentPlan,
    state: AgentState,
    cursor: FSize,
    executed_steps: FVec<FString>,
}
impl AgentGraph {
    /// Create a new agent graph from a plan
    ///
    /// # Example
    /// ```
    /// use fusion_agent_spec::AgentPlan;
    /// use fusion_agent_graph::AgentGraph;
    ///
    /// let plan = AgentPlan::new("plan-1", "Test goal");
    /// let graph = AgentGraph::new(plan);
    /// assert_eq!(graph.state(), AgentState::Idle);
    /// ```
    pub fn new(plan: AgentPlan) -> Self {
        Self {
            plan,
            state: AgentState::Idle,
            cursor: 0,
            executed_steps: vec![],
        }
    }
    /// Get the current execution state
    pub fn state(&self) -> AgentState {
        self.state
    }
    /// Get the next step to execute
    ///
    /// Returns `None` if all steps are complete or if the agent is not in a running state
    pub fn next_step(&self) -> Option<&PlanStep> {
        if self.cursor < self.plan.steps.len() {
            Some(&self.plan.steps[self.cursor])
        } else {
            None
        }
    }
    /// Advance to the next step
    ///
    /// Updates the cursor and transitions state as needed
    pub fn advance(&mut self) {
        if let Some(step) = self.next_step() {
            self.executed_steps.push(step.id.clone());
        }
        self.cursor += 1;
        if self.cursor >= self.plan.steps.len() {
            self.state = AgentState::Completed;
        } else if self.state == AgentState::Idle {
            self.state = AgentState::Running;
        }
    }
    /// Pause the agent execution
    pub fn pause(&mut self) {
        if self.state == AgentState::Running {
            self.state = AgentState::Paused;
        }
    }
    /// Resume the agent execution
    pub fn resume(&mut self) {
        if self.state == AgentState::Paused {
            self.state = AgentState::Running;
        }
    }
    /// Mark the agent as failed
    pub fn fail(&mut self) {
        self.state = AgentState::Failed;
    }
    /// Get the current cursor position
    pub fn cursor(&self) -> FSize {
        self.cursor
    }
    /// Get the total number of steps in the plan
    pub fn total_steps(&self) -> FSize {
        self.plan.steps.len()
    }
    /// Get the list of executed step IDs
    pub fn executed_steps(&self) -> &[FString] {
        &self.executed_steps
    }
    /// Get the current step's rationale (if available)
    pub fn current_rationale(&self) -> Option<FString> {
        self.next_step().map(|s| s.rationale.clone())
    }
    /// Calculate the percentage of completion
    pub fn completion_percentage(&self) -> f64 {
        if self.total_steps() == 0 {
            100.0
        } else {
            (self.cursor as f64 / self.total_steps() as f64) * 100.0
        }
    }
    /// Get remaining estimated cost
    pub fn remaining_cost(&self) -> f64 {
        self.plan.steps[self.cursor..].iter().map(|step| step.cost_estimate).sum()
    }
    /// Reset the graph to initial state (useful for replay)
    pub fn reset(&mut self) {
        self.cursor = 0;
        self.state = AgentState::Idle;
        self.executed_steps.clear();
    }
    /// Get a reference to the underlying plan
    pub fn plan(&self) -> &AgentPlan {
        &self.plan
    }
}
#[cfg(test)]
mod tests {
    use super::*;
    use fusion_agent_spec::PlanStep;
    use serde_json::json;
    fn create_test_plan() -> AgentPlan {
        let mut plan = AgentPlan::new("test-plan", "Test execution");
        plan.add_step(PlanStep::new("step-1", "tool1", json!({}), "First step", 1.0));
        plan.add_step(PlanStep::new("step-2", "tool2", json!({}), "Second step", 2.0));
        plan.add_step(PlanStep::new("step-3", "tool3", json!({}), "Third step", 3.0));
        plan
    }
    #[test]
    fn test_agent_graph_state_transitions() {
        let plan = create_test_plan();
        let mut graph = AgentGraph::new(plan);
        assert_eq!(graph.state(), AgentState::Idle);
        assert_eq!(graph.cursor(), 0);
        graph.advance();
        assert_eq!(graph.state(), AgentState::Running);
        assert_eq!(graph.cursor(), 1);
        graph.advance();
        assert_eq!(graph.state(), AgentState::Running);
        assert_eq!(graph.cursor(), 2);
        graph.advance();
        assert_eq!(graph.state(), AgentState::Completed);
        assert_eq!(graph.cursor(), 3);
    }
    #[test]
    fn test_pause_and_resume() {
        let plan = create_test_plan();
        let mut graph = AgentGraph::new(plan);
        graph.advance();
        assert_eq!(graph.state(), AgentState::Running);
        graph.pause();
        assert_eq!(graph.state(), AgentState::Paused);
        graph.resume();
        assert_eq!(graph.state(), AgentState::Running);
    }
    #[test]
    fn test_executed_steps_tracking() {
        let plan = create_test_plan();
        let mut graph = AgentGraph::new(plan);
        assert_eq!(graph.executed_steps().len(), 0);
        graph.advance();
        assert_eq!(graph.executed_steps().len(), 1);
        assert_eq!(graph.executed_steps() [0], "step-1");
        graph.advance();
        assert_eq!(graph.executed_steps().len(), 2);
        assert_eq!(graph.executed_steps() [1], "step-2");
    }
    #[test]
    fn test_completion_percentage() {
        let plan = create_test_plan();
        let mut graph = AgentGraph::new(plan);
        assert_eq!(graph.completion_percentage(), 0.0);
        graph.advance();
        assert!((graph.completion_percentage() - 33.333).abs() < 0.01);
        graph.advance();
        assert!((graph.completion_percentage() - 66.666).abs() < 0.01);
        graph.advance();
        assert_eq!(graph.completion_percentage(), 100.0);
    }
    #[test]
    fn test_remaining_cost() {
        let plan = create_test_plan();
        let mut graph = AgentGraph::new(plan);
        assert_eq!(graph.remaining_cost(), 6.0);
        graph.advance();
        assert_eq!(graph.remaining_cost(), 5.0);
        graph.advance();
        assert_eq!(graph.remaining_cost(), 3.0);
        graph.advance();
        assert_eq!(graph.remaining_cost(), 0.0);
    }
    #[test]
    fn test_reset() {
        let plan = create_test_plan();
        let mut graph = AgentGraph::new(plan);
        graph.advance();
        graph.advance();
        assert_eq!(graph.cursor(), 2);
        assert_eq!(graph.executed_steps().len(), 2);
        graph.reset();
        assert_eq!(graph.cursor(), 0);
        assert_eq!(graph.state(), AgentState::Idle);
        assert_eq!(graph.executed_steps().len(), 0);
    }
    #[test]
    fn test_current_rationale() {
        let plan = create_test_plan();
        let mut graph = AgentGraph::new(plan);
        assert_eq!(graph.current_rationale(), Some("First step".to_string()));
        graph.advance();
        assert_eq!(graph.current_rationale(), Some("Second step".to_string()));
        graph.advance();
        assert_eq!(graph.current_rationale(), Some("Third step".to_string()));
        graph.advance();
        assert_eq!(graph.current_rationale(), None);
    }
}
