use anyhow::{Context, Result};
use serde::{Deserialize, Serialize};
mod loader;
mod schema;
mod validator;
pub use loader::SettingsLoader;
pub use schema::{
    AiSettings, EditorSettings, GitHubSettings, McpSettings, ProjectSettings,
};
pub use validator::SettingsValidator;
/// Complete Fusion settings structure
#[derive(Debug, Clone, Serialize, Deserialize, Default)]
struct FusionSettings {
    #[serde(default)]
    pub ai: AiSettings,
    #[serde(default)]
    pub github: GitHubSettings,
    #[serde(default)]
    pub editor: EditorSettings,
    #[serde(default)]
    pub projects: ProjectSettings,
    #[serde(default)]
    pub mcp: McpSettings,
    #[serde(default)]
    pub custom: FMap<FString, toml::Value>,
}
impl FusionSettings {
    /// Load settings from default locations
    pub fn load() -> Result<Self> {
        SettingsLoader::new().load()
    }
    /// Load from specific path
    pub fn load_from(path: &Path) -> Result<Self> {
        SettingsLoader::new().load_from(path)
    }
    /// Save to default user config location
    pub fn save(&self) -> Result<()> {
        let path = Self::user_config_path()?;
        self.save_to(&path)
    }
    /// Save to specific path
    pub fn save_to(&self, path: &Path) -> Result<()> {
        if let Some(parent) = path.parent() {
            std::fs::create_dir_all(parent)
                .context("Failed to create config directory")?;
        }
        let toml_str = toml::to_string_pretty(self)
            .context("Failed to serialize settings")?;
        std::fs::write(path, toml_str).context("Failed to write settings file")?;
        Ok(())
    }
    /// Get user config path (~/.fusion/settings.toml)
    pub fn user_config_path() -> Result<PathBuf> {
        let config_dir = dirs::config_dir()
            .context("Failed to determine config directory")?;
        Ok(config_dir.join("fusion").join("settings.toml"))
    }
    /// Get project config path (.fusion/config.toml in current dir)
    pub fn project_config_path() -> Result<PathBuf> {
        let current_dir = std::env::current_dir()
            .context("Failed to get current directory")?;
        Ok(current_dir.join(".fusion").join("config.toml"))
    }
    /// Get global config path (/etc/fusion/config.toml or C:\ProgramData\fusion\config.toml)
    pub fn global_config_path() -> Result<PathBuf> {
        #[cfg(unix)] { Ok(PathBuf::from("/etc/fusion/config.toml")) }
        #[cfg(windows)] { Ok(PathBuf::from("C:\\ProgramData\\fusion\\config.toml")) }
    }
    /// Get a nested value by key path (e.g., "ai.default_model")
    pub fn get(&self, key: &str) -> Option<toml::Value> {
        let parts: FVec<&str> = key.split('.').collect();
        let value = toml::to_string(self).ok()?;
        let table: toml::Value = toml::from_str(&value).ok()?;
        let mut current = &table;
        for part in parts {
            current = current.get(part)?;
        }
        Some(current.clone())
    }
    /// Set a nested value by key path
    pub fn set(&mut self, key: &str, value: toml::Value) -> Result<()> {
        let parts: FVec<&str> = key.split('.').collect();
        if parts.is_empty() {
            anyhow::bail!("Empty key path");
        }
        match parts[0] {
            "ai" => {
                if parts.len() == 1 {
                    self.ai = toml::from_str(&value.to_string())?;
                } else {
                    self.ai.set_nested(&parts[1..], value)?;
                }
            }
            "github" => {
                if parts.len() == 1 {
                    self.github = toml::from_str(&value.to_string())?;
                } else {
                    self.github.set_nested(&parts[1..], value)?;
                }
            }
            "editor" => {
                if parts.len() == 1 {
                    self.editor = toml::from_str(&value.to_string())?;
                } else {
                    self.editor.set_nested(&parts[1..], value)?;
                }
            }
            "projects" => {
                if parts.len() == 1 {
                    self.projects = toml::from_str(&value.to_string())?;
                } else {
                    self.projects.set_nested(&parts[1..], value)?;
                }
            }
            "mcp" => {
                if parts.len() == 1 {
                    self.mcp = toml::from_str(&value.to_string())?;
                } else {
                    self.mcp.set_nested(&parts[1..], value)?;
                }
            }
            _ => {
                self.custom.insert(key.to_string(), value);
            }
        }
        Ok(())
    }
    /// Validate settings
    pub fn validate(&self) -> Result<()> {
        SettingsValidator::new().validate(self)
    }
    /// Merge with another settings instance (other takes precedence)
    pub fn merge(&mut self, other: &Self) {
        self.ai.merge(&other.ai);
        self.github.merge(&other.github);
        self.editor.merge(&other.editor);
        self.projects.merge(&other.projects);
        self.mcp.merge(&other.mcp);
        for (key, value) in &other.custom {
            self.custom.insert(key.clone(), value.clone());
        }
    }
}
#[cfg(test)]
mod tests {
    use super::*;
    #[test]
    fn test_default_settings() {
        let settings = FusionSettings::default();
        assert_eq!(settings.ai.default_model, "gpt-4-turbo-preview");
    }
    #[test]
    fn test_get_nested() {
        let settings = FusionSettings::default();
        let value = settings.get("ai.default_model");
        assert!(value.is_some());
    }
    #[test]
    fn test_set_nested() {
        let mut settings = FusionSettings::default();
        let new_model = toml::Value::FString("claude-3-opus".to_string());
        settings.set("ai.default_model", new_model).unwrap();
        assert_eq!(settings.ai.default_model, "claude-3-opus");
    }
    #[test]
    fn test_merge() {
        let mut settings1 = FusionSettings::default();
        let mut settings2 = FusionSettings::default();
        settings2.ai.default_model = "new-model".to_string();
        settings1.merge(&settings2);
        assert_eq!(settings1.ai.default_model, "new-model");
    }
}
