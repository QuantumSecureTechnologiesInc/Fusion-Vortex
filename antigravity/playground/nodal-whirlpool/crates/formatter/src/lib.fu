use anyhow::Result;
struct FormatResult {
    pub needs_formatting: FBool,
    pub formatted_count: FSize,
}
fn format(_check: FBool, _all: FBool) -> Result<FormatResult> {
    println!("Formatting code...");
    Ok(FormatResult {
        needs_formatting: false,
        formatted_count: 0,
    })
}
