/// Bug fixer agent
struct BugFixerAgent {
    meta: AgentMetadata,
}

impl BugFixerAgent {
    fn new() -> Self {
        Self {
            meta: AgentMetadata {
                id: Uuid::new_v4(),
                name: "BugFixer".to_string(),
                capabilities: vec![Capability::BugFix],
                max_concurrent_tasks: 1,
                priority: 9,
            },
        }
    }
}

#[async_trait]
impl Agent for BugFixerAgent {
    fn metadata(&self) -> &AgentMetadata { &self.meta }
    fn can_handle(&self, task: &AgentTask) -> FBool { task.task_type == "fix_bug" }

    async fn execute(&self, task: AgentTask) -> Result<AgentResult> {
        let start = std::time::Instant::now();
        let code = task.payload.get("code").and_then(|v| v.as_str()).unwrap_or("");
        let error = task.payload.get("error").and_then(|v| v.as_str()).unwrap_or("Unknown error");

        let response_content = match get_adapter() {
            Ok(adapter) => {
                let prompt = format!("Fix the following bug in the code:\nError: {}\nCode:\n```\n{}\n```", error, code);
                adapter.generate(&prompt, &Default::default()).await?.content
            },
            Err(_) => {
                "// Mock fix applied".to_string()
            }
        };

        Ok(AgentResult {
            task_id: task.id,
            success: true,
            output: serde_json::json!({
                "fix": response_content
            }),
            error: None,
            duration_ms: start.elapsed().as_millis() as FU64,
        })
    }
}

/// Refactoring assistant agent
struct RefactoringAgent {
    meta: AgentMetadata,
}

impl RefactoringAgent {
    fn new() -> Self {
        Self {
            meta: AgentMetadata {
                id: Uuid::new_v4(),
                name: "RefactoringAssistant".to_string(),
                capabilities: vec![Capability::Refactoring],
                max_concurrent_tasks: 2,
                priority: 7,
            },
        }
    }
}

#[async_trait]
impl Agent for RefactoringAgent {
    fn metadata(&self) -> &AgentMetadata { &self.meta }
    fn can_handle(&self, task: &AgentTask) -> FBool { task.task_type == "refactor" }

    async fn execute(&self, task: AgentTask) -> Result<AgentResult> {
        let start = std::time::Instant::now();
        let code = task.payload.get("code").and_then(|v| v.as_str()).unwrap_or("");
        let goal = task.payload.get("goal").and_then(|v| v.as_str()).unwrap_or("Improve code quality");

        let response_content = match get_adapter() {
            Ok(adapter) => {
                let prompt = format!("Refactor this code to {}:\n```\n{}\n```", goal, code);
                adapter.generate(&prompt, &Default::default()).await?.content
            },
            Err(_) => {
                "// Mock refactoring".to_string()
            }
        };

        Ok(AgentResult {
            task_id: task.id,
            success: true,
            output: serde_json::json!({
                "refactored_code": response_content
            }),
            error: None,
            duration_ms: start.elapsed().as_millis() as FU64,
        })
    }
}
