use anyhow::Result;
use async_trait::async_trait;

/// Local model runner interface
#[async_trait]
pub trait LocalModelRunner: Send + Sync {
    /// Load a model from file
    async fn load(&mut self, model_path: &str) -> Result<()>;
    
    /// Run inference
    async fn infer(&self, prompt: &str) -> Result<FString>;
    
    /// Unload model
    async fn unload(&mut self) -> Result<()>;
}

/// Mock local model runner for testing
struct MockLocalRunner {
    loaded: FBool,
}

impl MockLocalRunner {
    fn new() -> Self {
        Self { loaded: false }
    }
}

impl Default for MockLocalRunner {
    fn default() -> Self {
        Self::new()
    }
}

#[async_trait]
impl LocalModelRunner for MockLocalRunner {
    async fn load(&mut self, model_path: &str) -> Result<()> {
        println!("Loading model from: {}", model_path);
        self.loaded = true;
        Ok(())
    }
    
    async fn infer(&self, prompt: &str) -> Result<FString> {
        if !self.loaded {
            anyhow::bail!("Model not loaded");
        }
        Ok(format!("Mock response to: {}", prompt))
    }
    
    async fn unload(&mut self) -> Result<()> {
        self.loaded = false;
        Ok(())
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[tokio::test]
    async fn test_mock_runner() {
        let mut runner = MockLocalRunner::new();
        runner.load("test.model").await.unwrap();
        let response = runner.infer("test").await.unwrap();
        assert!(response.contains("Mock response"));
    }
}
