// test_collections.fu - Comprehensive test suite for collections library

// Import all collection types
use hash::Hash;
use hash::Eq;
use iterator::Iterator;
use iterator::RangeIterator;
use iterator::range;
use iterator::count;
use iterator::sum;
use hashmap::HashMap;
use hashset::HashSet;

// Test Hash trait implementations
fn test_hash_int() {
    let x = 42;
    let h = x.hash();
    assert(h == 42, "int hash should be identity");
}

fn test_hash_bool() {
    let t = true;
    let f = false;
    assert(t.hash() == 1, "true hash should be 1");
    assert(f.hash() == 0, "false hash should be 0");
}

// Test Iterator trait
fn test_range_iterator() {
    let mut iter = range(0, 5);
    
    assert(iter.has_next() == true, "should have next");
    let first = iter.next();
    assert(first.is_some(), "should get Some");
    assert(first.unwrap() == 0, "first should be 0");
    
    let second = iter.next();
    assert(second.unwrap() == 1, "second should be 1");
}

fn test_range_count() {
    let iter = range(0, 10);
    let c = count(iter);
    assert(c == 10, "count should be 10");
}

fn test_range_sum() {
    let iter = range(1, 11); // 1..10
    let total = sum(iter);
    assert(total == 55, "sum(1..10) should be 55");
}

// Test HashMap
fn test_hashmap_new() {
    let map = HashMap::<int, string>::new();
    assert(map.is_empty(), "new map should be empty");
    assert(map.len() == 0, "new map length should be 0");
    assert(map.capacity() == 16, "default capacity should be 16");
}

fn test_hashmap_with_capacity() {
    let map = HashMap::<int, string>::with_capacity(32);
    assert(map.capacity() == 32, "custom capacity should be 32");
}

fn test_hashmap_insert() {
    let mut map = HashMap::<int, string>::new();
    
    let old1 = map.insert(1, "one");
    assert(old1.is_none(), "first insert should return None");
    assert(map.len() == 1, "length should be 1");
    
    map.insert(2, "two");
    assert(map.len() == 2, "length should be 2");
}

fn test_hashmap_get() {
    let mut map = HashMap::<int, string>::new();
    map.insert(1, "one");
    
    let value = map.get(1);
    // Note: Stub implementation returns None
    // In real implementation: assert(value.unwrap() == "one");
}

fn test_hashmap_contains_key() {
    let mut map = HashMap::<int, string>::new();
    map.insert(1, "one");
    
    let has_one = map.contains_key(1);
    let has_two = map.contains_key(2);
    
    // Note: Stub implementation may not work correctly
    // In real implementation:
    // assert(has_one == true, "should contain key 1");
    // assert(has_two == false, "should not contain key 2");
}

fn test_hashmap_remove() {
    let mut map = HashMap::<int, string>::new();
    map.insert(1, "one");
    map.insert(2, "two");
    
    let removed = map.remove(1);
    assert(map.len() == 1, "length should be 1 after remove");
}

fn test_hashmap_clear() {
    let mut map = HashMap::<int, string>::new();
    map.insert(1, "one");
    map.insert(2, "two");
    
    map.clear();
    assert(map.is_empty(), "map should be empty after clear");
    assert(map.len() == 0, "length should be 0 after clear");
}

fn test_hashmap_resize() {
    let mut map = HashMap::<int, string>::with_capacity(4);
    let initial_capacity = map.capacity();
    
    // Insert enough to trigger resize (threshold = 0.75 * 4 = 3)
    map.insert(1, "one");
    map.insert(2, "two");
    map.insert(3, "three");
    map.insert(4, "four"); // Should trigger resize
    
    let new_capacity = map.capacity();
    assert(new_capacity == initial_capacity * 2, "capacity should double");
}

// Test HashSet
fn test_hashset_new() {
    let set = HashSet::<int>::new();
    assert(set.is_empty(), "new set should be empty");
    assert(set.len() == 0, "new set length should be 0");
}

fn test_hashset_insert() {
    let mut set = HashSet::<int>::new();
    
    let inserted1 = set.insert(1);
    assert(inserted1 == true, "first insert should return true");
    assert(set.len() == 1, "length should be 1");
    
    let inserted2 = set.insert(1); // Duplicate
    // In real implementation: assert(inserted2 == false);
}

fn test_hashset_contains() {
    let mut set = HashSet::<int>::new();
    set.insert(1);
    
    let has_one = set.contains(1);
    let has_two = set.contains(2);
    
    // Note: Stub implementation returns false
    // In real implementation:
    // assert(has_one == true);
    // assert(has_two == false);
}

fn test_hashset_remove() {
    let mut set = HashSet::<int>::new();
    set.insert(1);
    set.insert(2);
    
    let removed = set.remove(1);
    assert(removed == true, "remove existing should return true");
    assert(set.len() == 1, "length should be 1 after remove");
}

fn test_hashset_union() {
    let mut set1 = HashSet::<int>::new();
    set1.insert(1);
    set1.insert(2);
    
    let mut set2 = HashSet::<int>::new();
    set2.insert(2);
    set2.insert(3);
    
    let union = set1.union(set2);
    // In real implementation: assert(union.len() == 3);
}

fn test_hashset_intersection() {
    let mut set1 = HashSet::<int>::new();
    set1.insert(1);
    set1.insert(2);
    
    let mut set2 = HashSet::<int>::new();
    set2.insert(2);
    set2.insert(3);
    
    let intersection = set1.intersection(set2);
    // In real implementation: assert(intersection.len() == 1);
}

fn test_hashset_difference() {
    let mut set1 = HashSet::<int>::new();
    set1.insert(1);
    set1.insert(2);
    
    let mut set2 = HashSet::<int>::new();
    set2.insert(2);
    set2.insert(3);
    
    let difference = set1.difference(set2);
    // In real implementation: assert(difference.len() == 1);
}

fn test_hashset_is_subset() {
    let mut set1 = HashSet::<int>::new();
    set1.insert(1);
    
    let mut set2 = HashSet::<int>::new();
    set2.insert(1);
    set2.insert(2);
    
    let is_sub = set1.is_subset(set2);
    // In real implementation: assert(is_sub == true);
}

// Main test runner
fn main() -> int {
    // Hash tests
    test_hash_int();
    test_hash_bool();
    
    // Iterator tests
    test_range_iterator();
    test_range_count();
    test_range_sum();
    
    // HashMap tests
    test_hashmap_new();
    test_hashmap_with_capacity();
    test_hashmap_insert();
    test_hashmap_get();
    test_hashmap_contains_key();
    test_hashmap_remove();
    test_hashmap_clear();
    test_hashmap_resize();
    
    // HashSet tests
    test_hashset_new();
    test_hashset_insert();
    test_hashset_contains();
    test_hashset_remove();
    test_hashset_union();
    test_hashset_intersection();
    test_hashset_difference();
    test_hashset_is_subset();
    
    return 0; // All tests passed
}
