// Test Vector<T> implementation

fn main() -> int {
    let v = Vector::<int>::new();
    
    v.push(10);
    v.push(20);
    v.push(30);
    
    print("Vector length:");
    print(v.len());
    
    let first = v.get(0);
    print("First element:");
    print(first);
    
    let second = v.get(1);
    print("Second element:");
    print(second);
    
    let third = v.get(2);
    print("Third element:");
    print(third);
    
    v.free();
    
    return 0;
}
