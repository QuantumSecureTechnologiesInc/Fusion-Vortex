// ----------------------------
// Test
// ----------------------------
fn assert_true(v: bool, msg: string) -> void {
    if v { return; }
    panic(msg);
}
fn assert_eq_int(a: int, b: int, msg: string) -> void {
    if a == b { return; }
    panic(msg);
}
fn assert_eq_string(a: string, b: string, msg: string) -> void {
    if a == b { return; }
    panic(msg);
}
