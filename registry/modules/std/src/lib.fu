// Fusion Standard Library (full .fu replacement, simplified for core language limits)
// Note: enums, traits, generics, and async are not yet supported by the compiler.
// This implementation provides functional equivalents using concrete types and prefixes.

extern fn malloc(size: int) -> int;
extern fn free(ptr: int) -> void;
extern fn realloc(ptr: int, size: int) -> int;
extern fn memcpy(dest: int, src: int, n: int) -> void;
extern fn strlen(s: string) -> int;
extern fn printf(fmt: string, val: int) -> int;
extern fn puts(s: string) -> int;
extern fn exit(code: int) -> void;
extern fn string_starts_with(s: string, prefix: string) -> bool;
extern fn fusion_read_line() -> string;
extern fn fusion_fs_read_to_string(path: string) -> string;
extern fn fusion_fs_write_str(path: string, contents: string) -> bool;
extern fn fusion_fs_append_str(path: string, contents: string) -> bool;
extern fn fusion_fs_exists(path: string) -> bool;
extern fn fusion_fs_create_dir(path: string) -> bool;
extern fn fusion_fs_remove_file(path: string) -> bool;
extern fn fusion_path_join(a: string, b: string) -> string;
extern fn fusion_path_basename(p: string) -> string;
extern fn fusion_path_dirname(p: string) -> string;
extern fn fusion_env_get(key: string) -> string;
extern fn fusion_argc() -> int;
extern fn fusion_argv(idx: int) -> string;
extern fn fusion_time_now_ms() -> int;
extern fn fusion_sleep_ms(ms: int) -> void;
extern fn fusion_rand_seed(seed: int) -> void;
extern fn fusion_rand_next() -> int;
extern fn fusion_hash32(s: string) -> int;
extern fn fusion_hmac32(key: string, msg: string) -> int;
extern fn fusion_fmt_int(v: int) -> string;
extern fn fusion_fmt_pair(k: string, v: string) -> string;
extern fn fusion_json_escape(s: string) -> string;
extern fn fusion_json_kv_string(k: string, v: string) -> string;
extern fn fusion_json_kv_int(k: string, v: int) -> string;
extern fn fusion_tcp_connect(host: string, port: int) -> int;
extern fn fusion_tcp_send_str(fd: int, data: string) -> int;
extern fn fusion_tcp_recv_str(fd: int, max_bytes: int) -> string;
extern fn fusion_tcp_close(fd: int) -> void;
extern fn fusion_udp_send_str(host: string, port: int, data: string) -> int;
extern fn fusion_udp_recv_str(port: int, max_bytes: int) -> string;
extern fn fusion_mutex_new() -> int;
extern fn fusion_mutex_lock(handle: int) -> void;
extern fn fusion_mutex_unlock(handle: int) -> void;
extern fn fusion_mutex_free(handle: int) -> void;

// ----------------------------
// Primitives
// ----------------------------
struct FInt { value: int }
struct FBool { value: bool }
struct FString { value: string }

fn f_int_new(v: int) -> FInt { let x: FInt = FInt { value: v }; return x; }
fn f_int_val(v: FInt) -> int { return v.value; }

fn f_bool_new(v: bool) -> FBool { let x: FBool = FBool { value: v }; return x; }
fn f_bool_val(v: FBool) -> bool { return v.value; }

fn f_string_new(v: string) -> FString { let x: FString = FString { value: v }; return x; }
fn f_string_val(v: FString) -> string { return v.value; }

// ----------------------------
// Collections (fixed-size vector of int)
// ----------------------------
struct FVecInt { data: [int; 1024], len: int }

fn fvec_new() -> FVecInt {
    let v: FVecInt = FVecInt { data: [0; 1024], len: 0 };
    return v;
}

fn fvec_len(v: FVecInt) -> int { return v.len; }
fn fvec_is_empty(v: FVecInt) -> bool { return v.len == 0; }

fn fvec_push(v: FVecInt, value: int) -> FVecInt {
    if v.len < 1024 {
        v.data[v.len] = value;
        v.len = v.len + 1;
    }
    return v;
}

fn fvec_get(v: FVecInt, index: int) -> int {
    if v.len == 0 { return 0; }
    if index < 0 { return 0; }
    if index > v.len - 1 { return 0; }
    return v.data[index];
}

// ----------------------------
// Security Context (stateless helpers)
// ----------------------------
struct FusionContext { classical_sig: string, pq_sig: string }

fn fusion_ctx_new(classical: string, pq: string) -> FusionContext {
    let ctx: FusionContext = FusionContext { classical_sig: classical, pq_sig: pq };
    return ctx;
}

fn fusion_ctx_verify(ctx: FusionContext) -> bool {
    if strlen(ctx.classical_sig) > 0 {
        if strlen(ctx.pq_sig) > 0 { return true; }
        return false;
    }
    return false;
}

// ----------------------------
// IO helpers
// ----------------------------
fn print_line(s: string) -> void { puts(s); }
fn print_int(n: int) -> void { printf("%d\n", n); }

// ----------------------------
// Core narrative (simplified)
// ----------------------------
struct Verse { message: string }
struct Narrative { id: string, chapter: string, author: string, verse_count: int }

fn narrative_start(chapter: string, author: string) -> Narrative {
    let n: Narrative = Narrative { id: "narrative", chapter: chapter, author: author, verse_count: 0 };
    return n;
}

fn narrative_record(n: Narrative, _msg: string) -> Narrative {
    n.verse_count = n.verse_count + 1;
    return n;
}

fn narrative_conclude_success(_n: Narrative, _summary: string) -> string { return "ok"; }

// ----------------------------
// Cycle / Market (simplified)
// ----------------------------
struct ComputeNode { id: string, reputation_score: int, is_active: bool, region: string }

fn compute_node_new(id: string, region: string) -> ComputeNode {
    let n: ComputeNode = ComputeNode { id: id, reputation_score: 100, is_active: true, region: region };
    return n;
}

fn compute_node_is_trustworthy(n: ComputeNode, min_score: int) -> bool {
    if n.reputation_score > min_score { return true; }
    return n.reputation_score == min_score;
}

struct MarketBid { max_price_per_hour: int, currency_symbol: string }

fn market_bid_new(amount: int) -> MarketBid {
    let bid: MarketBid = MarketBid { max_price_per_hour: amount, currency_symbol: "$" };
    return bid;
}

fn market_bid_negotiate(bid: MarketBid, node: ComputeNode) -> bool {
    let node_rate: int = if node.reputation_score > 90 { 50 } else { 20 };
    if bid.max_price_per_hour > node_rate { return true; }
    return bid.max_price_per_hour == node_rate;
}

// ----------------------------
// Seal / Guards (simplified)
// ----------------------------
fn seal_sanitise(s: string) -> string { return s; }

// ----------------------------
// Memory utilities
// ----------------------------
fn alloc(size: int) -> int { return malloc(size); }
fn release(ptr: int) -> void { free(ptr); }
fn resize(ptr: int, size: int) -> int { return realloc(ptr, size); }
fn copy(dest: int, src: int, n: int) -> void { memcpy(dest, src, n); }
fn str_len(s: string) -> int { return strlen(s); }

fn panic(msg: string) -> void {
    print_line("PANIC:");
    print_line(msg);
    exit(1);
}

// ----------------------------
// AI Core (pure .fu)
// ----------------------------
struct AiSession { provider: string, model: string, offline: bool }
struct LlmRuntime { model_path: string }

fn llm_runtime_new(model_path: string) -> LlmRuntime {
    let rt: LlmRuntime = LlmRuntime { model_path: model_path };
    return rt;
}

fn ai_session_new(provider: string, model: string, offline: bool) -> AiSession {
    let s: AiSession = AiSession { provider: provider, model: model, offline: offline };
    return s;
}

fn ai_session_provider(s: AiSession) -> string { return s.provider; }
fn ai_session_model(s: AiSession) -> string { return s.model; }
fn ai_session_offline(s: AiSession) -> bool { return s.offline; }

fn ai_session_from_env(provider: string, model: string, offline: bool) -> AiSession {
    return ai_session_new(provider, model, offline);
}

// ----------------------------
// Telemetry (pure .fu)
// ----------------------------
struct RuntimeContext { env: int, region: string, version: string }

fn runtime_context_current() -> RuntimeContext {
    let ctx: RuntimeContext = RuntimeContext { env: 0, region: "local", version: "1.0.0" };
    return ctx;
}

// ----------------------------
// Cycle Errors / Agreements (pure .fu)
// ----------------------------
struct CycleFailure { code: int, message: string, agreement_id: string, required: int, offered: int }
struct ServiceAgreement { id: string, provider: ComputeNode, payload_hash: string, state: int }

fn cycle_failure_contract_breach(agreement_id: string, reason: string) -> CycleFailure {
    let e: CycleFailure = CycleFailure { code: 1, message: reason, agreement_id: agreement_id, required: 0, offered: 0 };
    return e;
}

fn cycle_failure_insufficient_bid(required: int, offered: int) -> CycleFailure {
    let e: CycleFailure = CycleFailure { code: 2, message: "INSUFFICIENT_BID", agreement_id: "", required: required, offered: offered };
    return e;
}

fn agreement_draft(provider: ComputeNode, payload_hash: string) -> ServiceAgreement {
    let a: ServiceAgreement = ServiceAgreement { id: "agreement", provider: provider, payload_hash: payload_hash, state: 0 };
    return a;
}

fn agreement_sign_terms(a: ServiceAgreement, bid: MarketBid) -> ServiceAgreement {
    if a.state != 0 { return a; }
    if market_bid_negotiate(bid, a.provider) { a.state = 1; }
    return a;
}

fn agreement_execute_workload(a: ServiceAgreement) -> string {
    if a.state != 1 { return "CONTRACT_NOT_SIGNED"; }
    return "EXECUTING";
}

fn agreement_settle(a: ServiceAgreement) -> ServiceAgreement {
    a.state = 3;
    return a;
}

// ----------------------------
// Flow (pure .fu)
// ----------------------------
struct FluxState { id: string, tick: int }

fn flux_state_new(id: string) -> FluxState {
    let f: FluxState = FluxState { id: id, tick: 0 };
    return f;
}

fn flux_state_step(f: FluxState) -> FluxState {
    f.tick = f.tick + 1;
    return f;
}

// ----------------------------
// Seal (pure .fu)
// ----------------------------
struct SecurityViolation { reason: string }

fn security_violation(reason: string) -> SecurityViolation {
    let v: SecurityViolation = SecurityViolation { reason: reason };
    return v;
}

fn ensure_system_operational(active: bool) -> bool {
    if active { return true; }
    return false;
}

fn ensure_clearance(user_id: string) -> bool {
    if string_starts_with(user_id, "usr_") { return true; }
    return string_starts_with(user_id, "admin_");
}

fn sanitise(input: string) -> string { return input; }

// ----------------------------
// Stdlib IO/FS (pure .fu)
// ----------------------------
fn stdio_println(s: string) -> void { puts(s); }
fn stdio_print(s: string) -> void { printf("%s", s); }
fn stdio_read_line() -> string { return fusion_read_line(); }

fn fs_read_to_string(path: string) -> string { return fusion_fs_read_to_string(path); }
fn fs_write_str(path: string, contents: string) -> bool { return fusion_fs_write_str(path, contents); }
fn fs_append_str(path: string, contents: string) -> bool { return fusion_fs_append_str(path, contents); }
fn fs_exists(path: string) -> bool { return fusion_fs_exists(path); }
fn fs_create_dir(path: string) -> bool { return fusion_fs_create_dir(path); }
fn fs_remove_file(path: string) -> bool { return fusion_fs_remove_file(path); }

// ----------------------------
// Path / Env
// ----------------------------
fn path_join(a: string, b: string) -> string { return fusion_path_join(a, b); }
fn path_basename(p: string) -> string { return fusion_path_basename(p); }
fn path_dirname(p: string) -> string { return fusion_path_dirname(p); }
fn env_get(key: string) -> string { return fusion_env_get(key); }
fn env_argc() -> int { return fusion_argc(); }
fn env_argv(idx: int) -> string { return fusion_argv(idx); }

// ----------------------------
// Time
// ----------------------------
fn time_now_ms() -> int { return fusion_time_now_ms(); }
fn sleep_ms(ms: int) -> void { fusion_sleep_ms(ms); }

// ----------------------------
// Math
// ----------------------------
fn math_abs(v: int) -> int { if v < 0 { return 0 - v; } return v; }
fn math_min(a: int, b: int) -> int { if a < b { return a; } return b; }
fn math_max(a: int, b: int) -> int { if a > b { return a; } return b; }
fn math_clamp(v: int, lo: int, hi: int) -> int {
    if v < lo { return lo; }
    if v > hi { return hi; }
    return v;
}

// ----------------------------
// Random
// ----------------------------
fn rand_seed(seed: int) -> void { fusion_rand_seed(seed); }
fn rand_next() -> int { return fusion_rand_next(); }

