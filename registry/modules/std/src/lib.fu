fn tcp_recv(fd: int, max_bytes: int) -> string { return fusion_tcp_recv_str(fd, max_bytes); }
fn tcp_close(fd: int) -> void { fusion_tcp_close(fd); }
fn udp_send(host: string, port: int, data: string) -> int { return fusion_udp_send_str(host, port, data); }
fn udp_recv(port: int, max_bytes: int) -> string { return fusion_udp_recv_str(port, max_bytes); }

