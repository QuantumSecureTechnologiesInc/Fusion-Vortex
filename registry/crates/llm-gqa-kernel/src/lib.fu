/// Production GQA Kernel.
/// 
/// Implements the Key/Value repetition logic for Grouped Query Attention (GQA).
/// Reduces memory bandwidth usage during decoding.

use fusion_core::types::tensor::{Tensor, Matrix, Vector1D};
use fusion_core::{FusionResult, FusionError};

pub struct GqaKernel;

impl GqaKernel {
    /// Repeats Key/Value states to match the number of Query heads.
    /// Input K/V: [SeqLen, KV_Dim]. Output Q/V: [SeqLen, Q_Dim].
    pub fn repeat_kv(kv_tensor: &Matrix<f64>, num_q_heads: FSize, num_kv_heads: FSize) -> FusionResult<Matrix<f64>> {
        let (seq_len, kv_dim) = (kv_tensor.shape[0], kv_tensor.shape[1]);
        if num_q_heads % num_kv_heads != 0 {
             return Err(FusionError::InvalidDimension("Q heads must be divisible by KV heads.".into()));
        }

        let head_dim = kv_dim / num_kv_heads;
        let repetition_factor = num_q_heads / num_kv_heads;

        let new_dim = num_q_heads * head_dim;
        let mut new_data = Vec::with_capacity(seq_len * new_dim);

        // Perform repetition loop (core logic of GQA)
        for t in 0..seq_len {
            for kv_head in 0..num_kv_heads {
                let kv_head_start = kv_head * head_dim;
                let kv_head_end = kv_head_start + head_dim;

                // Repeat the data 'repetition_factor' times
                for _ in 0..repetition_factor {
                    for i in kv_head_start..kv_head_end {
                        let val = kv_tensor.get([t, i])?;
                        new_data.push(val);
                    }
                }
            }
        }

        Tensor::new(new_data, [seq_len, new_dim])
    }
}
