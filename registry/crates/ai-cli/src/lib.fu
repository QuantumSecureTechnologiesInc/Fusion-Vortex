// __FU_COMPAT_START__
#![allow(missing_docs)]
use std::path::PathBuf;
#[allow(missing_docs, dead_code)] type FBool = bool;
#[allow(missing_docs, dead_code)] type FSize = usize;
#[allow(missing_docs, dead_code)] type FVec<T> = Vec<T>;
// __FU_COMPAT_END__
use anyhow::Result;
pub mod commands;
pub mod interactive;
use fusion_ai_core::{
    AdapterConfig, AnthropicConfig, DeepSeekConfig, GemmaConfig, GoogleConfig,
    GptOssConfig, LocalConfig, MistralConfig, ModelSession, OllamaConfig,
    OpenAIConfig, PatchMetadata, PhiConfig, PreviewEngine, PromptManager,
    QwenConfig, SafetyEngine, UnifiedAdapter, WorkspaceLoader,
};
pub fn get_adapter(offline: FBool) -> Result<Box<dyn ModelSession>> {
    if offline {
        let config = LocalConfig::default();
        return Ok(
            UnifiedAdapter::from_config(AdapterConfig::Local(config))?.create_session(),
        );
    }
    if let Ok(provider) = std::env::var("FUSION_AI_PROVIDER") {
        let provider = provider.to_lowercase();
        match provider.as_str() {
            "ollama" => {
                let mut config = OllamaConfig::default();
                if let Ok(url) = std::env::var("OLLAMA_BASE_URL") {
                    config.base_url = url;
                }
                if let Ok(model) = std::env::var("OLLAMA_MODEL") {
                    config.model = model;
                }
                return Ok(
                    UnifiedAdapter::from_config(AdapterConfig::Ollama(config))?
                        .create_session(),
                );
            }
            "gpt-oss" => {
                let mut config = GptOssConfig::default();
                if let Ok(url) = std::env::var("GPT_OSS_BASE_URL") {
                    config.base_url = url;
                }
                if let Ok(model) = std::env::var("GPT_OSS_MODEL") {
                    config.model = model;
                }
                return Ok(
                    UnifiedAdapter::from_config(AdapterConfig::GptOss(config))?
                        .create_session(),
                );
            }
            "mistral" => {
                let mut config = MistralConfig::default();
                if let Ok(key) = std::env::var("MISTRAL_API_KEY") {
                    config.api_key = key;
                }
                if let Ok(url) = std::env::var("MISTRAL_BASE_URL") {
                    config.base_url = url;
                }
                if let Ok(model) = std::env::var("MISTRAL_MODEL") {
                    config.model = model;
                }
                return Ok(
                    UnifiedAdapter::from_config(AdapterConfig::Mistral(config))?
                        .create_session(),
                );
            }
            "phi" => {
                let mut config = PhiConfig::default();
                if let Ok(url) = std::env::var("PHI_BASE_URL") {
                    config.base_url = url;
                }
                if let Ok(model) = std::env::var("PHI_MODEL") {
                    config.model = model;
                }
                return Ok(
                    UnifiedAdapter::from_config(AdapterConfig::Phi(config))?
                        .create_session(),
                );
            }
            "gemma" => {
                let mut config = GemmaConfig::default();
                if let Ok(url) = std::env::var("GEMMA_BASE_URL") {
                    config.base_url = url;
                }
                if let Ok(model) = std::env::var("GEMMA_MODEL") {
                    config.model = model;
                }
                return Ok(
                    UnifiedAdapter::from_config(AdapterConfig::Gemma(config))?
                        .create_session(),
                );
            }
            "qwen" => {
                let mut config = QwenConfig::default();
                if let Ok(key) = std::env::var("QWEN_API_KEY") {
                    config.api_key = key;
                }
                if let Ok(url) = std::env::var("QWEN_BASE_URL") {
                    config.base_url = url;
                }
                if let Ok(model) = std::env::var("QWEN_MODEL") {
                    config.model = model;
                }
                return Ok(
                    UnifiedAdapter::from_config(AdapterConfig::Qwen(config))?
                        .create_session(),
                );
            }
            "deepseek" => {
                let mut config = DeepSeekConfig::default();
                if let Ok(key) = std::env::var("DEEPSEEK_API_KEY") {
                    config.api_key = key;
                }
                if let Ok(url) = std::env::var("DEEPSEEK_BASE_URL") {
                    config.base_url = url;
                }
                if let Ok(model) = std::env::var("DEEPSEEK_MODEL") {
                    config.model = model;
                }
                return Ok(
                    UnifiedAdapter::from_config(AdapterConfig::DeepSeek(config))?
                        .create_session(),
                );
            }
            _ => {}
        }
    }
    if let Ok(url) = std::env::var("OLLAMA_BASE_URL") {
        let mut config = OllamaConfig::default();
        config.base_url = url;
        if let Ok(model) = std::env::var("OLLAMA_MODEL") {
            config.model = model;
        }
        return Ok(
            UnifiedAdapter::from_config(AdapterConfig::Ollama(config))?.create_session(),
        );
    }
    if let Ok(url) = std::env::var("GPT_OSS_BASE_URL") {
        let mut config = GptOssConfig::default();
        config.base_url = url;
        if let Ok(model) = std::env::var("GPT_OSS_MODEL") {
            config.model = model;
        }
        return Ok(
            UnifiedAdapter::from_config(AdapterConfig::GptOss(config))?
                .create_session(),
        );
    }
    if let Ok(key) = std::env::var("MISTRAL_API_KEY") {
        let mut config = MistralConfig::default();
        config.api_key = key;
        if let Ok(url) = std::env::var("MISTRAL_BASE_URL") {
            config.base_url = url;
        }
        if let Ok(model) = std::env::var("MISTRAL_MODEL") {
            config.model = model;
        }
        return Ok(
            UnifiedAdapter::from_config(AdapterConfig::Mistral(config))?
                .create_session(),
        );
    }
    if let Ok(url) = std::env::var("PHI_BASE_URL") {
        let mut config = PhiConfig::default();
        config.base_url = url;
        if let Ok(model) = std::env::var("PHI_MODEL") {
            config.model = model;
        }
        return Ok(
            UnifiedAdapter::from_config(AdapterConfig::Phi(config))?
                .create_session(),
        );
    }
    if let Ok(url) = std::env::var("GEMMA_BASE_URL") {
        let mut config = GemmaConfig::default();
        config.base_url = url;
        if let Ok(model) = std::env::var("GEMMA_MODEL") {
            config.model = model;
        }
        return Ok(
            UnifiedAdapter::from_config(AdapterConfig::Gemma(config))?
                .create_session(),
        );
    }
    if let Ok(key) = std::env::var("QWEN_API_KEY") {
        let mut config = QwenConfig::default();
        config.api_key = key;
        if let Ok(url) = std::env::var("QWEN_BASE_URL") {
            config.base_url = url;
        }
        if let Ok(model) = std::env::var("QWEN_MODEL") {
            config.model = model;
        }
        return Ok(
            UnifiedAdapter::from_config(AdapterConfig::Qwen(config))?.create_session(),
        );
    }
    if let Ok(key) = std::env::var("DEEPSEEK_API_KEY") {
        let mut config = DeepSeekConfig::default();
        config.api_key = key;
        if let Ok(url) = std::env::var("DEEPSEEK_BASE_URL") {
            config.base_url = url;
        }
        if let Ok(model) = std::env::var("DEEPSEEK_MODEL") {
            config.model = model;
        }
        return Ok(
            UnifiedAdapter::from_config(AdapterConfig::DeepSeek(config))?
                .create_session(),
        );
    }
    if let Ok(key) = std::env::var("OPENAI_API_KEY") {
        let config = OpenAIConfig {
            api_key: key,
            ..Default::default()
        };
        return Ok(
            UnifiedAdapter::from_config(AdapterConfig::OpenAI(config))?.create_session(),
        );
    }
    if let Ok(key) = std::env::var("ANTHROPIC_API_KEY") {
        let config = AnthropicConfig {
            api_key: key,
            ..Default::default()
        };
        return Ok(
            UnifiedAdapter::from_config(AdapterConfig::Anthropic(config))?
                .create_session(),
        );
    }
    if let Ok(key) = std::env::var("GOOGLE_API_KEY") {
        let config = GoogleConfig {
            api_key: key,
            ..Default::default()
        };
        return Ok(
            UnifiedAdapter::from_config(AdapterConfig::Google(config))?.create_session(),
        );
    }
    anyhow::bail!(
        "No API keys found. Please set OPENAI_API_KEY, ANTHROPIC_API_KEY, or GOOGLE_API_KEY.\n\
         Or use --offline to run with a local LLM."
    )
}
/// Start interactive AI assistant
pub fn assist(prompt: Option<&str>, offline: FBool) -> Result<()> {
    println!("🤖 Fusion AI Assistant");
    if let Some(p) = prompt {
        println!("\nPrompt: {}", p);
        match get_adapter(offline) {
            Ok(adapter) => {
                let rt = tokio::runtime::Runtime::new()?;
                let (response_text, _) = rt.block_on(adapter.predict(p))?;
                println!("\nResponse:\n{}", response_text);
            }
            Err(e) => {
                println!("\n⚠️  Error initializing AI adapter: {}", e);
            }
        }
    } else {
        interactive::start_session(offline)?;
    }
    Ok(())
}
/// Generate code from description
pub fn generate(
    description: &str,
    target: Option<&str>,
    preview_only: FBool,
    offline: FBool,
    _max_tokens: Option<FSize>,
) -> Result<()> {
    println!("🔧 Generating code: {}", description);
    let adapter = match get_adapter(offline) {
        Ok(a) => a,
        Err(e) => {
            println!("⚠️  Authentication failed: {}", e);
            return Ok(());
        }
    };
    let workspace_path = std::env::current_dir()?;
    let loader = WorkspaceLoader::new(workspace_path);
    let context = loader.load()?;
    println!("✓ Loaded workspace: {}", context.project_config.name);
    let prompt_manager = PromptManager::new();
    let mut vars = std::collections::HashMap::new();
    vars.insert("description".to_string(), description.to_string());
    let file_list = context
        .files
        .iter()
        .map(|f| f.path.display().to_string())
        .collect::<FVec<_>>()
        .join("\n");
    vars.insert("context".to_string(), format!("Files in project:\n{}", file_list));
    let prompt = prompt_manager
        .render("generate", &vars)
        .unwrap_or_else(|| format!("Generate Fusion code for: {}", description));
    println!("⏳ Contacting AI Model...");
    let rt = tokio::runtime::Runtime::new()?;
    let (generated_code, _) = rt.block_on(adapter.predict(&prompt))?;
    let safety_engine = SafetyEngine::new();
    let safety_report = safety_engine.verify(&generated_code);
    println!("🔒 Safety check: {:?}", safety_report.level);
    if safety_report.requires_review {
        println!("⚠️  Manual review required:");
        for issue in &safety_report.issues {
            println!("  - {:?}: {}", issue.kind, issue.description);
        }
    }
    let preview_engine = PreviewEngine::new();
    let metadata = PatchMetadata {
        model_id: adapter.provider_name().to_string(),
        prompt_hash: blake3::hash(description.as_bytes()).to_string(),
        timestamp: chrono::Utc::now().to_rfc3339(),
        safety_score: 0.95,
    };
    let target_file = target
        .map(PathBuf::from)
        .unwrap_or_else(|| PathBuf::from("src/generated.fu"));
    let original_content = if target_file.exists() {
        std::fs::read_to_string(&target_file).unwrap_or_default()
    } else {
        String::new()
    };
    let patch = preview_engine
        .generate_patch(
            target_file.clone(),
            &original_content,
            &generated_code,
            metadata,
        )?;
    println!("\n📄 Preview:");
    println!("File: {}", target_file.display());
    println!("\n{}", patch.diff);
    if !preview_only && !safety_report.requires_review {
        println!("\n✓ Applying changes...");
        if let Some(parent) = target_file.parent() {
            std::fs::create_dir_all(parent)?;
        }
        std::fs::write(&target_file, &generated_code)?;
        println!("✓ Changes applied to {}", target_file.display());
    } else if preview_only {
        println!("\n📋 Preview only - no changes applied");
    } else {
        println!("\n⏸️  Manual review required before applying");
    }
    Ok(())
}
/// Refactor existing code
pub fn refactor(
    description: &str,
    target: &str,
    preview_only: FBool,
    offline: FBool,
) -> Result<()> {
    println!("♻️  Refactoring: {} -> {}", target, description);
    let adapter = get_adapter(offline)?;
    let path = PathBuf::from(target);
    if !path.exists() {
        anyhow::bail!("Target file does not exist: {}", target);
    }
    let code = std::fs::read_to_string(&path)?;
    let prompt_manager = PromptManager::new();
    let mut vars = std::collections::HashMap::new();
    vars.insert("code".to_string(), code.clone());
    vars.insert("description".to_string(), description.to_string());
    let prompt = prompt_manager
        .render("refactor", &vars)
        .unwrap_or_else(|| {
            format!("Refactor this code: {}\n\nTo: {}", code, description)
        });
    println!("⏳ Contacting AI Model...");
    let rt = tokio::runtime::Runtime::new()?;
    let (new_code, _) = rt.block_on(adapter.predict(&prompt))?;
    let preview_engine = PreviewEngine::new();
    let metadata = PatchMetadata {
        model_id: adapter.provider_name().to_string(),
        prompt_hash: blake3::hash(description.as_bytes()).to_string(),
        timestamp: chrono::Utc::now().to_rfc3339(),
        safety_score: 1.0,
    };
    let patch = preview_engine.generate_patch(path.clone(), &code, &new_code, metadata)?;
    println!("\n📄 Preview:");
    println!("\n{}", patch.diff);
    if !preview_only {
        std::fs::write(&path, &new_code)?;
        println!("✓ Refactoring applied.");
    }
    Ok(())
}
/// Explain code
pub fn explain(target: &str, depth: &str, offline: FBool) -> Result<()> {
    println!("📖 Explaining: {} (depth: {})", target, depth);
    let adapter = get_adapter(offline)?;
    let path = PathBuf::from(target);
    let code = if path.exists() {
        std::fs::read_to_string(&path)?
    } else {
        target.to_string()
    };
    println!("⏳ Analyzing...");
    let rt = tokio::runtime::Runtime::new()?;
    let explanation = rt.block_on(adapter.explain(&code, depth))?;
    println!("\n🤖 Explanation:\n{}", explanation.summary);
    println!("\nDetails:");
    for detail in explanation.details {
        println!("- {}", detail);
    }
    Ok(())
}
/// Review code for issues
pub fn review(target: Option<&str>, focus: &str, offline: FBool) -> Result<()> {
    println!("🔍 Reviewing code (focus: {})", focus);
    let adapter = get_adapter(offline)?;
    let target_display = target.unwrap_or("src");
    let path = PathBuf::from(target_display);
    if !path.exists() {
        println!("Target path not found.");
        return Ok(());
    }
    if path.is_file() {
        let code = std::fs::read_to_string(&path)?;
        let prompt = format!(
            "Review this Fusion code focusing on {}:\n```fusion\n{}\n```", focus, code
        );
        println!("⏳ Reviewing...");
        let rt = tokio::runtime::Runtime::new()?;
        let (response, _) = rt.block_on(adapter.predict(&prompt))?;
        println!("\n📋 Review Report:\n{}", response);
    } else {
        println!(
            "Directory review not fully implemented in this step. Please specify a file."
        );
    }
    Ok(())
}
/// Generate tests
pub fn tests(target: &str, test_type: &str, offline: FBool) -> Result<()> {
    println!("🧪 Generating {} tests for: {}", test_type, target);
    let adapter = get_adapter(offline)?;
    let path = PathBuf::from(target);
    if !path.exists() {
        anyhow::bail!("Target not found");
    }
    let code = std::fs::read_to_string(&path)?;
    let prompt = format!(
        "Generate {} tests for the following Fusion code:\n```fusion\n{}\n```",
        test_type, code
    );
    println!("⏳ Generating...");
    let rt = tokio::runtime::Runtime::new()?;
    let (response, _) = rt.block_on(adapter.predict(&prompt))?;
    println!("\nTests:\n{}", response);
    Ok(())
}
/// Generate documentation
pub fn doc(target: &str, examples: FBool, offline: FBool) -> Result<()> {
    println!("📚 Generating documentation for: {}", target);
    let adapter = get_adapter(offline)?;
    let path = PathBuf::from(target);
    if !path.exists() {
        anyhow::bail!("Target not found");
    }
    let code = std::fs::read_to_string(&path)?;
    let prompt = format!(
        "Generate documentation for the following Fusion code. Examples: {}.\n```fusion\n{}\n```",
        examples, code
    );
    println!("⏳ Writing docs...");
    let rt = tokio::runtime::Runtime::new()?;
    let (response, _) = rt.block_on(adapter.predict(&prompt))?;
    println!("\nDocs:\n{}", response);
    Ok(())
}
/// Configure AI settings
pub fn config(show: FBool, model: Option<&str>, api_key: Option<&str>) -> Result<()> {
    if show {
        println!("🔧 Current AI Configuration:");
        if let Ok(k) = std::env::var("OPENAI_API_KEY") {
            println!("  OpenAI: Configured (*****{})", & k[k.len().min(4)..]);
        }
        if let Ok(k) = std::env::var("ANTHROPIC_API_KEY") {
            println!("  Anthropic: Configured (*****{})", & k[k.len().min(4)..]);
        }
        if let Ok(k) = std::env::var("GOOGLE_API_KEY") {
            println!("  Google: Configured (*****{})", & k[k.len().min(4)..]);
        }
        println!("  Local Mode: Available via --offline (default: localhost:11434)");
        if std::env::var("OPENAI_API_KEY").is_err()
            && std::env::var("ANTHROPIC_API_KEY").is_err()
            && std::env::var("GOOGLE_API_KEY").is_err()
        {
            println!("  No active online providers found.");
        }
    }
    if let Some(_m) = model {
        println!("✓ Model preference saved (implied)");
    }
    if let Some(_k) = api_key {
        println!("✓ API key updated (session only - set env var for persistence)");
    }
    Ok(())
}
