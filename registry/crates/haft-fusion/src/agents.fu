use log::{debug, info, warn};
use tokio::time::interval;
use crate::tensor::FluxTensor;
/// Base trait for all HAFT agents
#[async_trait::async_trait]
trait Agent: Send + Sync {
    /// Run the agent's main loop
    async fn run(&self);
    /// Get the agent's name
    fn name(&self) -> &str;
}
/// Researcher Agent: Analyzes statistical properties of the tensor
struct Researcher {
    tensor: Arc<FluxTensor>,
    variance_threshold: f64,
    interval_ms: FU64,
}
impl Researcher {
    pub fn new(tensor: Arc<FluxTensor>, variance_threshold: f64) -> Self {
        Self {
            tensor,
            variance_threshold,
            interval_ms: 5000,
        }
    }
}
#[async_trait::async_trait]
impl Agent for Researcher {
    async fn run(&self) {
        info!("[Researcher] Starting statistical analysis agent");
        let mut ticker = interval(Duration::from_millis(self.interval_ms));
        loop {
            ticker.tick().await;
            self.tensor.calculate_stats();
            let stats = self.tensor.get_stats();
            debug!(
                "[Researcher] Stats - Mean: {:.2}, Variance: {:.2}, Hot: {}, Cold: {}",
                stats.mean, stats.variance, stats.hot_count, stats.cold_count
            );
            if stats.variance > self.variance_threshold {
                warn!(
                    "[Researcher] High variance detected: {:.2} > {:.2}", stats.variance,
                    self.variance_threshold
                );
            }
            if stats.total_accesses > 0 {
                let hit_rate = (stats.cache_hits as f64 / stats.total_accesses as f64)
                    * 100.0;
                info!("[Researcher] Cache hit rate: {:.1}%", hit_rate);
            }
        }
    }
    fn name(&self) -> &str {
        "Researcher"
    }
}
/// Builder Agent: Manages memory and triggers compression
struct Builder {
    tensor: Arc<FluxTensor>,
    hot_limit: FSize,
    interval_ms: FU64,
}
impl Builder {
    pub fn new(tensor: Arc<FluxTensor>, hot_limit: FSize) -> Self {
        Self {
            tensor,
            hot_limit,
            interval_ms: 10000,
        }
    }
}
#[async_trait::async_trait]
impl Agent for Builder {
    async fn run(&self) {
        info!(
            "[Builder] Starting memory management agent (hot limit: {})", self.hot_limit
        );
        let mut ticker = interval(Duration::from_millis(self.interval_ms));
        loop {
            ticker.tick().await;
            let stats = self.tensor.get_stats();
            debug!(
                "[Builder] Memory check - Hot: {}/{}, Cold: {}", stats.hot_count, self
                .hot_limit, stats.cold_count
            );
            if stats.hot_count > self.hot_limit {
                let excess = stats.hot_count - self.hot_limit;
                info!(
                    "[Builder] Hot storage over limit ({} > {}), compressing {} elements",
                    stats.hot_count, self.hot_limit, excess
                );
                let compressed = self.tensor.compress(self.hot_limit);
                info!("[Builder] Compressed {} elements to cold storage", compressed);
            }
        }
    }
    fn name(&self) -> &str {
        "Builder"
    }
}
/// Optimizer Agent: Optimizes access patterns and memory layout
struct Optimizer {
    tensor: Arc<FluxTensor>,
    interval_ms: FU64,
}
impl Optimizer {
    pub fn new(tensor: Arc<FluxTensor>) -> Self {
        Self { tensor, interval_ms: 15000 }
    }
}
#[async_trait::async_trait]
impl Agent for Optimizer {
    async fn run(&self) {
        info!("[Optimizer] Starting optimization agent");
        let mut ticker = interval(Duration::from_millis(self.interval_ms));
        loop {
            ticker.tick().await;
            let stats = self.tensor.get_stats();
            debug!(
                "[Optimizer] Analyzing access patterns - Total accesses: {}", stats
                .total_accesses
            );
            if stats.total_accesses > 10000 {
                info!(
                    "[Optimizer] Resetting access patterns for fresh optimization cycle"
                );
                self.tensor.reset_access_patterns();
            }
            if stats.total_accesses > 0 {
                let hit_rate = (stats.cache_hits as f64 / stats.total_accesses as f64)
                    * 100.0;
                if hit_rate < 80.0 {
                    warn!(
                        "[Optimizer] Low cache efficiency: {:.1}% - consider adjusting hot limit",
                        hit_rate
                    );
                }
            }
        }
    }
    fn name(&self) -> &str {
        "Optimizer"
    }
}
/// Spawn all HAFT agents for a given tensor
async fn spawn_agents(tensor: Arc<FluxTensor>) {
    let researcher = Researcher::new(tensor.clone(), 1.0);
    let builder = Builder::new(tensor.clone(), 1_000_000);
    let optimizer = Optimizer::new(tensor.clone());
    tokio::spawn(async move { researcher.run().await });
    tokio::spawn(async move { builder.run().await });
    tokio::spawn(async move { optimizer.run().await });
    info!("All HAFT agents spawned successfully");
}
#[cfg(test)]
mod tests {
    use super::*;
    #[tokio::test]
    async fn test_agent_creation() {
        let tensor = Arc::new(FluxTensor::new(vec![10, 10]));
        let researcher = Researcher::new(tensor.clone(), 1.0);
        let builder = Builder::new(tensor.clone(), 50);
        let optimizer = Optimizer::new(tensor.clone());
        assert_eq!(researcher.name(), "Researcher");
        assert_eq!(builder.name(), "Builder");
        assert_eq!(optimizer.name(), "Optimizer");
    }
}
