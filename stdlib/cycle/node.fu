// Compute node stub (pure .fu)
// Reduced to fit 16-byte ABI

struct ComputeNode {
    id: int,
    score: int,
    active: int,
    region: int,
}

fn compute_node_new(id: int, region: int) -> ComputeNode {
    let n: ComputeNode = ComputeNode { id: id, score: 50, active: 1, region: region };
    return n;
}

fn compute_node_is_active(n: ComputeNode) -> int {
    if n.active != 0 { return 1; }
    return 0;
}
