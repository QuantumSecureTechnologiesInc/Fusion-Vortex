// Neural network layer interface

trait Layer {
    fn forward(self, input: Tensor<float>) -> Tensor<float>;
    fn backward(mut self, grad: Tensor<float>) -> Tensor<float>;
    fn parameters(self) -> Vector<Tensor<float>>;
}

// Example: Linear layer
class Linear implements Layer {
    weights: Tensor<float>;
    bias: Tensor<float>;
    input_size: int;
    output_size: int;
    
    fn new(input_size: int, output_size: int) -> Linear {
        // TODO: Initialize weights and bias
        // weights: random initialization (Xavier/He)
        // bias: zeros
        
        return Linear {
            weights: dummy_tensor(),
            bias: dummy_tensor(),
            input_size: input_size,
            output_size: output_size
        };
    }
    
    fn forward(self, input: Tensor<float>) -> Tensor<float> {
        // TODO: output = input @ weights + bias
        return input;
    }
    
   fn backward(mut self, grad: Tensor<float>) -> Tensor<float> {
        // TODO: Compute gradients
        // grad_input = grad @ weights^T
        // grad_weights = input^T @ grad
        // grad_bias = sum(grad, axis=0)
        return grad;
    }
    
    fn parameters(self) -> Vector<Tensor<float>> {
        let mut params = Vector::new();
        params.push(self.weights);
        params.push(self.bias);
        return params;
    }
}

