// stdlib/ml/mod.fu - Machine Learning Library Foundation
// Traits and interfaces for ML operations with GPU acceleration

// Tensor trait - Foundation for all ML operations
trait Tensor<T> {
    fn shape(self) -> Vector<int>;
    fn rank(self) -> int;
    fn size(self) -> int;
    fn reshape(mut self, new_shape: Vector<int>) -> Result<(), string>;
}

// Activation function trait
trait Activation {
    fn forward(x: Tensor<float>) -> Tensor<float>;
    fn backward(grad: Tensor<float>) -> Tensor<float>;
}

// Loss function trait  
trait Loss {
    fn compute(predicted: Tensor<float>, target: Tensor<float>) -> float;
    fn gradient(predicted: Tensor<float>, target: Tensor<float>) -> Tensor<float>;
}

// Optimizer trait
trait Optimizer {
    fn step(mut self, params: Vector<Tensor<float>>, grads: Vector<Tensor<float>>);
    fn zero_grad(mut self);
}

// GPU-accelerated annotation (compiler directive)
// Usage: @gpu_accelerated
// This tells the compiler to generate GPU kernel code

