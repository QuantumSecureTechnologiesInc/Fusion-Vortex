class Sigmoid implements Activation {
    fn forward(x: Tensor<float>) -> Tensor<float> {
        // TODO: 1 / (1 + exp(-x))
        return x;
    }
    
    fn backward(grad: Tensor<float>) -> Tensor<float> {
