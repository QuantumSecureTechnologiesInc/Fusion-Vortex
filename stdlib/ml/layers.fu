// Dropout layer for regularization
class Dropout {
    rate: float;  // Dropout rate (0.0 to 1.0)
    training: bool;
}

impl Dropout {
    fn new(rate: float) -> Dropout {
        return Dropout {
            rate: rate,
            training: true
        };
    }
    
    fn set_training(mut self, training: bool) {
        self.training = training;
    }
    
    fn forward(self, input: Tensor) -> Tensor {
        if !self.training {
            return input;
        }
        
        // During training, randomly drop neurons
        // Simplified: scale by (1 - rate) instead of masking
        let scale = 1.0 - self.rate;
        return scalar_multiply(input, scale);
    }
}

// Batch Normalization layer
class BatchNorm {
    epsilon: float;
    momentum: float;
    running_mean: Tensor;
    running_var: Tensor;
}

impl BatchNorm {
    fn new(num_features: int) -> BatchNorm {
        let mut shape = Vector::new();
        shape.push(num_features);
        
        return BatchNorm {
            epsilon: 0.00001,
            momentum: 0.9,
            running_mean: Tensor::zeros(shape),
            running_var: Tensor::ones(shape)
        };
    }
    
