// security context (pure .fu)

extern fn strlen(s: string) -> int;

struct FusionContext { classical_sig: string, pq_sig: string }

fn fusion_ctx_new(classical: string, pq: string) -> FusionContext {
    let ctx: FusionContext = FusionContext { classical_sig: classical, pq_sig: pq };
    return ctx;
}

fn fusion_ctx_verify(ctx: FusionContext) -> bool {
    if strlen(ctx.classical_sig) > 0 {
        if strlen(ctx.pq_sig) > 0 { return true; }
        return false;
    }
    return false;
}